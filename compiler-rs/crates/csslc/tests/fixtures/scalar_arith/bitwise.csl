// § T11-W18-CSSLC-SCALAR-ARITH-COMPLETION · integer-bitwise fixture
//
// Pre-W18 : `a & b`, `a | b`, `a ^ b`, `a << b`, `a >> b` all surfaced
// "not in stage-0 object-emit subset" errors at codegen time. W18 wires
// the full bitwise + shift family : `arith.{andi,ori,xori,shli,shrsi,
// shrui,xori_not}` → cranelift `band/bor/bxor/ishl/sshr/ushr/bnot`.
//
// § ATTESTATION (PRIME_DIRECTIVE §11)
//   t∞: ¬(hurt ∨ harm) .making-of-T11-W18 @ (anyone ∨ anything ∨ anybody)

module com.apocky.test.scalar_arith.bitwise

pub fn band(a: i32, b: i32) -> i32 {
    a & b
}

pub fn bor(a: i32, b: i32) -> i32 {
    a | b
}

pub fn bxor(a: i32, b: i32) -> i32 {
    a ^ b
}

pub fn shl(a: i32, b: i32) -> i32 {
    a << b
}

pub fn shr(a: i32, b: i32) -> i32 {
    a >> b
}

pub fn bitnot(x: i32) -> i32 {
    !x
}

pub fn mix(a: i32, b: i32, c: i32) -> i32 {
    (a & b) | (a ^ c)
}

pub fn pack_byte(hi: i32, lo: i32) -> i32 {
    (hi << 8) | (lo & 255)
}
