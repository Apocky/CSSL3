# § I> cross-editor consistency • applies repo-wide
# § I> trim-trailing-whitespace off for .md + .csl (preserves CSLv3-notation alignment)

root = true

[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true
indent_style             = space
indent_size              = 4

[*.{md,csl}]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.toml]
indent_size = 4

[Makefile]
indent_style = tab
