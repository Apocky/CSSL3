      ↳ regex-driven keyword-grammar baseline · LLM-bridge slot for F1 follow-on
    pub fn generate(req: &ProcgenRequest) -> ProcgenOutput
      ↳ BLAKE3-fingerprint-seeded · Fibonacci-disc crystal placement · pure-fn
    pub fn asset_fetch_stub(uri: &str) -> Result<Vec<u8>, FetchErr>
      ↳ returns empty Vec · F2 follow-on wires real HTTP
