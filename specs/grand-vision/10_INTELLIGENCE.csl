       ≡ {DM ⊕ GM ⊕ Collaborator ⊕ Coder} ; ¬ generic-AGI
       ≡ narrow-task-bounded ; ¬ open-vocabulary-goal-pursuit
  t∞: ¬ self-improvement-recursion
       ≡ ¬ role-rewrites-its-own-decision-policy mid-session
       ≡ KAN-splines BAKED @ comptime ; ¬ online-grad-update
  t∞: ¬ open-ended-goal-pursuit ; ∀ role responds-to player-action ; ¬ self-trigger
  t∞: ¬ cross-role-bleed  ‼ ; each-role bound-to its-own-cap-ladder
       ≡ inter-role transitions = explicit-handoff-events ¬ shared-state-mutate
  t∞: ∀ role ⊑ (sovereign-cap-bound · audit-emit · refusable-by-player · ¬ surveillance)
