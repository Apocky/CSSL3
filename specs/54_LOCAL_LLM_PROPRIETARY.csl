§I LlmBridge-TRAIT (contract)
  ⟦
    pub trait LlmBridge: Send + Sync {
        fn name(&self) -> &'static str ;
        fn mode(&self) -> LlmMode ;
        fn chat(&self, messages: &[LlmMessage]) -> Result<String, LlmError> ;
        fn chat_stream(...) ;
        fn cancel(&self) ;
    }
  ⟧

