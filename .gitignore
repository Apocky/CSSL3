# § I> Cargo.lock KEPT for R16 reproducibility (binary+library workspace)
# § I> .perf-baseline/ + tests/golden/ committed → regression-ratchet

# Rust build artifacts
/compiler-rs/target/
/target/
**/*.rs.bk

# IDE / editor ephemera
.idea/
.vscode/
*.swp
*.swo
*.swn

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# Coverage / profiling
/coverage/
*.profraw
*.profdata
flamegraph.svg
perf.data*

# Generated shader / codegen blobs (not committed — regenerated per-build)
# (golden references stored under tests/golden/ by explicit extension)
*.spv
*.dxil
*.msl.tmp

# § T11-W18-CSSLC-ADVANCE2 : csslc test-fixture object artifacts. The e2e
# tests emit `.obj` next to each `.csl` fixture (so parallel test runs
# don't collide on a shared output path) ; the .obj is regenerated every
# test run and must NOT be tracked in git.
compiler-rs/crates/csslc/tests/fixtures/**/*.obj

# Caches
.cache/
/compiler-rs/target-doc/

# § T11-LOA-LOG-1 : cssl-rt loa_startup writes a per-invocation runtime log
# under `logs/` (cwd-relative). Not committed.
**/logs/loa_runtime.log
**/logs/

# Claude Code ephemera + internal agent files
.claude/
CLAUDE.md
HANDOFF_SESSION_*.csl
SESSION_*_HANDOFF.md

# § T11-W17-J · Tauri/React frontend build artifacts (regenerated by `npm install` + `npm run build`)
**/frontend/node_modules/
**/frontend/dist/
**/frontend/package-lock.json
# § Cargo.lock files inside individual crate directories (workspace root Cargo.lock is canonical)
compiler-rs/crates/*/Cargo.lock
