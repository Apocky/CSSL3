# cssl-edge — environment variables (ALL OPTIONAL, stub-friendly)
# Copy to .env.local for local dev (or set in Vercel project settings for deploy).
# When unset, endpoints return well-shaped stub responses with `stub:true`.

# === Claude / Anthropic LLM (drives /api/intent text→scene-graph) ===
# Get from https://console.anthropic.com/
CLAUDE_API_KEY=

# === Lazarus autonomous LoA v14 runner ===
# DeepSeek key stays server/local-runner only; never expose via NEXT_PUBLIC_*.
DEEPSEEK_API_KEY=
# Runner calls DeepSeek only when explicitly enabled.
LAZARUS_ENABLE_MODEL_CALLS=0
LAZARUS_CONTROL_URL=http://localhost:3000
LAZARUS_RUNNER_ID=local-apocky
LAZARUS_RUNNER_LABEL=LoA v14 local Lazarus runner
LAZARUS_RUNNER_TOKEN=
# Set to 1 for one-shot smoke tests; keep 0/unset for the service runner loop.
LAZARUS_ONCE=0

# === Admin Chat (/admin/chat) ===
# The admin chat route does not fabricate responses. It calls DeepSeek when
# DEEPSEEK_API_KEY is set, otherwise Anthropic when ANTHROPIC_API_KEY or
# CLAUDE_API_KEY is set. Optional model override:
ADMIN_CHAT_MODEL=
ADMIN_CHAT_DEEPSEEK_MODEL=deepseek-reasoner
ADMIN_CHAT_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# === Supabase (cache + auth · drives /api/asset/* + /api/generate/* persistence) ===
# Get from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NEXT_PUBLIC_ variants are required for CLIENT-SIDE auth (OAuth, magic-link, /account page).
# Without these the auth buttons show stub-mode and sign-in is unavailable in the browser.
# Set them to the same values as SUPABASE_URL / SUPABASE_ANON_KEY above.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# === Free-asset upstream APIs (license-filtered proxy targets) ===
# Sketchfab Data API — https://sketchfab.com/developers/data-api/v3
SKETCHFAB_API_TOKEN=
# Polyhaven (CC0) — no key required, but rate-limit aware
POLYHAVEN_USER_AGENT=cssl-edge/0.1
# OpenGameArt — public scrape, no key
# Quaternius / Kenney — public CDNs, no key

# === Neural-3D providers (drives /api/generate/3d gateway) ===
# Stability AI — https://platform.stability.ai/
STABILITY_API_KEY=
# Meshy — https://www.meshy.ai/api
MESHY_API_KEY=
# Tripo — https://www.tripo3d.ai/
TRIPO_API_KEY=

# === Edge runtime config ===
# Override served_by tag (default "cssl-edge")
EDGE_SERVED_BY=cssl-edge
# Default cap when client omits it ("sovereign" | "none")
EDGE_DEFAULT_CAP=sovereign

# === MNEME memory service (specs/43..45) ===
# Anthropic API — Haiku 4.5 (extract/verify/classify/query) + Sonnet 4.6 (synth)
ANTHROPIC_API_KEY=
# Voyage AI — voyage-3-large 1024d embeddings
VOYAGE_API_KEY=
# Owner Ed25519 PK (64 hex chars) used to bind sovereign profile rows
MNEME_SOVEREIGN_PUBKEY_HEX=
# Per-profile default sigma mask (32 bytes hex = 64 chars). Optional; if set
# overrides the constructed `defaultMask()` in lib/mneme/sigma.ts.
MNEME_DEFAULT_MASK_HEX=
# Voyage timeout in ms (default 10000). Bump in slow-network environments.
MNEME_VOYAGE_TIMEOUT=10000
# Per-route recall cache TTL seconds (default 5; 0 disables).
MNEME_RECALL_CACHE_TTL_SECONDS=5
