    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "tsx": "^4.16.2",
    "typescript": "5.5.3"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
