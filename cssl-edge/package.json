{
  "name": "cssl-edge",
  "version": "0.1.0",
  "private": true,
  "description": "LoA-v13 Edge — public MCP gateway for CSSL/LoA scenes (Vercel-deployable Next.js)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "tsc --noEmit",
    "lint": "next lint",
    "test:health": "node --import tsx tests/api/health.test.ts",
    "test:companion": "node --import tsx tests/api/companion.test.ts",
    "test:sovereign": "node --import tsx tests/lib/sovereign.test.ts",
    "test:signaling": "node --import tsx tests/api/signaling.test.ts",
