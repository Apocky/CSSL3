// examples/test_visible_window.cssl
//
// § GOAL : open a 1280×720 window · pump messages for ~5 seconds via
//          tail-recursion · destroy · exit. If window appears + stays-open
//          while moving the mouse around, the cssl-host-window machinery
//          is fine and the engine-side state-machine has the bug.
//
// § BUILD : csslc.exe build examples/test_visible_window.cssl --emit=exe -o /tmp/win5s.exe
// § RUN   : /tmp/win5s.exe   → window should appear ~immediately and stay 5s
//
// § DIAGNOSTIC :
//   - window-appears + stays-5s  ⇒  cssl-host-window is fine · engine_run_loop has bug
//   - window-flickers-then-vanishes ⇒  pump-loop OR time-sleep issue
//   - no-window ⇒ cssl-rt delegation OR cssl-host-window spawn-failure
//
// § STAGE-0 SHAPES :
//   tail-recursion bounded · no while-loop · no mut · per FIX1-20 csslc support

module com.apocky.examples.test_visible_window

// Pump-for-N-frames @ ~60fps (16ms sleep) · tail-recursive · bounded.
fn pump_n(h : u64, n : i32) -> i32 {
    if n <= 0 {
        return 0i32
    }
    let _ = window::pump(h, 0i64, 0i64) ;
    let _ = time::sleep_ns(16_000_000u64) ;
    pump_n(h, n - 1i32)
}

fn main() -> i32 {
    // Spawn 1280×720 RESIZABLE | DPI_AWARE = 1|4 = 5
    let h : u64 = window::spawn(0i64, 0i64, 1280u32, 720u32, 5u32) ;
    if h == 0u64 {
        return 1i32
    }
    // Pump 300 frames · ~5 sec @ 60fps. Window should be visible + responsive.
    let _ = pump_n(h, 300i32) ;
    let _ = window::destroy(h) ;
    0i32
}
