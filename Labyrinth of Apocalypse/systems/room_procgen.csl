// KAN-bias query for rarity distribution at-this-room
extern "C" fn __cssl_kan_bias_rarity_dist(
    biome_id: u8,
    arc_pos: u8,
    consent_token: u64,
    out_weights_ptr: *mut u8,
    out_weights_cap: u32,
