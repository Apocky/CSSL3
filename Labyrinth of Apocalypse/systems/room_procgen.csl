#[test]
fn t07_npc_spawn_bounds() -> i32 {
    // Min/Max spawn bounds match Apocky-canonical per-room budget
    if NPC_SPAWN_MIN != 1u32  { return 1 ; }
    if NPC_SPAWN_MAX != 3u32  { return 2 ; }
    if LOOT_DROP_MIN != 3u32  { return 3 ; }
    if LOOT_DROP_MAX != 5u32  { return 4 ; }
    if NPC_SPAWN_MIN  > NPC_SPAWN_MAX { return 5 ; }
    if LOOT_DROP_MIN  > LOOT_DROP_MAX { return 6 ; }
    0
}

#[test]
fn t08_select_tier_canonical_coverage() -> i32 {
    // roll=0 → Common (always)
    let t0: u8 = select_tier_from_weights(
        DROP_RATE_COMMON_DEFAULT,
        DROP_RATE_UNCOMMON_DEFAULT,
        DROP_RATE_RARE_DEFAULT,
        DROP_RATE_EPIC_DEFAULT,
        DROP_RATE_LEGENDARY_DEFAULT,
        DROP_RATE_MYTHIC_DEFAULT,
        DROP_RATE_PRISMATIC_DEFAULT,
        DROP_RATE_CHAOTIC_DEFAULT,
        0u32,
    ) ;
    if t0 != RARITY_COMMON { return 1 ; }

    // roll=9999 → Chaotic (last bucket)
    let tlast: u8 = select_tier_from_weights(
        DROP_RATE_COMMON_DEFAULT,
        DROP_RATE_UNCOMMON_DEFAULT,
        DROP_RATE_RARE_DEFAULT,
        DROP_RATE_EPIC_DEFAULT,
        DROP_RATE_LEGENDARY_DEFAULT,
        DROP_RATE_MYTHIC_DEFAULT,
        DROP_RATE_PRISMATIC_DEFAULT,
        DROP_RATE_CHAOTIC_DEFAULT,
        9999u32,
    ) ;
    if tlast != RARITY_CHAOTIC { return 2 ; }

    // roll=5499 → boundary between Common (0..5499) and Uncommon (5500..)
    let t_boundary: u8 = select_tier_from_weights(
        DROP_RATE_COMMON_DEFAULT,
        DROP_RATE_UNCOMMON_DEFAULT,
        DROP_RATE_RARE_DEFAULT,
        DROP_RATE_EPIC_DEFAULT,
        DROP_RATE_LEGENDARY_DEFAULT,
        DROP_RATE_MYTHIC_DEFAULT,
        DROP_RATE_PRISMATIC_DEFAULT,
        DROP_RATE_CHAOTIC_DEFAULT,
        5499u32,
    ) ;
    if t_boundary != RARITY_COMMON { return 3 ; }

    // roll=5500 → boundary into Uncommon
    let t_uncommon: u8 = select_tier_from_weights(
        DROP_RATE_COMMON_DEFAULT,
        DROP_RATE_UNCOMMON_DEFAULT,
        DROP_RATE_RARE_DEFAULT,
        DROP_RATE_EPIC_DEFAULT,
        DROP_RATE_LEGENDARY_DEFAULT,
        DROP_RATE_MYTHIC_DEFAULT,
        DROP_RATE_PRISMATIC_DEFAULT,
        DROP_RATE_CHAOTIC_DEFAULT,
        5500u32,
    ) ;
    if t_uncommon != RARITY_UNCOMMON { return 4 ; }

    0
}

#[test]
fn t09_mix_u64_deterministic() -> i32 {
    // Same input → same output (replay-stable)
    let a: u64 = mix_u64(0xCAFE_BABE_DEAD_BEEFu64, 0x1234_5678_ABCD_EF01u64) ;
    let b: u64 = mix_u64(0xCAFE_BABE_DEAD_BEEFu64, 0x1234_5678_ABCD_EF01u64) ;
    if a != b { return 1 ; }

    // Different salts → different outputs (avalanche)
    let c: u64 = mix_u64(0xCAFE_BABE_DEAD_BEEFu64, 0x1234_5678_ABCD_EF02u64) ;
    if a == c { return 2 ; }

    0
}

#[test]
fn t10_idx_of_mix_zero_n_safe() -> i32 {
    // n=0 must not divide-by-zero · returns 0 by canon
    let i: u32 = idx_of_mix(0xCAFEu64, 0u32) ;
    if i != 0u32 { return 1 ; }

    // n=1 always returns 0
    let i1: u32 = idx_of_mix(0xCAFEu64, 1u32) ;
    if i1 != 0u32 { return 2 ; }

    // n=12 returns 0..11 (archetype-count safety)
    let i12: u32 = idx_of_mix(0xCAFEu64, 12u32) ;
    if i12 >= 12u32 { return 3 ; }

    0
}

#[test]
fn t11_axis_constants_distinct() -> i32 {
    if AXIS_NPC_ARCHETYPE     == AXIS_LOOT_RARITY    { return 1 ; }
    if AXIS_NPC_COUNT         == AXIS_LOOT_COUNT     { return 2 ; }
    if AXIS_INTERACTABLE_KIND == AXIS_NPC_ARCHETYPE  { return 3 ; }
    if AXIS_BIOME_MOOD        == AXIS_ROOM_TENSION   { return 4 ; }
    if AXIS_CAUSAL_VETO       == AXIS_NPC_COUNT      { return 5 ; }
    0
}

#[test]
fn t12_empty_room_contents_canonical_zeros() -> i32 {
    let r: RoomContents = empty_room_contents() ;
    if r.npc_count          != 0u32 { return 1 ; }
    if r.loot_count         != 0u32 { return 2 ; }
    if r.interactable_count != 0u32 { return 3 ; }
    if r.composition_seed   != 0u64 { return 4 ; }
    if r.composition_anchor != 0u64 { return 5 ; }
    0
}

