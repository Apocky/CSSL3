// ─────────────────────────────────────────────────────────────────────────
// § Cap-Matrix predicate helpers
// ─────────────────────────────────────────────────────────────────────────

// Check if a CapMatrix has a specific bit set. ALL bits default-deny — they
// must be explicitly granted for spawn to occur. ‼ Σ-mask invariant.
fn cap_has_bit(caps: &CapMatrix, bit: u32) -> bool {
    let masked: u32 = (*caps).bits & bit ;
    if masked == 0u32 { return false ; }
    return true ;
}

fn cap_allows_content(caps: &CapMatrix) -> bool {
    cap_has_bit(caps, CAP_BIT_CONTENT)
}

fn cap_allows_loot(caps: &CapMatrix) -> bool {
    cap_has_bit(caps, CAP_BIT_LOOT)
}

fn cap_allows_boss(caps: &CapMatrix) -> bool {
    cap_has_bit(caps, CAP_BIT_BOSS)
}

fn cap_allows_puzzle(caps: &CapMatrix) -> bool {
    cap_has_bit(caps, CAP_BIT_PUZZLE)
}

fn cap_allows_lore(caps: &CapMatrix) -> bool {
    cap_has_bit(caps, CAP_BIT_LORE)
}

fn cap_allows_trade(caps: &CapMatrix) -> bool {
    cap_has_bit(caps, CAP_BIT_TRADE)
}

fn cap_allows_kan_bias(caps: &CapMatrix) -> bool {
    if (*caps).consent_token == 0u64 { return false ; }
    cap_has_bit(caps, CAP_BIT_KAN_BIAS)
}

fn cap_allows_mycelium(caps: &CapMatrix) -> bool {
    if (*caps).consent_token == 0u64 { return false ; }
    cap_has_bit(caps, CAP_BIT_MYCELIUM)
}

// ─────────────────────────────────────────────────────────────────────────
// § Deterministic-mix helpers (substrate-stable hash · NOT crypto-strong)
// ─────────────────────────────────────────────────────────────────────────
//
// Used for selecting indices into substrate-supplied distributions. The actual
// random-bit-source is the (seed, dims, caps) tuple pre-mixed by the caller ;
// these helpers further mix sub-contexts deterministically. Replay-stable.
// substrate-side BLAKE3 anchors the canonical attestation ; these are local
// helpers for index-selection only.

fn mix_u64(state: u64, salt: u64) -> u64 {
    let mut x: u64 = state ^ salt ;
    x = x ^ (x >> 33u64) ;
    // u64 multiplicative-mixing (xorshift+lcg-ish · stable across replays)
    x = x ^ (x << 21u64) ;
    x = x ^ (x >> 17u64) ;
    x
}

// Reduce a u64 mix to a 0..N-1 index (modulo). Σ-mask-checked for non-zero N.
fn idx_of_mix(mixed: u64, n: u32) -> u32 {
    if n == 0u32 { return 0u32 ; }
    let n64: u64 = n as u64 ;
    let i: u64 = mixed % n64 ;
    i as u32
}

// Select a rarity-tier from a permyriad-weighted distribution.
// `weights[i]` = permyriad share of tier-i ; `total` = Σ weights ; `roll` = mixed-u64
// reduced mod 10000. Returns the tier discriminant 0..7.
fn select_tier_from_weights(
    w0: u32, w1: u32, w2: u32, w3: u32,
    w4: u32, w5: u32, w6: u32, w7: u32,
    roll: u32,
) -> u8 {
    // Cumulative scan
    let mut acc: u32 = 0u32 ;
    acc = acc + w0 ; if roll < acc { return RARITY_COMMON ;     }
    acc = acc + w1 ; if roll < acc { return RARITY_UNCOMMON ;   }
    acc = acc + w2 ; if roll < acc { return RARITY_RARE ;       }
    acc = acc + w3 ; if roll < acc { return RARITY_EPIC ;       }
    acc = acc + w4 ; if roll < acc { return RARITY_LEGENDARY ;  }
    acc = acc + w5 ; if roll < acc { return RARITY_MYTHIC ;     }
    acc = acc + w6 ; if roll < acc { return RARITY_PRISMATIC ;  }
    acc = acc + w7 ; if roll < acc { return RARITY_CHAOTIC ;    }
    // Fallback (overflow) → common (substrate-floor on misweight)
    RARITY_COMMON
}

// ─────────────────────────────────────────────────────────────────────────
// § NPC-count derivation  (substrate-evolved · 1..3 within bounds)
// ─────────────────────────────────────────────────────────────────────────
//
// Pulls AXIS_NPC_COUNT from substrate-intelligence ; clamps to [MIN..MAX].
// Falls back to 1 if substrate denies (Σ-mask floor).

fn derive_npc_count(intelligence_handle: u64, caps: &CapMatrix) -> u32 {
    if !cap_allows_content(caps) { return 0u32 ; }
    let raw: u64 = __cssl_intelligence_query_axis(intelligence_handle, AXIS_NPC_COUNT) ;
    // raw = 0 = substrate-denies → fallback floor 1
    if raw == 0u64 { return NPC_SPAWN_MIN ; }
    // Clamp to [1..3]
    let n: u32 = (raw % 3u64 + 1u64) as u32 ;
    if n < NPC_SPAWN_MIN { return NPC_SPAWN_MIN ; }
    if n > NPC_SPAWN_MAX { return NPC_SPAWN_MAX ; }
    n
}

// Loot-count derivation (3..5 within bounds)
fn derive_loot_count(intelligence_handle: u64, caps: &CapMatrix) -> u32 {
    if !cap_allows_loot(caps) { return 0u32 ; }
    let raw: u64 = __cssl_intelligence_query_axis(intelligence_handle, AXIS_LOOT_COUNT) ;
    if raw == 0u64 { return LOOT_DROP_MIN ; }
    let n: u32 = (raw % 3u64 + 3u64) as u32 ;
    if n < LOOT_DROP_MIN { return LOOT_DROP_MIN ; }
    if n > LOOT_DROP_MAX { return LOOT_DROP_MAX ; }
    n
}

// Interactable-count derivation (0..4 · gated by puzzle/lore/trade caps)
fn derive_interactable_count(intelligence_handle: u64, caps: &CapMatrix) -> u32 {
    let mut allowed_kinds: u32 = 0u32 ;
    if cap_allows_puzzle(caps) { allowed_kinds = allowed_kinds + 1u32 ; }
    if cap_allows_lore(caps)   { allowed_kinds = allowed_kinds + 1u32 ; }
    if cap_allows_trade(caps)  { allowed_kinds = allowed_kinds + 1u32 ; }
    if allowed_kinds == 0u32 { return 0u32 ; }
    let raw: u64 = __cssl_intelligence_query_axis(intelligence_handle, AXIS_INTERACTABLE_KIND) ;
    if raw == 0u64 { return 1u32 ; }
    let n: u32 = (raw % 4u64 + 1u64) as u32 ;
    if n > INTERACTABLE_MAX_PER_ROOM { return INTERACTABLE_MAX_PER_ROOM ; }
    n
}

// ─────────────────────────────────────────────────────────────────────────
// § NPC archetype selection  (KAN-bias + HDC-binding + causal-seed-veto)
// ─────────────────────────────────────────────────────────────────────────
//
// 4-step selection :
//   1. Pull KAN-archetype-distribution-weights (12 weights ; one per archetype)
//   2. Mix (room-seed · player-state) via HDC-bind into a roll
//   3. Reduce roll modulo Σ-weights → pick archetype index
//   4. Causal-seed-veto-check : if vetoed, fall back to Wanderer (safe-default)

fn select_npc_archetype(
    intelligence_handle: u64,
    seed_lo: u64,
    seed_hi: u64,
    dims: &RoomDims,
    caps: &CapMatrix,
    spawn_index: u32,
) -> u8 {
    // Step 1 : direct query the substrate-intelligence axis for this spawn's archetype.
    // The substrate already-incorporates KAN-bias + HDC-binding internally ; we
    // request the i-th spawn's archetype via salted axis-query.
    let salted: u64 = mix_u64(intelligence_handle, spawn_index as u64) ;
    let axis_handle: u64 = mix_u64(salted, AXIS_NPC_ARCHETYPE as u64) ;
    let raw: u64 = __cssl_intelligence_query_axis(axis_handle, AXIS_NPC_ARCHETYPE) ;

    // Step 2 : reduce raw to archetype-id 0..11
    let mut archetype: u8 = (raw % 12u64) as u8 ;
    if archetype >= archetype_count() { archetype = ARCHETYPE_WANDERER ; }

    // Step 3 : if archetype is MERCENARY/NOBLE/MERCHANT but caps don't allow trade,
    //          downgrade to Wanderer (Σ-mask substrate-floor)
    if archetype == ARCHETYPE_MERCHANT && !cap_allows_trade(caps) {
        archetype = ARCHETYPE_WANDERER ;
    }
    if archetype == ARCHETYPE_NOBLE && !cap_allows_trade(caps) {
        archetype = ARCHETYPE_WANDERER ;
    }

    // Step 4 : causal-seed veto-check (predict consequences ; default-zero-rarity for npc-only)
    let veto: u32 = __cssl_causal_seed_veto(archetype, RARITY_COMMON, seed_lo, seed_hi) ;
    if veto != 0u32 { return ARCHETYPE_WANDERER ; }

    archetype
}

// ─────────────────────────────────────────────────────────────────────────
// § Loot rarity selection  (KAN-bias + permyriad-weighted-roll + 8-tier ladder)
// ─────────────────────────────────────────────────────────────────────────
//
// Pulls the 8-tier permyriad distribution (KAN-modulated when consent granted,
// else falls back to defaults defined above). Mixes the seed with drop-index
// to produce a deterministic-replayable roll into [0..10000) ; reduces via the
// cumulative-scan helper `select_tier_from_weights`.

fn select_loot_rarity(
    intelligence_handle: u64,
    seed_lo: u64,
    dims: &RoomDims,
    caps: &CapMatrix,
    drop_index: u32,
) -> u8 {
    // Pull weights : KAN-modulated if consent-granted ; defaults otherwise.
    // (Substrate-side fills 8 × u32 LE bytes into out_weights_ptr · stage-0 stub
    //  may return immediately ; we use the defaults if KAN unavailable.)
    let mut w0: u32 = DROP_RATE_COMMON_DEFAULT ;
    let mut w1: u32 = DROP_RATE_UNCOMMON_DEFAULT ;
    let mut w2: u32 = DROP_RATE_RARE_DEFAULT ;
    let mut w3: u32 = DROP_RATE_EPIC_DEFAULT ;
    let mut w4: u32 = DROP_RATE_LEGENDARY_DEFAULT ;
    let mut w5: u32 = DROP_RATE_MYTHIC_DEFAULT ;
    let mut w6: u32 = DROP_RATE_PRISMATIC_DEFAULT ;
    let mut w7: u32 = DROP_RATE_CHAOTIC_DEFAULT ;

    // KAN-bias : substrate writes 8 × u32 LE on success · 0..32 bytes
    // (We intentionally do not perform unsafe writes from .csl source ; the
    //  substrate-intelligence handle's AXIS_LOOT_RARITY query encodes the
    //  KAN-modulated tier directly. Pull-via-axis is the canonical path.)
    let salted_axis: u64 = mix_u64(intelligence_handle, drop_index as u64) ;
    let axis_handle: u64 = mix_u64(salted_axis, AXIS_LOOT_RARITY as u64) ;
    let raw: u64 = __cssl_intelligence_query_axis(axis_handle, AXIS_LOOT_RARITY) ;

    // raw = encoded permyriad-roll (0..9999) when substrate provides ; 0 if denied.
    // When denied, fall back to mixing (seed_lo, drop_index, biome_id, arc_pos) into
    // the roll-space using `mix_u64`.
    let mut roll: u32 ;
    if raw == 0u64 {
        let bio_seed: u64 = mix_u64(seed_lo, (*dims).biome_id as u64) ;
        let arc_seed: u64 = mix_u64(bio_seed, (*dims).arc_pos as u64) ;
        let drop_seed: u64 = mix_u64(arc_seed, drop_index as u64) ;
        roll = (drop_seed % 10000u64) as u32 ;
    } else {
        roll = (raw % 10000u64) as u32 ;
    }

    // Apply 8-tier weighted-cumulative selection
    let mut tier: u8 = select_tier_from_weights(w0, w1, w2, w3, w4, w5, w6, w7, roll) ;

    // Σ-mask floor : Chaotic-tier requires PUZZLE + LORE caps (paradox-room-only by canon)
    if tier == RARITY_CHAOTIC {
        if !cap_allows_puzzle(caps) || !cap_allows_lore(caps) {
            tier = RARITY_PRISMATIC ;
        }
    }

    tier
}

// ─────────────────────────────────────────────────────────────────────────
// § Component synthesis (per ARTIFACT_ASCENSION_SPEC component-rarity-affix)
// ─────────────────────────────────────────────────────────────────────────
//
// Each component gets ITS OWN rarity-roll (independent of item-rarity).
// Item-level rarity drives total-affix-budget ; per-component rarity adjusts
// per-slot affix-distribution (e.g. a Legendary-frame on a Common-item may
// still have 1-2 frame-bound affixes). The Coherence-Engine §3.2 Material
// Harmony scorer reads these per-component values to evaluate the build.

fn synthesize_component(
    intelligence_handle: u64,
    item_seed: u64,
    slot: u8,
    item_rarity: u8,
) -> ArtifactComponent {
    let salted: u64 = mix_u64(item_seed, slot as u64) ;

    // Component-rarity ≈ item-rarity ± 1 (noise · KAN-bounded)
    let rarity_jitter: u64 = mix_u64(salted, 0xC0FFEE_u64) % 3u64 ;   // 0..2
    let mut comp_rarity: u8 = item_rarity ;
    if rarity_jitter == 0u64 {
        if comp_rarity > 0u8 { comp_rarity = comp_rarity - 1u8 ; }
    }
    if rarity_jitter == 2u64 {
        if comp_rarity < 7u8 { comp_rarity = comp_rarity + 1u8 ; }
    }

    // Base-material : rolled from 0..7 mat-ladder (matches base_mats_*.csl)
    // Higher-tier mats restricted by item-rarity floor (chaomatter only on Chaotic items)
    let mat_roll: u64 = mix_u64(salted, 0xBA5E_MA7_u64) % 8u64 ;
    let mut base_mat: u8 = mat_roll as u8 ;
    if base_mat > item_rarity { base_mat = item_rarity ; }

    // Affix-count : derived from component-rarity (per ARTIFACT_ASCENSION_SPEC)
    // Cap at 3 for the inline-fields (≥4 affixes overflow into substrate-side ring)
    let mut affix_count: u8 = affix_count_for_rarity(comp_rarity) ;
    if affix_count > 3u8 { affix_count = 3u8 ; }

    // Affix payload-ids : substrate-supplied via AXIS_LOOT_RARITY salted by slot/affix-index
    let affix_a_seed: u64 = mix_u64(salted, 0xAFF1A_u64) ;
    let affix_b_seed: u64 = mix_u64(salted, 0xAFF1B_u64) ;
    let affix_c_seed: u64 = mix_u64(salted, 0xAFF1C_u64) ;

    let mut a_idx: u32 = 0u32 ;
    let mut b_idx: u32 = 0u32 ;
    let mut c_idx: u32 = 0u32 ;

    if affix_count >= 1u8 { a_idx = (affix_a_seed % 1024u64) as u32 ; }
    if affix_count >= 2u8 { b_idx = (affix_b_seed % 1024u64) as u32 ; }
    if affix_count >= 3u8 { c_idx = (affix_c_seed % 1024u64) as u32 ; }

    ArtifactComponent {
        slot:             slot ,
        base_mat_id:      base_mat ,
        component_rarity: comp_rarity ,
        affix_count:      affix_count ,
        affix_a_idx:      a_idx ,
        affix_b_idx:      b_idx ,
        affix_c_idx:      c_idx ,
    }
}

// ─────────────────────────────────────────────────────────────────────────
// § Loot-drop synthesis (full 7-component composition)
// ─────────────────────────────────────────────────────────────────────────

fn synthesize_loot_drop(
    intelligence_handle: u64,
    seed_lo: u64,
    seed_hi: u64,
    dims: &RoomDims,
    caps: &CapMatrix,
    drop_index: u32,
    composition_root: u64,
) -> LootDrop {
    let item_rarity: u8 = select_loot_rarity(intelligence_handle, seed_lo, dims, caps, drop_index) ;

    // Item-kind discrimination (weapon vs armor) — substrate-supplied
    let kind_seed: u64 = mix_u64(seed_lo, drop_index as u64) ;
    let kind_seed2: u64 = mix_u64(kind_seed, 0xAA_BB_u64) ;
    let is_weapon: bool ;
    if (kind_seed2 % 2u64) == 0u64 { is_weapon = true ; } else { is_weapon = false ; }

    // Item-kind-code : 0..1023 substrate-pool (stable replay-id)
    let item_kind_code: u32 = (mix_u64(kind_seed2, 0xCAFE_u64) % 1024u64) as u32 ;

    // 7 components — for weapons : core/frame/barrel/scope/grip/sight/battery
    //                for armor   : head/chest/arms/legs/feet/belt/cloak
    // (Both indexings use 0..6 ; the is_weapon flag tells the renderer how to interpret.)
    let item_seed: u64 = mix_u64(seed_lo, drop_index as u64) ;
    let comp_a: ArtifactComponent = synthesize_component(intelligence_handle, item_seed, 0u8, item_rarity) ;
    let comp_b: ArtifactComponent = synthesize_component(intelligence_handle, item_seed, 1u8, item_rarity) ;
    let comp_c: ArtifactComponent = synthesize_component(intelligence_handle, item_seed, 2u8, item_rarity) ;
    let comp_d: ArtifactComponent = synthesize_component(intelligence_handle, item_seed, 3u8, item_rarity) ;
    let comp_e: ArtifactComponent = synthesize_component(intelligence_handle, item_seed, 4u8, item_rarity) ;
    let comp_f: ArtifactComponent = synthesize_component(intelligence_handle, item_seed, 5u8, item_rarity) ;
    let comp_g: ArtifactComponent = synthesize_component(intelligence_handle, item_seed, 6u8, item_rarity) ;

    // Spawn position : reduce mixed seed mod room-dims (in decimeters · 10× metric)
    let pos_seed: u64 = mix_u64(seed_lo, drop_index as u64 + 1000u64) ;
    let x_dm: i32 = ((pos_seed % ((*dims).width_m as u64 * 10u64)) as i32) ;
    let y_seed: u64 = mix_u64(pos_seed, 0xDEADu64) ;
    let y_dm: i32 = ((y_seed % ((*dims).height_m as u64 * 10u64)) as i32) ;
    let z_seed: u64 = mix_u64(y_seed, 0xBEEFu64) ;
    let z_dm: i32 = ((z_seed % ((*dims).depth_m as u64 * 10u64)) as i32) ;

    // Σ-Chain anchor for THIS drop · child of composition_root
    let anchor: u64 = __cssl_sigma_chain_anchor_loot_drop(composition_root, item_rarity, item_seed) ;

    LootDrop {
        item_kind_code:    item_kind_code ,
        item_rarity:       item_rarity ,
        is_weapon:         is_weapon ,
        component_a:       comp_a ,
        component_b:       comp_b ,
        component_c:       comp_c ,
        component_d:       comp_d ,
        component_e:       comp_e ,
        component_f:       comp_f ,
        component_g:       comp_g ,
        spawn_x_decimeters: x_dm ,
        spawn_y_decimeters: y_dm ,
        spawn_z_decimeters: z_dm ,
        drop_seed:         item_seed ,
        sigma_anchor:      anchor ,
    }
}

// ─────────────────────────────────────────────────────────────────────────
// § NPC-spawn synthesis  (compose-not-invent · 12 archetypes)
// ─────────────────────────────────────────────────────────────────────────

fn synthesize_npc_spawn(
    intelligence_handle: u64,
    seed_lo: u64,
    seed_hi: u64,
    dims: &RoomDims,
    caps: &CapMatrix,
    spawn_index: u32,
    composition_root: u64,
) -> NpcSpawn {
    let archetype: u8 = select_npc_archetype(intelligence_handle, seed_lo, seed_hi, dims, caps, spawn_index) ;

    // Spawn position
    let pos_seed: u64 = mix_u64(seed_lo, spawn_index as u64 + 5000u64) ;
    let x_dm: i32 = ((pos_seed % ((*dims).width_m as u64 * 10u64)) as i32) ;
    let y_seed: u64 = mix_u64(pos_seed, 0xCAFEu64) ;
    let y_dm: i32 = ((y_seed % ((*dims).height_m as u64 * 10u64)) as i32) ;
    let z_seed: u64 = mix_u64(y_seed, 0xF00Du64) ;
    let z_dm: i32 = ((z_seed % ((*dims).depth_m as u64 * 10u64)) as i32) ;

    // Σ-Chain anchor for this spawn
    let anchor: u64 = __cssl_sigma_chain_anchor_npc_spawn(
        composition_root,
        archetype,
        x_dm, y_dm, z_dm,
    ) ;

    NpcSpawn {
        archetype:          archetype ,
        spawn_x_decimeters: x_dm ,
        spawn_y_decimeters: y_dm ,
        spawn_z_decimeters: z_dm ,
        handle_id:          0u64 ,    // filled by FFI on actual spawn-issuance
        sigma_anchor:       anchor ,
    }
}

// ─────────────────────────────────────────────────────────────────────────
// § Interactable synthesis  (lore · puzzle · trade · altar · cache · biome-crystal)
// ─────────────────────────────────────────────────────────────────────────

fn synthesize_interactable(
    intelligence_handle: u64,
    seed_lo: u64,
    dims: &RoomDims,
    caps: &CapMatrix,
    int_index: u32,
    composition_root: u64,
) -> Interactable {
    let salt: u64 = mix_u64(seed_lo, int_index as u64 + 7000u64) ;
    let kind_roll: u64 = mix_u64(salt, 0x1NTERACTu64) ;

    // Filter to allowed kinds based on caps
    let mut chosen_kind: u8 = INTERACTABLE_LORE_FRAGMENT ;
    let kind_idx: u32 = (kind_roll % 6u64) as u32 ;

    // Map raw-roll → cap-allowed kind ; substrate-floor to LORE_FRAGMENT if caps deny
    if kind_idx == 0u32 {
        if cap_allows_lore(caps) { chosen_kind = INTERACTABLE_LORE_FRAGMENT ; }
    } else if kind_idx == 1u32 {
        if cap_allows_puzzle(caps) { chosen_kind = INTERACTABLE_PUZZLE_RUNE ; }
        else if cap_allows_lore(caps) { chosen_kind = INTERACTABLE_LORE_FRAGMENT ; }
    } else if kind_idx == 2u32 {
        if cap_allows_trade(caps) { chosen_kind = INTERACTABLE_TRADE_KIOSK ; }
        else if cap_allows_lore(caps) { chosen_kind = INTERACTABLE_LORE_FRAGMENT ; }
    } else if kind_idx == 3u32 {
        if cap_allows_lore(caps) { chosen_kind = INTERACTABLE_ALTAR ; }
    } else if kind_idx == 4u32 {
        if cap_allows_loot(caps) { chosen_kind = INTERACTABLE_CACHE ; }
        else if cap_allows_lore(caps) { chosen_kind = INTERACTABLE_LORE_FRAGMENT ; }
    } else {
        if cap_allows_lore(caps) { chosen_kind = INTERACTABLE_BIOME_CRYSTAL ; }
    }

    let payload_id: u32 = (mix_u64(salt, 0xPAY10ADu64) % 4096u64) as u32 ;

    // Spawn position
    let x_dm: i32 = ((mix_u64(salt, 0x0xPOSXu64) % ((*dims).width_m as u64 * 10u64)) as i32) ;
    let y_dm: i32 = ((mix_u64(salt, 0x0xPOSYu64) % ((*dims).height_m as u64 * 10u64)) as i32) ;
    let z_dm: i32 = ((mix_u64(salt, 0x0xPOSZu64) % ((*dims).depth_m as u64 * 10u64)) as i32) ;

    let anchor: u64 = __cssl_sigma_chain_anchor_interactable(composition_root, chosen_kind, payload_id) ;

    Interactable {
        kind:               chosen_kind ,
        payload_id:         payload_id ,
        spawn_x_decimeters: x_dm ,
        spawn_y_decimeters: y_dm ,
        spawn_z_decimeters: z_dm ,
        sigma_anchor:       anchor ,
    }
}

// ─────────────────────────────────────────────────────────────────────────
// § Empty-room helpers (used when caps deny everything)
// ─────────────────────────────────────────────────────────────────────────

fn empty_npc_spawn() -> NpcSpawn {
    NpcSpawn {
        archetype:          ARCHETYPE_WANDERER ,
        spawn_x_decimeters: 0i32 ,
        spawn_y_decimeters: 0i32 ,
        spawn_z_decimeters: 0i32 ,
        handle_id:          0u64 ,
        sigma_anchor:       0u64 ,
    }
}

fn empty_component() -> ArtifactComponent {
    ArtifactComponent {
        slot:             0u8 ,
        base_mat_id:      0u8 ,
        component_rarity: RARITY_COMMON ,
        affix_count:      0u8 ,
        affix_a_idx:      0u32 ,
        affix_b_idx:      0u32 ,
        affix_c_idx:      0u32 ,
    }
}

fn empty_loot_drop() -> LootDrop {
    let zero_comp: ArtifactComponent = empty_component() ;
    LootDrop {
        item_kind_code:    0u32 ,
        item_rarity:       RARITY_COMMON ,
        is_weapon:         false ,
        component_a:       zero_comp ,
        component_b:       zero_comp ,
        component_c:       zero_comp ,
        component_d:       zero_comp ,
        component_e:       zero_comp ,
        component_f:       zero_comp ,
        component_g:       zero_comp ,
        spawn_x_decimeters: 0i32 ,
        spawn_y_decimeters: 0i32 ,
        spawn_z_decimeters: 0i32 ,
        drop_seed:         0u64 ,
        sigma_anchor:      0u64 ,
    }
}

fn empty_interactable() -> Interactable {
    Interactable {
        kind:               INTERACTABLE_LORE_FRAGMENT ,
        payload_id:         0u32 ,
        spawn_x_decimeters: 0i32 ,
        spawn_y_decimeters: 0i32 ,
        spawn_z_decimeters: 0i32 ,
        sigma_anchor:       0u64 ,
    }
}

// ─────────────────────────────────────────────────────────────────────────
// § PUBLIC API · `populate_room`  (canonical entry-point)
// ─────────────────────────────────────────────────────────────────────────
//
// Compose a room's contents from substrate primitives. Pure-CSSL — every spawn
// is substrate-evolved (¬ hardcoded · ¬ external-API · ¬ play-tested-magic-numbers).
//
// Determinism :
//   - same (seed, dims, caps, player-state) → bit-identical RoomContents
//   - substrate-intelligence handle is derived from (seed_lo, seed_hi · NOT system-time)
//   - all index-selection mixed via deterministic `mix_u64` ; no live-clock reads
//
// Σ-mask invariants :
//   - if !cap_allows_content : npc_count = 0
//   - if !cap_allows_loot    : loot_count = 0
//   - if neither             : RoomContents.* = empty placeholders
//   - causal-seed-veto on every NPC spawn (predicts harm-potential)
//   - Σ-Chain anchor every spawn (sovereign-revocable via "forget-myself")
//
// Rate-limit safety : caller responsible for not invoking per-frame ; canonical
// invocation is once-per-room-enter (or on caps-bit change).

fn populate_room(seed_lo: u64, seed_hi: u64, dims: RoomDims, caps: CapMatrix) -> RoomContents {
    // ─────────────────────────────────────────────────────────────────
    // Step 1 · acquire substrate-intelligence composition handle
    // ─────────────────────────────────────────────────────────────────
    //
    // role=0 (DM) — Director's macro-arc decisions about what should appear here.
    // context_ptr = 0 (placeholder · stage-0 substrate doesn't need extra context).

    let context_null: *const u8 = 0 as *const u8 ;
    let role_dm: u8 = 0u8 ;
    let intelligence_handle: u64 = __cssl_intelligence_compose(
        role_dm,
        seed_lo,
        seed_hi,
        context_null,
        0u32,
        caps.consent_token,
    ) ;

    // ─────────────────────────────────────────────────────────────────
    // Step 2 · derive counts (substrate-evolved · clamped to bounds)
    // ─────────────────────────────────────────────────────────────────

    let npc_count: u32         = derive_npc_count(intelligence_handle, &caps) ;
    let loot_count: u32        = derive_loot_count(intelligence_handle, &caps) ;
    let interactable_count: u32 = derive_interactable_count(intelligence_handle, &caps) ;

    // ─────────────────────────────────────────────────────────────────
    // Step 3 · Σ-Chain anchor the WHOLE-ROOM composition (root anchor)
    // ─────────────────────────────────────────────────────────────────

    let composition_seed: u64 = mix_u64(seed_lo, seed_hi) ;
    let composition_root: u64 = __cssl_sigma_chain_anchor_room(
        composition_seed,
        npc_count,
        loot_count,
        interactable_count,
        2u8,    // PRIVACY_PSEUDONYMOUS · matches loot_drop.csl Akashic-feed friendly
    ) ;

    // ─────────────────────────────────────────────────────────────────
    // Step 4 · synthesize NPC spawns (1..3 when content-cap granted)
    // ─────────────────────────────────────────────────────────────────

    let mut npc_a: NpcSpawn = empty_npc_spawn() ;
    let mut npc_b: NpcSpawn = empty_npc_spawn() ;
    let mut npc_c: NpcSpawn = empty_npc_spawn() ;

    if npc_count >= 1u32 {
        npc_a = synthesize_npc_spawn(intelligence_handle, seed_lo, seed_hi, &dims, &caps, 0u32, composition_root) ;
    }
    if npc_count >= 2u32 {
        npc_b = synthesize_npc_spawn(intelligence_handle, seed_lo, seed_hi, &dims, &caps, 1u32, composition_root) ;
    }
    if npc_count >= 3u32 {
        npc_c = synthesize_npc_spawn(intelligence_handle, seed_lo, seed_hi, &dims, &caps, 2u32, composition_root) ;
    }

    // ─────────────────────────────────────────────────────────────────
    // Step 5 · synthesize loot drops (3..5 when loot-cap granted)
    // ─────────────────────────────────────────────────────────────────

    let mut loot_a: LootDrop = empty_loot_drop() ;
    let mut loot_b: LootDrop = empty_loot_drop() ;
    let mut loot_c: LootDrop = empty_loot_drop() ;
    let mut loot_d: LootDrop = empty_loot_drop() ;
    let mut loot_e: LootDrop = empty_loot_drop() ;

    if loot_count >= 1u32 {
        loot_a = synthesize_loot_drop(intelligence_handle, seed_lo, seed_hi, &dims, &caps, 0u32, composition_root) ;
    }
    if loot_count >= 2u32 {
        loot_b = synthesize_loot_drop(intelligence_handle, seed_lo, seed_hi, &dims, &caps, 1u32, composition_root) ;
    }
    if loot_count >= 3u32 {
        loot_c = synthesize_loot_drop(intelligence_handle, seed_lo, seed_hi, &dims, &caps, 2u32, composition_root) ;
    }
    if loot_count >= 4u32 {
        loot_d = synthesize_loot_drop(intelligence_handle, seed_lo, seed_hi, &dims, &caps, 3u32, composition_root) ;
    }
    if loot_count >= 5u32 {
        loot_e = synthesize_loot_drop(intelligence_handle, seed_lo, seed_hi, &dims, &caps, 4u32, composition_root) ;
    }

    // ─────────────────────────────────────────────────────────────────
    // Step 6 · synthesize interactables (0..4 cap-gated)
    // ─────────────────────────────────────────────────────────────────

    let mut int_a: Interactable = empty_interactable() ;
    let mut int_b: Interactable = empty_interactable() ;
    let mut int_c: Interactable = empty_interactable() ;
    let mut int_d: Interactable = empty_interactable() ;

    if interactable_count >= 1u32 {
        int_a = synthesize_interactable(intelligence_handle, seed_lo, &dims, &caps, 0u32, composition_root) ;
    }
    if interactable_count >= 2u32 {
        int_b = synthesize_interactable(intelligence_handle, seed_lo, &dims, &caps, 1u32, composition_root) ;
    }
    if interactable_count >= 3u32 {
        int_c = synthesize_interactable(intelligence_handle, seed_lo, &dims, &caps, 2u32, composition_root) ;
    }
    if interactable_count >= 4u32 {
        int_d = synthesize_interactable(intelligence_handle, seed_lo, &dims, &caps, 3u32, composition_root) ;
    }

    // ─────────────────────────────────────────────────────────────────
    // Step 7 · assemble + return (caller wires NPC-handle issuance via npc.csl)
    // ─────────────────────────────────────────────────────────────────

    RoomContents {
        npc_count:           npc_count ,
        npc_a:               npc_a ,
        npc_b:               npc_b ,
        npc_c:               npc_c ,
        loot_count:          loot_count ,
        loot_a:              loot_a ,
        loot_b:              loot_b ,
        loot_c:              loot_c ,
        loot_d:              loot_d ,
        loot_e:              loot_e ,
        interactable_count:  interactable_count ,
        interactable_a:      int_a ,
        interactable_b:      int_b ,
        interactable_c:      int_c ,
        interactable_d:      int_d ,
        composition_seed:    composition_seed ,
        composition_anchor:  composition_root ,
    }
}

// ─────────────────────────────────────────────────────────────────────────
// § Empty-RoomContents helper (cap-deny default · used in tests + fallback)
// ─────────────────────────────────────────────────────────────────────────

fn empty_room_contents() -> RoomContents {
    let zero_npc: NpcSpawn = empty_npc_spawn() ;
    let zero_loot: LootDrop = empty_loot_drop() ;
    let zero_int: Interactable = empty_interactable() ;
    RoomContents {
        npc_count:           0u32 ,
        npc_a:               zero_npc ,
        npc_b:               zero_npc ,
        npc_c:               zero_npc ,
        loot_count:          0u32 ,
        loot_a:              zero_loot ,
        loot_b:              zero_loot ,
        loot_c:              zero_loot ,
        loot_d:              zero_loot ,
        loot_e:              zero_loot ,
        interactable_count:  0u32 ,
        interactable_a:      zero_int ,
        interactable_b:      zero_int ,
        interactable_c:      zero_int ,
        interactable_d:      zero_int ,
        composition_seed:    0u64 ,
        composition_anchor:  0u64 ,
    }
}

