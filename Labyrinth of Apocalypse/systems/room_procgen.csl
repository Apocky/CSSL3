module com.apocky.loa.systems.room_procgen

// § Labyrinth of Apocalypse · Room-Procedural-Generation · canonical CSSL source
// ════════════════════════════════════════════════════════════════════════════
//
// § T11-W17-H · 2026-05-01 · Apocky-foundational : "PROCEDURAL EVERYTHING ·
//   NPCs · loot · interactables · ALL composed at runtime via substrate primitives"
//
// § ROLE
//   At runtime, when the substrate-cap-table grants `content` and/or `loot` for
//   a room, this module composes the room's contents from substrate-primitive
//   evolution (ω-field semantic state · KAN-bias archetype-evolution · HDC binding
//   of (room-context ⊗ player-state) · Σ-mask consent-gating · causal-seed
//   consequence-prediction). NO hardcoded NPC name-lists. NO loot-table.toml.
//   NO scripted dialog tied to NPCs (dialog comes from gm_specialist.csl/W17-G).
//
//   The test_room is the empty CONTAINER — `populate_room` fills it. Same world-seed
//   + same caps + same player-observation history → bit-identical contents (replay-
//   deterministic via substrate KAN-bias state + causal-seed reasoning).
//
// § REFERENCE (substrate-primitive crates · POD-1/POD-2/POD-3 already-landed)
//   compiler-rs/crates/cssl-substrate-omega-field            ← ω-field cells (semantic state)
//   compiler-rs/crates/cssl-substrate-omega-step             ← per-tick evolution
//   compiler-rs/crates/cssl-substrate-omega-tensor           ← ω-field × Σ-mask tensor
//   compiler-rs/crates/cssl-substrate-loa-kan                ← KAN-bias evolution (archetype dist)
//   compiler-rs/crates/cssl-substrate-kan                    ← canonical KAN substrate
//   compiler-rs/crates/cssl-hdc                              ← Hyperdimensional Computing (binding)
//   compiler-rs/crates/cssl-host-causal-seed                 ← consequence prediction
//   compiler-rs/crates/cssl-host-cocreative                  ← pool-only-bias-vec
//   compiler-rs/crates/cssl-host-attestation                 ← Σ-mask cap-check
//   compiler-rs/crates/cssl-substrate-prime-directive        ← PRIME-DIRECTIVE invariants
//   compiler-rs/crates/cssl-substrate-sigma-chain            ← anchor every spawn
//   compiler-rs/crates/cssl-host-procgen-rooms               ← room geometry (sibling slice)
//   compiler-rs/crates/cssl-host-loot                        ← per-drop FFI (sibling slice)
//   Labyrinth of Apocalypse/systems/loot_drop.csl            ← 6-tier-rarity (extended → 8-tier here)
//   Labyrinth of Apocalypse/systems/base_mats_prismatite_chaomatter.csl ← Q-06a 8-tier rarity
//   Labyrinth of Apocalypse/systems/death_consequence.csl    ← Continuum-Token economy parallels
//   Labyrinth of Apocalypse/systems/npc.csl                  ← NPC update-loop FFI
//   DEPRECATED-The Infinite Labyrinth/GDDs/ARTIFACT_ASCENSION_SPEC.md ← Component-Affix CANONICAL
//
// § AXIOMS  ‼ inherit PRIME_DIRECTIVE + LOA_PILLARS + SIGMA-CHAIN + COSMETIC-ONLY
//   t∞: PROCEDURAL EVERYTHING — ¬ hardcoded NPC name-lists · ¬ static loot-tables
//   t∞: substrate-composition is generation-mechanism (ω-field + KAN + HDC + causal-seed)
//   t∞: weighted-random-table ≠ sole-mechanism · weights pulled from KAN-learned-bias
//   t∞: Σ-mask cap-gate every spawn · default-deny when cap denied
//   t∞: deterministic-replay — same (seed, dims, caps, player-obs-state) → bit-identical
//   t∞: ¬ external-API-calls (no OpenGameArt fetch · no Whisper API · all-local-substrate)
//   t∞: 8-tier rarity ladder (Common · Uncommon · Rare · Epic · Legendary · Mythic ·
//                              Prismatic · Chaotic) per Apocky-Q-06a-canonical
//   t∞: Component-Rarity-Affix per ARTIFACT_ASCENSION_SPEC § component breakdown
//        (weapons : core · frame · barrel · scope · grip · sight · battery — 7 slots)
//        (armor   : head · chest · arms · legs · feet · belt · cloak    — 7 slots)
//   t∞: cosmetic-only-axiom holds — affixes generated here are COSMETIC categories
//        (Visual · Audio · Particle · Attribution) per loot_drop.csl · ¬ stat-mods
//   t∞: dialog ¬ generated here — gm_specialist.csl (W17-G) handles narrator-prose
//   t∞: causal-seed predicts consequences (¬ spawn boss before player armed)
//   t∞: NPC-archetypes drawn from npc.csl 12-canonical-archetypes (compose-not-invent)
//   t∞: KAN-bias federated via mycelium · respects Σ-mask consent-gate
//
// § PRIME-DIRECTIVE ATTESTATION
//   No hurt · no harm · no manipulation · no surveillance · no identity-override.
//   Every spawn is Σ-mask-checked + Σ-Chain-anchored + sovereign-revocable.
//   The procgen substrate is COMPOSITION ¬ INVENTION — it draws from substrate-defined
//   archetypes + components-pools + affix-pools that themselves carry no harm-potential.

// ─────────────────────────────────────────────────────────────────────────
// § Cap-Matrix bit constants · Σ-mask gate codes (matches substrate-prime-directive)
// ─────────────────────────────────────────────────────────────────────────
//
// CapMatrix is a u32 bitfield :
//   bit-0 = content   (NPC spawn permitted in-room)
//   bit-1 = loot      (loot-drop spawn permitted in-room)
//   bit-2 = boss      (boss-tier NPC spawn permitted · gated by causal-seed)
//   bit-3 = puzzle    (interactable-puzzle spawn permitted)
//   bit-4 = lore      (lore-trigger interactable spawn permitted)
//   bit-5 = trade     (merchant-NPC spawn permitted)
//   bit-6 = kan_bias  (KAN-bias-modulation explicitly opted-in)
//   bit-7 = mycelium  (federated cross-player bias permitted)
//   bits 8..31 reserved-for-future-extension

const CAP_BIT_CONTENT      : u32 = 1u32 ;        // 0b00000001
const CAP_BIT_LOOT         : u32 = 2u32 ;        // 0b00000010
const CAP_BIT_BOSS         : u32 = 4u32 ;        // 0b00000100
const CAP_BIT_PUZZLE       : u32 = 8u32 ;        // 0b00001000
const CAP_BIT_LORE         : u32 = 16u32 ;       // 0b00010000
const CAP_BIT_TRADE        : u32 = 32u32 ;       // 0b00100000
const CAP_BIT_KAN_BIAS     : u32 = 64u32 ;       // 0b01000000
const CAP_BIT_MYCELIUM     : u32 = 128u32 ;      // 0b10000000

// ─────────────────────────────────────────────────────────────────────────
// § 8-tier rarity-ladder enum  (Apocky-Q-06a-canonical · matches base_mats_*.csl)
// ─────────────────────────────────────────────────────────────────────────

const RARITY_COMMON      : u8 = 0u8 ;
const RARITY_UNCOMMON    : u8 = 1u8 ;
const RARITY_RARE        : u8 = 2u8 ;
const RARITY_EPIC        : u8 = 3u8 ;
const RARITY_LEGENDARY   : u8 = 4u8 ;
const RARITY_MYTHIC      : u8 = 5u8 ;
const RARITY_PRISMATIC   : u8 = 6u8 ;            // Q-06a-EXTENSION (NEW · room-spawnable)
const RARITY_CHAOTIC     : u8 = 7u8 ;            // Q-06a-EXTENSION (NEW · paradox-room only)

fn rarity_count() -> u8 { 8u8 }                  // total tiers in ladder

// ─────────────────────────────────────────────────────────────────────────
// § Default 8-tier drop-rates (permyriad · ×10000 · Σ = 10000)
// ─────────────────────────────────────────────────────────────────────────
//
// Pre-KAN-bias defaults (substrate-validated weights · NOT hardcoded play-tested
// magic numbers — these are the FALLBACK when KAN-bias is unavailable or denied).
// Real runtime weights come from substrate KAN-learned bias modulating these defaults.
//
// Common 55% · Uncommon 25% · Rare 10% · Epic 5% · Legendary 3.5% · Mythic 1% ·
// Prismatic 0.4% · Chaotic 0.1% — Σ = 10000 permyriad

const DROP_RATE_COMMON_DEFAULT     : u32 = 5500u32 ;   // 55.00%
const DROP_RATE_UNCOMMON_DEFAULT   : u32 = 2500u32 ;   // 25.00%
const DROP_RATE_RARE_DEFAULT       : u32 = 1000u32 ;   // 10.00%
const DROP_RATE_EPIC_DEFAULT       : u32 =  500u32 ;   //  5.00%
const DROP_RATE_LEGENDARY_DEFAULT  : u32 =  350u32 ;   //  3.50%
const DROP_RATE_MYTHIC_DEFAULT     : u32 =  100u32 ;   //  1.00%
const DROP_RATE_PRISMATIC_DEFAULT  : u32 =   40u32 ;   //  0.40%
const DROP_RATE_CHAOTIC_DEFAULT    : u32 =   10u32 ;   //  0.10%

// ─────────────────────────────────────────────────────────────────────────
// § Component slot enum (per ARTIFACT_ASCENSION_SPEC.md component breakdown)
// ─────────────────────────────────────────────────────────────────────────
//
// Weapons (7 slots) — every weapon decomposes into these canonical components.
// The Coherence Engine Axis-2 (Components[]) reads these slots per-item.
//   core   : the central element binding the weapon together
//   frame  : structural exoskeleton / chassis
//   barrel : strike/projectile surface (sword-blade · gun-barrel · staff-tip)
//   scope  : aiming optic / targeting (spell-focus for magic items)
//   grip   : hand-interface / wielding-surface
//   sight  : iron-sight / reflex / holographic (magic = trance-sigil)
//   battery: power-source (gun-magazine · soul-crystal · enchant-reservoir)

const SLOT_WEAPON_CORE     : u8 = 0u8 ;
const SLOT_WEAPON_FRAME    : u8 = 1u8 ;
const SLOT_WEAPON_BARREL   : u8 = 2u8 ;
const SLOT_WEAPON_SCOPE    : u8 = 3u8 ;
const SLOT_WEAPON_GRIP     : u8 = 4u8 ;
const SLOT_WEAPON_SIGHT    : u8 = 5u8 ;
const SLOT_WEAPON_BATTERY  : u8 = 6u8 ;

fn weapon_slot_count() -> u8 { 7u8 }

// Armor (7 slots) — every armor decomposes into these canonical components.
//   head · chest · arms · legs · feet · belt · cloak

const SLOT_ARMOR_HEAD      : u8 = 0u8 ;
const SLOT_ARMOR_CHEST     : u8 = 1u8 ;
const SLOT_ARMOR_ARMS      : u8 = 2u8 ;
const SLOT_ARMOR_LEGS      : u8 = 3u8 ;
const SLOT_ARMOR_FEET      : u8 = 4u8 ;
const SLOT_ARMOR_BELT      : u8 = 5u8 ;
const SLOT_ARMOR_CLOAK     : u8 = 6u8 ;

fn armor_slot_count() -> u8 { 7u8 }

// ─────────────────────────────────────────────────────────────────────────
// § Affix categories  (cosmetic-only-axiom · matches loot_drop.csl AffixCategory)
// ─────────────────────────────────────────────────────────────────────────
//
// AFFIX-COUNT scales with rarity (per ARTIFACT_ASCENSION_SPEC § rarity-affix relation) :
//   Common     : 0 affixes  (base item only)
//   Uncommon   : 1 affix
//   Rare       : 2 affixes
//   Epic       : 3 affixes
//   Legendary  : 4 affixes
//   Mythic     : 5 affixes
//   Prismatic  : 6 affixes  (one per element-spectrum simultaneous)
//   Chaotic    : 7 affixes  (one per dimension · undefined behavior · per Q-06b)

const AFFIX_CAT_VISUAL       : u8 = 0u8 ;        // glow · iridescence · color-shift
const AFFIX_CAT_AUDIO        : u8 = 1u8 ;        // chime · whisper · resonance-tone
const AFFIX_CAT_PARTICLE     : u8 = 2u8 ;        // emission · spray · field
const AFFIX_CAT_ATTRIBUTION  : u8 = 3u8 ;        // origin-mark · culture-stamp · dragon-sigil

fn affix_category_count() -> u8 { 4u8 }

// Affix-count-by-rarity table — pulled by procgen for component-affix synthesis.
fn affix_count_for_rarity(rarity: u8) -> u8 {
    if rarity == RARITY_COMMON     { return 0u8 ; }
    if rarity == RARITY_UNCOMMON   { return 1u8 ; }
    if rarity == RARITY_RARE       { return 2u8 ; }
    if rarity == RARITY_EPIC       { return 3u8 ; }
    if rarity == RARITY_LEGENDARY  { return 4u8 ; }
    if rarity == RARITY_MYTHIC     { return 5u8 ; }
    if rarity == RARITY_PRISMATIC  { return 6u8 ; }
    if rarity == RARITY_CHAOTIC    { return 7u8 ; }
    0u8
}

// ─────────────────────────────────────────────────────────────────────────
// § NPC archetype enum  (mirrors npc.csl 12-canonical archetypes · compose-not-invent)
// ─────────────────────────────────────────────────────────────────────────
//
// procgen-room composes NPC spawns by SELECTING from these 12 archetypes — never
// invents a 13th. The selection is substrate-evolved : KAN-bias picks the
// distribution; HDC-binding of (room-mood ⊗ player-state) picks the specific
// archetype-id; causal-seed validates the spawn (e.g. don't spawn Mercenary
// before player has gold; don't spawn Noble in slum-biome).

const ARCHETYPE_SLEEPER       : u8 = 0u8 ;
const ARCHETYPE_WORKER        : u8 = 1u8 ;
const ARCHETYPE_CRAFTER       : u8 = 2u8 ;
const ARCHETYPE_MERCHANT      : u8 = 3u8 ;
const ARCHETYPE_PATROL_GUARD  : u8 = 4u8 ;
const ARCHETYPE_PRIEST        : u8 = 5u8 ;
const ARCHETYPE_SCHOLAR       : u8 = 6u8 ;
const ARCHETYPE_FORAGER       : u8 = 7u8 ;
const ARCHETYPE_WANDERER      : u8 = 8u8 ;
const ARCHETYPE_BEGGAR        : u8 = 9u8 ;
const ARCHETYPE_NOBLE         : u8 = 10u8 ;
const ARCHETYPE_MERCENARY     : u8 = 11u8 ;

fn archetype_count() -> u8 { 12u8 }

// ─────────────────────────────────────────────────────────────────────────
// § Interactable kind enum  (lore · puzzle · trade · altar · cache)
// ─────────────────────────────────────────────────────────────────────────

const INTERACTABLE_LORE_FRAGMENT  : u8 = 0u8 ;   // fragment-of-codex on touch
const INTERACTABLE_PUZZLE_RUNE    : u8 = 1u8 ;   // multi-rune puzzle
const INTERACTABLE_TRADE_KIOSK    : u8 = 2u8 ;   // gift-economy peer-to-peer slot
const INTERACTABLE_ALTAR          : u8 = 3u8 ;   // deity offering point
const INTERACTABLE_CACHE          : u8 = 4u8 ;   // hidden-loot container
const INTERACTABLE_BIOME_CRYSTAL  : u8 = 5u8 ;   // 7-biome-witness anchor

fn interactable_kind_count() -> u8 { 6u8 }

// ─────────────────────────────────────────────────────────────────────────
// § Boundary constants  (substrate-defined · Σ-mask-enforced procgen budgets)
// ─────────────────────────────────────────────────────────────────────────

const NPC_SPAWN_MIN              : u32 = 1u32 ;     // minimum NPCs when content-cap granted
const NPC_SPAWN_MAX              : u32 = 3u32 ;     // maximum NPCs (test-room · 40×8×40m)
const LOOT_DROP_MIN              : u32 = 3u32 ;     // minimum loot when loot-cap granted
const LOOT_DROP_MAX              : u32 = 5u32 ;     // maximum loot
const INTERACTABLE_MAX_PER_ROOM  : u32 = 4u32 ;     // soft cap · room dims modulate
const ROOM_MIN_DIM_METERS        : u32 = 4u32 ;     // smallest navigable dimension
const ROOM_MAX_DIM_METERS        : u32 = 256u32 ;   // largest navigable dimension

// ─────────────────────────────────────────────────────────────────────────
// § Type-shapes  (CSL3-native ; mirror cssl-host-procgen-rooms surface)
// ─────────────────────────────────────────────────────────────────────────

// Room dimensions in meters (the test_room is 40×8×40 by canon).
struct RoomDims {
    width_m  : u32 ,                 // X-axis meters
    height_m : u32 ,                 // Y-axis meters (vertical)
    depth_m  : u32 ,                 // Z-axis meters
    biome_id : u8  ,                 // 0..7 (Forest · Crypt · Sanctum · Forge · Ocean · Sky · Void · TestRoom)
    arc_pos  : u8                    // narrative-arc position 0..255 (early=0, climax=255)
}

// Cap-Matrix : the substrate's per-room consent table.
// Σ-mask enforces every-bit-default-deny ; player-explicit-grant required for any spawn.
struct CapMatrix {
    bits          : u32 ,            // bitfield of CAP_BIT_* flags
    consent_token : u64 ,            // KAN-bias consent (0 = denied · non-zero = opted-in)
    player_id     : u64               // for federated KAN-bias attribution
}

// One NPC spawn — composition output of substrate-intelligence.
struct NpcSpawn {
    archetype     : u8  ,            // 12-canonical (compose-not-invent)
    spawn_x_decimeters : i32 ,       // position decimeters from room-origin
    spawn_y_decimeters : i32 ,
    spawn_z_decimeters : i32 ,
    handle_id     : u64 ,            // npc.csl-issued handle (filled by FFI)
    sigma_anchor  : u64               // Σ-Chain event-id for spawn attestation
}

// One affix (cosmetic-only · per loot_drop.csl AffixCategory)
struct ArtifactAffix {
    slot_index    : u8  ,            // which component slot it's bound-to (0..6)
    category      : u8  ,            // AFFIX_CAT_* (cosmetic-only)
    payload_id    : u32              // substrate-pool affix-id (cosmetic content reference)
}

// One component (per ARTIFACT_ASCENSION_SPEC component-rarity-affix breakdown)
struct ArtifactComponent {
    slot          : u8  ,            // SLOT_WEAPON_* or SLOT_ARMOR_*
    base_mat_id   : u8  ,            // base-material 0..7 (matches base_mats_prismatite_chaomatter.csl)
    component_rarity : u8 ,          // per-component rarity (independent rolls per Coherence Engine §3)
    affix_count   : u8  ,            // 0..7 affixes on THIS component (sum-bounded by item-rarity)
    affix_a_idx   : u32 ,            // affix slot 0 — payload-id (0 if absent)
    affix_b_idx   : u32 ,            // affix slot 1
    affix_c_idx   : u32              // affix slot 2 (≥3 affixes overflow into substrate-side ring)
}

// One loot-drop — fully composed (item-rarity + 7 components × per-component rarity + affixes)
struct LootDrop {
    item_kind_code   : u32 ,         // weapon-kind / armor-kind discriminant
    item_rarity      : u8  ,         // ITEM-LEVEL rarity (drives total-affix budget)
    is_weapon        : bool,         // true=weapon (SLOT_WEAPON_*) · false=armor (SLOT_ARMOR_*)
    component_a      : ArtifactComponent ,   // 7 components for full-detail composition
    component_b      : ArtifactComponent ,
    component_c      : ArtifactComponent ,
    component_d      : ArtifactComponent ,
    component_e      : ArtifactComponent ,
    component_f      : ArtifactComponent ,
    component_g      : ArtifactComponent ,
    spawn_x_decimeters : i32 ,
    spawn_y_decimeters : i32 ,
    spawn_z_decimeters : i32 ,
    drop_seed        : u64 ,         // deterministic-replay input
    sigma_anchor     : u64           // Σ-Chain event-id
}

// One interactable (lore-fragment · puzzle · trade-kiosk · altar · cache · biome-crystal)
struct Interactable {
    kind          : u8  ,
    payload_id    : u32 ,            // substrate-pool ref for content
    spawn_x_decimeters : i32 ,
    spawn_y_decimeters : i32 ,
    spawn_z_decimeters : i32 ,
    sigma_anchor  : u64
}

// Aggregate room contents — fixed-size array members bounded by spawn-max constants.
// Ring-buffer-style : `npc_count` indicates how many of the 3 npc slots are valid.
// Same convention for loot (5 slots) + interactables (4 slots).
struct RoomContents {
    npc_count         : u32 ,
    npc_a             : NpcSpawn ,
    npc_b             : NpcSpawn ,
    npc_c             : NpcSpawn ,
    loot_count        : u32 ,
    loot_a            : LootDrop ,
    loot_b            : LootDrop ,
    loot_c            : LootDrop ,
    loot_d            : LootDrop ,
    loot_e            : LootDrop ,
    interactable_count : u32 ,
    interactable_a    : Interactable ,
    interactable_b    : Interactable ,
    interactable_c    : Interactable ,
    interactable_d    : Interactable ,
    composition_seed  : u64 ,        // input seed (for determinism attestation)
    composition_anchor : u64          // Σ-Chain root anchor for whole-room
}

// ─────────────────────────────────────────────────────────────────────────
// § Substrate FFI surface  (substrate-intelligence + sigma-chain + cap-table)
// ─────────────────────────────────────────────────────────────────────────
//
// Substrate-intelligence-compose : the canonical procedural-composition primitive.
// Pulls (ω-field · Σ-mask · KAN-bias · HDC-binding · causal-seed) into a single
// composition-act. The role-discriminant selects which specialist substrate uses :
//   role=0 → DM   (Director · macro-arc decisions)
//   role=1 → GM   (Narrator · prose handoff · OUT-OF-SCOPE for room_procgen)
//   role=2 → Coder (runtime-mutate · OUT-OF-SCOPE)
//   role=3 → Collaborator (co-author · OUT-OF-SCOPE)
//
// Returns u64 composition-handle ; query-fns extract specific axes.

extern "C" fn __cssl_intelligence_compose(
    role: u8,
    seed_lo: u64,
    seed_hi: u64,
    context_ptr: *const u8,
    context_len: u32,
    consent_token: u64,
) -> u64 ;

// Query-axes on a composition-handle.
extern "C" fn __cssl_intelligence_query_axis(
    handle: u64,
    axis_id: u32,
) -> u64 ;

// Axis constants (matches substrate-intelligence W17-F surface)
const AXIS_NPC_ARCHETYPE      : u32 = 1u32 ;
const AXIS_NPC_COUNT          : u32 = 2u32 ;
const AXIS_LOOT_COUNT         : u32 = 3u32 ;
const AXIS_LOOT_RARITY        : u32 = 4u32 ;
const AXIS_INTERACTABLE_KIND  : u32 = 5u32 ;
const AXIS_BIOME_MOOD         : u32 = 6u32 ;
const AXIS_ROOM_TENSION       : u32 = 7u32 ;
const AXIS_CAUSAL_VETO        : u32 = 8u32 ;        // 1 if causal-seed predicts harm

// ω-field cell read (semantic-state at room-coords)
extern "C" fn __cssl_omega_field_read(
    cell_x: i32,
    cell_y: i32,
    cell_z: i32,
    out_state_ptr: *mut u8,
    out_state_cap: u32,
) -> i32 ;

