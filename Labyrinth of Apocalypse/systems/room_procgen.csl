#[test]
fn t01_rarity_codes_distinct() -> i32 {
    if RARITY_COMMON     != 0u8 { return 1 ; }
    if RARITY_UNCOMMON   != 1u8 { return 2 ; }
    if RARITY_RARE       != 2u8 { return 3 ; }
    if RARITY_EPIC       != 3u8 { return 4 ; }
    if RARITY_LEGENDARY  != 4u8 { return 5 ; }
    if RARITY_MYTHIC     != 5u8 { return 6 ; }
    if RARITY_PRISMATIC  != 6u8 { return 7 ; }
    if RARITY_CHAOTIC    != 7u8 { return 8 ; }
    0
}

#[test]
fn t02_default_drop_rates_sum_permyriad_full() -> i32 {
    let sum: u32 = DROP_RATE_COMMON_DEFAULT
        + DROP_RATE_UNCOMMON_DEFAULT
        + DROP_RATE_RARE_DEFAULT
        + DROP_RATE_EPIC_DEFAULT
        + DROP_RATE_LEGENDARY_DEFAULT
        + DROP_RATE_MYTHIC_DEFAULT
        + DROP_RATE_PRISMATIC_DEFAULT
        + DROP_RATE_CHAOTIC_DEFAULT ;
    if sum != 10000u32 { return 1 ; }
    0
}

