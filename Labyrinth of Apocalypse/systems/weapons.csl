fn weapons_destroy_session(handle: i64) -> i32 { __cssl_weapons_destroy_session(handle) }
fn weapons_kind_count() -> u32 { WEAPON_KIND_COUNT }
fn weapons_base_dps(kind: u32, tier: u32) -> f32 { base_dps(kind, tier) }
fn weapons_per_shot(kind: u32, tier: u32) -> f32 { per_shot(kind, tier) }
fn weapons_dps_signature(kind: u32, tier: u32) -> u64 { dps_signature(kind, tier) }
fn weapons_compute_damage(
    base: f32, zone: u32, dmg_type: u32, armor_class: u32, crit: u32,
) -> f32 { compute_damage(base, zone, dmg_type, armor_class, crit) }
fn weapons_damage_falloff(
    distance_m: f32, min_range_m: f32, max_range_m: f32, floor_mult: f32,
) -> f32 { damage_falloff(distance_m, min_range_m, max_range_m, floor_mult) }
