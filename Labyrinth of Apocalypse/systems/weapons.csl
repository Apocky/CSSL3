fn weapons_pool_capacity(handle: i64) -> u32 { __cssl_weapons_pool_capacity(handle) }

// § Cosmetic-axiom verification gate (CSSL-native · DPS-signature parity).
//
// Verifies that two builds with same (kind, tier) but different cosmetic
// skins produce identical DPS-signatures. Returns 1 on parity, 0 on leak.
// If this ever returns 0 the cosmetic-only-axiom has been violated.
fn weapons_axiom_parity_check(kind: u32, tier: u32) -> u32 {
    let a : WeaponBuild = WeaponBuild { kind: kind, tier: tier, cosmetic: cosmetic_default() } ;
    let b : WeaponBuild = WeaponBuild { kind: kind, tier: tier, cosmetic: cosmetic_gold_tracer() } ;
    let sig_a : u64 = build_dps_signature(a) ;
    let sig_b : u64 = build_dps_signature(b) ;
    let dmg_a : f32 = build_per_shot(a) ;
    let dmg_b : f32 = build_per_shot(b) ;
    if sig_a == sig_b && dmg_a == dmg_b { return 1 ; }
    0
}

// § weapons_axiom_attestation : iterates ALL (kind × tier) = 96 builds
//   and verifies cosmetic-skin SWAP doesn't alter DPS-signature.
//   Returns 1 on full pass ; 0 on first leak detected.
//   This is the RUNTIME proof of cosmetic-only-axiom.
fn weapons_axiom_attestation() -> u32 {
    let mut k : u32 = 0 ;
    while k < WEAPON_KIND_COUNT {
        let mut t : u32 = 0 ;
        while t < TIER_COUNT {
            if weapons_axiom_parity_check(k, t) == 0 { return 0 ; }
            t = t + 1 ;
        }
        k = k + 1 ;
    }
    1
}

// ─────────────────────────────────────────────────────────────────────────
// § INLINE TESTS (≥ test discipline · runtime-attestation gates)
// ─────────────────────────────────────────────────────────────────────────

// Test : count matches frozen list (16 kinds).
fn test_weapons_kind_count_is_16() -> u32 {
    if WEAPON_KIND_COUNT == 16 { 1 } else { 0 }
}

// Test : tier ladder monotonic (Mythic ≥ Legendary ≥ ... ≥ Common).
fn test_tier_dps_monotone() -> u32 {
    let c : f32 = tier_dps_multiplier(TIER_COMMON) ;
    let u : f32 = tier_dps_multiplier(TIER_UNCOMMON) ;
    let r : f32 = tier_dps_multiplier(TIER_RARE) ;
    let e : f32 = tier_dps_multiplier(TIER_EPIC) ;
    let l : f32 = tier_dps_multiplier(TIER_LEGENDARY) ;
    let m : f32 = tier_dps_multiplier(TIER_MYTHIC) ;
    if u >= c && r >= u && e >= r && l >= e && m >= l { 1 } else { 0 }
}

// Test : Mythic ≈ 2× Common (frozen ratio).
fn test_mythic_2x_common() -> u32 {
    let c : f32 = tier_dps_multiplier(TIER_COMMON) ;
    let m : f32 = tier_dps_multiplier(TIER_MYTHIC) ;
    let ratio : f32 = m / c ;
    if ratio >= 1.99 && ratio <= 2.01 { 1 } else { 0 }
}

// Test : headshot multiplier = 2.0x.
fn test_headshot_2x() -> u32 {
    let h : f32 = hit_zone_multiplier(ZONE_HEAD) ;
    let b : f32 = hit_zone_multiplier(ZONE_BODY) ;
    if h == 2.0 && b == 1.0 { 1 } else { 0 }
}

// Test : weakpoint multiplier = 2.5x.
fn test_weakpoint_25x() -> u32 {
    let w : f32 = hit_zone_multiplier(ZONE_WEAK_POINT) ;
    if w == 2.5 { 1 } else { 0 }
}

// Test : armor-matrix unarmored is neutral (=1.0) for all damage types.
fn test_armor_unarmored_neutral() -> u32 {
    let mut dt : u32 = 0 ;
    while dt < DMG_TYPE_COUNT {
        let m : f32 = armor_modifier(dt, ARMOR_UNARMORED) ;
        if m != 1.0 { return 0 ; }
        dt = dt + 1 ;
    }
    1
}

// Test : crit multiplies damage by 1.5x.
fn test_crit_15x() -> u32 {
    let normal : f32 = compute_damage(100.0, ZONE_BODY, DMG_KINETIC, ARMOR_UNARMORED, 0) ;
    let crit   : f32 = compute_damage(100.0, ZONE_BODY, DMG_KINETIC, ARMOR_UNARMORED, 1) ;
    let ratio  : f32 = crit / normal ;
    if ratio >= 1.49 && ratio <= 1.51 { 1 } else { 0 }
}

// Test : falloff saturates correctly at endpoints.
fn test_falloff_saturates() -> u32 {
    let near : f32 = damage_falloff( 5.0, 10.0, 50.0, 0.4) ;
    let far  : f32 = damage_falloff(60.0, 10.0, 50.0, 0.4) ;
    let mid  : f32 = damage_falloff(30.0, 10.0, 50.0, 0.4) ;
    if near == 1.0 && far == 0.4 && mid > 0.4 && mid < 1.0 { 1 } else { 0 }
}

// Test : cosmetic-only-axiom (full attestation across all kinds × tiers).
fn test_cosmetic_only_axiom() -> u32 {
    weapons_axiom_attestation()
}

// Test : per_shot is pure-fn of (kind, tier) — same input → same output.
fn test_per_shot_deterministic() -> u32 {
    let a : f32 = per_shot(WEAPON_RIFLE, TIER_RARE) ;
    let b : f32 = per_shot(WEAPON_RIFLE, TIER_RARE) ;
    if a == b { 1 } else { 0 }
}

// Test : recoil pattern is deterministic for same (kind, shot_index).
fn test_recoil_deterministic() -> u32 {
    let a : RecoilEvent = recoil_for(WEAPON_RIFLE, 5) ;
    let b : RecoilEvent = recoil_for(WEAPON_RIFLE, 5) ;
    if a.pitch_rad == b.pitch_rad && a.yaw_rad == b.yaw_rad { 1 } else { 0 }
}

// Test : melee weapon has zero recoil (frozen mechanic).
fn test_melee_zero_recoil() -> u32 {
    let r : RecoilEvent = recoil_for(WEAPON_MELEE, 5) ;
    if r.pitch_rad == 0.0 && r.yaw_rad == 0.0 { 1 } else { 0 }
}

// Test : pool capacity is 256 (FROZEN).
fn test_pool_capacity_256() -> u32 {
    if PROJECTILE_POOL_CAP == 256 { 1 } else { 0 }
}

// § weapons_run_all_inline_tests : aggregate gate ; returns count of passes.
//   13/13 = full pass ; any value < 13 = regression in CSSL-Sem.
fn weapons_run_all_inline_tests() -> u32 {
    let mut passes : u32 = 0 ;
    if test_weapons_kind_count_is_16() == 1 { passes = passes + 1 ; }
    if test_tier_dps_monotone()        == 1 { passes = passes + 1 ; }
    if test_mythic_2x_common()         == 1 { passes = passes + 1 ; }
    if test_headshot_2x()              == 1 { passes = passes + 1 ; }
    if test_weakpoint_25x()            == 1 { passes = passes + 1 ; }
    if test_armor_unarmored_neutral()  == 1 { passes = passes + 1 ; }
    if test_crit_15x()                 == 1 { passes = passes + 1 ; }
    if test_falloff_saturates()        == 1 { passes = passes + 1 ; }
    if test_cosmetic_only_axiom()      == 1 { passes = passes + 1 ; }
    if test_per_shot_deterministic()   == 1 { passes = passes + 1 ; }
    if test_recoil_deterministic()     == 1 { passes = passes + 1 ; }
    if test_melee_zero_recoil()        == 1 { passes = passes + 1 ; }
    if test_pool_capacity_256()        == 1 { passes = passes + 1 ; }
    passes
}

