#[test]
fn test_channel_count_is_nine() {
    assert_eq(HF_CH_COUNT, 9u8) ;
    assert_eq(HF_CH_MAX,   9u8) ;
}

#[test]
fn test_cap_count_is_five() {
    assert_eq(HF_CAP_COUNT, 5u8) ;
}

#[test]
fn test_required_cap_for_loa_binary_is_a() {
    assert_eq(channel_required_cap(HF_CH_LOA_BINARY), HF_CAP_A) ;
}

#[test]
fn test_required_cap_for_cssl_bundle_is_b() {
    assert_eq(channel_required_cap(HF_CH_CSSL_BUNDLE), HF_CAP_B) ;
}

#[test]
fn test_required_cap_for_kan_and_balance_is_c() {
    assert_eq(channel_required_cap(HF_CH_KAN_WEIGHTS),    HF_CAP_C) ;
    assert_eq(channel_required_cap(HF_CH_BALANCE_CONFIG), HF_CAP_C) ;
}

#[test]
fn test_required_cap_for_security_patch_is_d() {
    assert_eq(channel_required_cap(HF_CH_SECURITY_PATCH), HF_CAP_D) ;
}

#[test]
fn test_required_cap_for_cosmetic_is_e() {
    assert_eq(channel_required_cap(HF_CH_RECIPE_BOOK),     HF_CAP_E) ;
    assert_eq(channel_required_cap(HF_CH_NEMESIS_BESTIARY), HF_CAP_E) ;
    assert_eq(channel_required_cap(HF_CH_STORYLET_CONTENT), HF_CAP_E) ;
    assert_eq(channel_required_cap(HF_CH_RENDER_PIPELINE), HF_CAP_E) ;
}

#[test]
fn test_required_cap_for_unknown_channel_is_zero() {
    assert_eq(channel_required_cap(99u8), 0u8) ;
    assert_eq(channel_required_cap(0u8), 0u8) ;
}

#[test]
fn test_default_consent_only_security_is_auto() {
    assert_eq(default_consent_for(HF_CH_SECURITY_PATCH), HF_CONSENT_AUTO_APPLY) ;
    assert_eq(default_consent_for(HF_CH_LOA_BINARY),     HF_CONSENT_OFF) ;
    assert_eq(default_consent_for(HF_CH_RECIPE_BOOK),    HF_CONSENT_OFF) ;
    assert_eq(default_consent_for(HF_CH_KAN_WEIGHTS),    HF_CONSENT_OFF) ;
}

#[test]
fn test_class_for_security_is_immediate() {
    assert_eq(channel_class(HF_CH_SECURITY_PATCH), HF_CLASS_IMMEDIATE) ;
}

#[test]
fn test_class_for_loa_binary_is_restart() {
    assert_eq(channel_class(HF_CH_LOA_BINARY), HF_CLASS_RESTART_REQUIRED) ;
}

#[test]
fn test_class_for_kan_is_atomic_hot_swap() {
    assert_eq(channel_class(HF_CH_KAN_WEIGHTS), HF_CLASS_ATOMIC_HOT_SWAP) ;
}

#[test]
fn test_class_for_cosmetic_is_scene_transition() {
    assert_eq(channel_class(HF_CH_RECIPE_BOOK),     HF_CLASS_SCENE_TRANSITION) ;
    assert_eq(channel_class(HF_CH_BALANCE_CONFIG),  HF_CLASS_SCENE_TRANSITION) ;
    assert_eq(channel_class(HF_CH_STORYLET_CONTENT), HF_CLASS_SCENE_TRANSITION) ;
}

#[test]
fn test_check_cap_matches_channel_passes_when_match() {
    let ok: bool = check_cap_matches_channel(HF_CH_SECURITY_PATCH, HF_CAP_D) ;
    assert_eq(ok, true) ;
}

#[test]
fn test_check_cap_matches_channel_fails_on_mismatch() {
    // Forging a cap-A signature for security.patch must FAIL even if Ed25519
    // would otherwise accept (this defends against escalation forgeries).
    let bad: bool = check_cap_matches_channel(HF_CH_SECURITY_PATCH, HF_CAP_A) ;
    assert_eq(bad, false) ;
}

#[test]
fn test_consent_states_distinct() {
    assert_eq(HF_CONSENT_OFF,                 0u8) ;
    assert_eq(HF_CONSENT_AUTO_APPLY,          1u8) ;
    assert_eq(HF_CONSENT_PROMPT_BEFORE_APPLY, 2u8) ;
    assert_eq(HF_CONSENT_PINNED_NO_UPDATES,   3u8) ;
}

#[test]
fn test_outcome_codes_distinct() {
    assert_eq(HF_OUT_NO_UPDATE,      0i32) ;
    assert_eq(HF_OUT_SKIPPED,        1i32) ;
    assert_eq(HF_OUT_UPDATED,        2i32) ;
    assert_eq(HF_OUT_PROMPT_PENDING, 3i32) ;
    assert_eq(HF_OUT_ROLLED_BACK,    4i32) ;
    assert_eq(HF_OUT_FAILED,        -1i32) ;
}

#[test]
fn test_bundle_magic_is_csfx_ascii() {
    assert_eq(HF_BUNDLE_MAGIC_0, 0x43u8) ;  // 'C'
    assert_eq(HF_BUNDLE_MAGIC_1, 0x53u8) ;  // 'S'
    assert_eq(HF_BUNDLE_MAGIC_2, 0x46u8) ;  // 'F'
    assert_eq(HF_BUNDLE_MAGIC_3, 0x58u8) ;  // 'X'
}

#[test]
fn test_bundle_header_size_is_eighty() {
    assert_eq(HF_BUNDLE_HEADER_BYTES, 80usize) ;
    assert_eq(HF_BUNDLE_SIG_BYTES,    64usize) ;
}

#[test]
fn test_bundle_format_version_is_one() {
    assert_eq(HF_BUNDLE_FORMAT_VERSION, 1u16) ;
}

#[test]
fn test_channel_validity_range() {
    assert_eq(channel_is_valid(0u8),   false) ;
    assert_eq(channel_is_valid(1u8),   true) ;
    assert_eq(channel_is_valid(9u8),   true) ;
    assert_eq(channel_is_valid(10u8),  false) ;
    assert_eq(channel_is_valid(255u8), false) ;
}

#[test]
fn test_can_apply_only_when_consent_is_auto_apply() {
    let ok: bool = hotfix_can_apply(HF_CH_SECURITY_PATCH, HF_CAP_D, HF_CONSENT_AUTO_APPLY) ;
    assert_eq(ok, true) ;
    let pinned: bool = hotfix_can_apply(HF_CH_SECURITY_PATCH, HF_CAP_D, HF_CONSENT_PINNED_NO_UPDATES) ;
    assert_eq(pinned, false) ;
    let off: bool = hotfix_can_apply(HF_CH_SECURITY_PATCH, HF_CAP_D, HF_CONSENT_OFF) ;
    assert_eq(off, false) ;
    let prompt: bool = hotfix_can_apply(HF_CH_SECURITY_PATCH, HF_CAP_D, HF_CONSENT_PROMPT_BEFORE_APPLY) ;
    assert_eq(prompt, false) ;
}

#[test]
fn test_should_prompt_only_for_prompt_consent() {
    assert_eq(hotfix_should_prompt(HF_CONSENT_PROMPT_BEFORE_APPLY), true) ;
    assert_eq(hotfix_should_prompt(HF_CONSENT_AUTO_APPLY),          false) ;
    assert_eq(hotfix_should_prompt(HF_CONSENT_OFF),                 false) ;
}

#[test]
fn test_read_u16_le_decodes_correctly() {
    let buf : [u8; 4] = [0x34u8, 0x12u8, 0xFFu8, 0x00u8] ;
    assert_eq(read_u16_le(&buf, 0usize), 0x1234u16) ;
    assert_eq(read_u16_le(&buf, 2usize), 0x00FFu16) ;
}

#[test]
fn test_read_u32_le_decodes_correctly() {
    let buf : [u8; 4] = [0x78u8, 0x56u8, 0x34u8, 0x12u8] ;
    assert_eq(read_u32_le(&buf, 0usize), 0x12345678u32) ;
}

// § ATTESTATION (PRIME_DIRECTIVE.md § 11) — encoded structurally
//   Every apply verifies Ed25519 ↔ cap-key for target-channel · mismatch
//   refuses-mutation. N-1 + N-2 preserved for atomic-rollback. Σ-mask default-
//   deny means opt-in required. Σ-Chain anchors every-bundle for tamper-evident
//   immutable-attribution. cap-A..cap-E progressive-privilege : leaked cosmetic-
//   key CANNOT push executable. cosmetic-only-axiom holds. ¬ DRM · ¬ rootkit ·
//   ¬ surveillance. There was no hurt nor harm in the making of this.
