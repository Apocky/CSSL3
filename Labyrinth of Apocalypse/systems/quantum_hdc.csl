//
// § PRIME-DIRECTIVE
//   ℂ-HDC ≠ surveillance-vector ≠ user-fingerprinting. The phase-info
//   per-component is deterministic-derivation from inputs. No host-clock,
//   no thread-rng. Coherence-measure is observable to the consumer
//   (ω-field cell · crystal · creature) — no hidden-state.
//   ¬ harm @ making-of-this · sovereign-substrate-extension.
//
// § STRUCT · CHdcVec
//   record CHdcVec {
//     amp:   [f32 × 256]   // ‖aᵢ‖ ∈ [0, 1] amplitude per-component
//     phase: [f32 × 256]   // φᵢ ∈ [-π, π] phase per-component
//   }
//
// § OPS
//   bind(a · b) → c
//     ∀ i ∈ 0..256 :
//       c.amp[i]   = a.amp[i] · b.amp[i]
//       c.phase[i] = wrap(a.phase[i] + b.phase[i])
//     ∵ aᵢ·bᵢ = ‖aᵢ‖·‖bᵢ‖ · exp(i·(φₐ+φ_b))
//
//   bundle(&[v₁ ··· vₙ]) → c
//     re = ∑ⱼ vⱼ.amp[i]·cos(vⱼ.phase[i])
//     im = ∑ⱼ vⱼ.amp[i]·sin(vⱼ.phase[i])
//     c.amp[i]   = √(re² + im²)
//     c.phase[i] = atan2(im, re)
//     // then renormalize amplitudes to max-amp = 1.0
//
//   permute(v · n) → v'
//     ∀ i : v'.amp[i]   = v.amp[i]
//           v'.phase[i] = wrap(v.phase[i] + n·π/256)
//
//   coherence(a · b) → f32 ∈ [0, 1]
//     re = ∑ aᵢ·bᵢ·cos(φₐ - φ_b)
//     im = ∑ aᵢ·bᵢ·sin(φₐ - φ_b)
//     return √(re² + im²) / 256
//
//   interfere(a · b) → c
//     // explicit-interference : sum without renormalize · phase-bias preserved
//     c.amp[i]   = √((aᵢ·cos(φₐ) + bᵢ·cos(φ_b))² + (aᵢ·sin(φₐ) + bᵢ·sin(φ_b))²)
//     c.phase[i] = atan2(aᵢ·sin(φₐ) + bᵢ·sin(φ_b) · aᵢ·cos(φₐ) + bᵢ·cos(φ_b))
//     // amplitudes can-go > 1 (constructive) or → 0 (destructive)
//
//   derive_from_blake3(seed: [u8 × 32]) → CHdcVec
//     h = blake3.update(b"chdc-derive-v1") · update(seed)
//     bytes = h.finalize_xof.read(2048)  // 256 components · 8 bytes each
//     ∀ i ∈ 0..256 :
//       u₀ = u32.from_le(bytes[i·8 ··· i·8+4])
//       u₁ = u32.from_le(bytes[i·8+4 ··· i·8+8])
//       amp[i]   = (u₀ as f32) / (u32.MAX as f32)        ∈ [0, 1]
//       phase[i] = ((u₁ as f32) / (u32.MAX as f32) - 0.5) · 2π  ∈ [-π, π]
//
// § DETERMINISM-CONTRACT
//   ∀ seed → derive_from_blake3(seed) bit-identical ∀ hosts
//   ∀ a · b → bind(a · b) bit-identical ∀ hosts (modulo IEEE-754 sum-order)
//     ⟹ tests use ε-tolerance ≤ 1e-5 for amplitude · 1e-4 for phase
//   no-thread-local-state · no-system-clock · no-getrandom
//
// § ENGINE-INTEGRATION (forward-references · deferred to consumer-slices)
//   ω-field-cell : per-cell quantum-tag attached @ semantic-annotation
//                  coherence-measure observable to perception-π
//   crystal-graph : crystal-pair-resonance via interfere() showing fringes
//   creature-genome : optional-quantum-overlay on-binary-genome
//                     (decoherence-tolerance allele · evolutionary-pressure)
//   substrate-intelligence : intent-translation via bind+permute composition
//                            response-coherence-score gates emission
//
// § PERFORMANCE-DESIGN-NOTES
//   AVX-512 FMA : (re·c - im·s · re·s + im·c) per-component = 4-FMA-pairs
//   256 components @ 8-component-FMA-vec = 32 vec-instructions per-bind
//   sub-microsecond on modern silicon · ≪ KAN-network forward-pass
