§ AXIOM-8 · empty-field zero-output
═════════════════════════════════════════════════════════════════════════════
  ∀ pixel ∈ field :
    contributing-crystals = ∅ ⇒ pixel = (0, 0, 0, 0)
    InterferenceFrame.n_pixels_lit = 0

§ INTERFACE
═════════════════════════════════════════════════════════════════════════════
fn resolve_interference_field(
    observer  : ObserverCoord,
    crystals  : &[Crystal],
    field     : &mut PixelField,
) → InterferenceFrame :
  ⟨§ contract⟩
    field-pre = field-post.cleared
    field-post.pixel-count = field.width × field.height
    determinism ⊑ ∀ host ⊗ same-inputs ⇒ same-bytes
    Σ-mask-honored = ∀ pixel
  ⟨§ side-effects⟩
    ↦ field.pixels[ ∀ ] ← write-RGBA8
  ⟨§ frame-output⟩
    InterferenceFrame {
      observer        : ObserverCoord
      n_crystals      : u32
      n_pixels_lit    : u32     ← pixels with bundle.amp > ε
      n_fringe_peaks  : u32     ← pixels with bundle.amp > 1.5 × per-crystal-max
      fingerprint     : u32     ← BLAKE3-truncate(field.bytes)
    }

§ HSV→RGB (deterministic floating-point)
═════════════════════════════════════════════════════════════════════════════
fn hsv_to_rgb(h_deg : f32, s : f32, v : f32) → (u8, u8, u8) :
  ⟨h ∈ [0, 360) · s ∈ [0, 1] · v ∈ [0, 1]⟩
  c ← v × s
  x ← c × (1 - abs((h / 60) % 2 - 1))
  m ← v - c
  (r', g', b') ← match h:
    [  0,  60) → (c, x, 0)
    [ 60, 120) → (x, c, 0)
    [120, 180) → (0, c, x)
    [180, 240) → (0, x, c)
    [240, 300) → (x, 0, c)
    [300, 360) → (c, 0, x)
  R ← clamp((r' + m) × 255, 0, 255) .as-u8
  G ← clamp((g' + m) × 255, 0, 255) .as-u8
  B ← clamp((b' + m) × 255, 0, 255) .as-u8

