§ AXIOM-1 · pixel = bundle .of(ℂ-wave-contribution-from-each-crystal)
═════════════════════════════════════════════════════════════════════════════
  ∀ pixel ∈ field :
    bundle ← Σ ⟨crystal.ℂ-wave .at(pixel-coord)⟩
    pixel.R ← magnitude²(bundle) ⊑ intensity
    pixel.HUE ← arg(bundle) ⊑ hue-shift  ← HSV→RGB
    pixel.A ← 255 ← if bundle.amp > ε
              else 0

§ AXIOM-2 · per-crystal ℂ-wave construction
═════════════════════════════════════════════════════════════════════════════
  ∀ crystal ∈ contributing-crystals :
    seed ← BLAKE3(crystal.fingerprint || sample-idx || pixel-x || pixel-y)
    base ← CHdcVec.derive_from_blake3(seed)        ← ∈ [0,1] amplitude
    phase-rot ← (observer.yaw_milli + observer.pitch_milli + sample-idx · 7)
    rotated ← base.permute(phase-rot)              ← phase-only rotation
    weighted ← scale-amplitude(rotated, weight)    ← inverse-distance × extent
    Σ ← bundle Σ rotated.weighted

§ AXIOM-3 · holographic-reduction.to(ℂ-mean) → R-G-B
═════════════════════════════════════════════════════════════════════════════
  ℂ-vec.amp[256] · ℂ-vec.phase[256] →
    mean-amp ← Σᵢ amp[i] / 256
    mean-phase ← arg(Σᵢ ℂ.from-polar(amp[i], phase[i]))
    intensity ← clamp(mean-amp², 0, 1) · 255
    hue ← (mean-phase + π) / 2π · 360°               ← ∈ [0, 360]
    saturation ← coherence-score(crystal-bundle) ⊑ ∈ [0, 1]
    value ← intensity / 255
    (R, G, B) ← HSV→RGB(hue, saturation, value)

§ AXIOM-4 · Σ-mask per-aspect filter
═════════════════════════════════════════════════════════════════════════════
  silhouette-aspect-required-for-contribution ← bit-0
  bloom-aspect-modulates-saturation           ← bit-7
  ∀ crystal :
    if ¬(crystal.aspect_permitted(silhouette) ∧ observer.permits_aspect(silhouette)) :
      crystal-contribution ← ZERO
    if ¬(crystal.aspect_permitted(bloom) ∧ observer.permits_aspect(bloom)) :
      saturation ← saturation × 0.5            ← desaturate when bloom revoked

