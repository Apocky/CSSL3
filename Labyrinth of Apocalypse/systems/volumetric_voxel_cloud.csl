// ─────────────────────────────────────────────────────────────────────────

extern "C" fn voxel_cloud_dispatch(
    cloud: u32,
    observer_coord: u32,
    framebuffer_handle: u32,
    width: u32,
    height: u32
) -> u32 ;
// Encodes + submits the splat compute-pass. Returns 0 on success.
// `framebuffer_handle` is an RGBA8 storage-texture handle.

extern "C" fn voxel_cloud_dispatch_with_radius(
    cloud: u32,
    observer_coord: u32,
    framebuffer_handle: u32,
    width: u32,
    height: u32,
    splat_radius_px: u32
) -> u32 ;
// Variant with explicit splat radius.

// ─────────────────────────────────────────────────────────────────────────
// § STATS-API
// ─────────────────────────────────────────────────────────────────────────

extern "C" fn voxel_cloud_density_scale_q31(cloud: u32) -> u32 ;
// q1.31 fixed-point ; 0x80000000 = 1.0 (full density), lower = budget-scaled.

extern "C" fn voxel_cloud_capacity(cloud: u32) -> u32 ;
// Current GPU storage-buffer capacity in voxel-points.

// ─────────────────────────────────────────────────────────────────────────
// § REPLAY-API
// ─────────────────────────────────────────────────────────────────────────

extern "C" fn voxel_cloud_replay_compare(
    canonical_fingerprint: u32,
    rerun_fingerprint: u32
) -> u32 ;
// 1 if equal · 0 if mismatch. Drives fail-fast on cloud-divergence.

// ─────────────────────────────────────────────────────────────────────────
// § Σ-MASK CONSENT (PRIME-DIRECTIVE)
// ─────────────────────────────────────────────────────────────────────────
// Σ-mask gating runs INSIDE build_voxel_cloud :
//   - For each crystal, if `crystal.aspect_permitted(ASPECT_SILHOUETTE)` is
//     false, the crystal contributes ZERO cells.
//   - For observer-aware build, the observer's `permits_aspect(SILHOUETTE)`
//     is AND-ed ; if false the cloud is empty.
//   - Inside the splat shader the per-voxel sigma_mask is checked AGAIN
//     before the splat is written. Defense in depth.

extern "C" fn voxel_cloud_sigma_filter_apply(
    crystal_sigma_mask: u32,
    observer_sigma_token: u32,
    aspect: u32
) -> u32 ;
// 1 if the conjunction permits the aspect ; 0 if either denies.

// ─────────────────────────────────────────────────────────────────────────
// § PARADIGM-COMPOSITION · pixel-field × voxel-cloud
// ─────────────────────────────────────────────────────────────────────────
// Both rendering paradigms can run on the same crystal-set in the same
// frame. They produce DIFFERENT visual representations of the SAME ω-field
// state. The host wires them as parallel passes :
//
//   pass-A : substrate_resonance_dispatch(observer, crystals)
//             ⟶ pixel-field framebuffer (2D RGBA)
//   pass-B : voxel_cloud_dispatch(cloud, observer, framebuffer)
//             ⟶ voxel-cloud overlay (3D point splat)
//
// Compose-mode (host-side blend) selects which dominates :
//   compose-mode A=PIXEL_FIELD  ⟶ B-pass tinted-overlay (10% alpha)
//   compose-mode A=VOXEL_CLOUD  ⟶ B-pass dominant (A-pass underlay)
//   compose-mode A=DUAL         ⟶ alternating frames (genre-fluid switch)

const COMPOSE_MODE_PIXEL_FIELD : u32 = 0 ;
const COMPOSE_MODE_VOXEL_CLOUD : u32 = 1 ;
const COMPOSE_MODE_DUAL        : u32 = 2 ;
const COMPOSE_MODE_OVERLAY     : u32 = 3 ;

extern "C" fn voxel_cloud_compose_mode_set(mode: u32) -> u32 ;
extern "C" fn voxel_cloud_compose_mode_get() -> u32 ;

// ─────────────────────────────────────────────────────────────────────────
// § DETERMINISM CONTRACT
// ─────────────────────────────────────────────────────────────────────────
//   - Same (crystal-set · observer-coord · illuminant) ⇒ same VoxelCloudHandle
//   - cloud-fingerprint hash equality ⇒ identical voxel-cloud
//   - Crystal-order is part of the contract (re-ordering crystals changes
//     the fingerprint ; this is intentional for replay-attestation).
//   - Halton-jitter is deterministic from `crystal.fingerprint` ; never RNG.
//   - GPU splat order = cloud-buffer order = stable across runs ; the
//     write-only-storage-texture last-writer-wins is bit-stable within a
//     single dispatch on a given driver.

// ─────────────────────────────────────────────────────────────────────────
// § CSSLC-GAPS to close
// ─────────────────────────────────────────────────────────────────────────
//
//   1. struct-FFI VoxelCloudHandle ← post-W17 (current : opaque u32)
//   2. f32-fixed-point native ← post-W17 (i32-millis works · less precise)
//   3. atomic-uvec4 splat-accumulation ← future-iteration (write-only stage-0)
//   4. spectral-direct splat (skip RGB-projection) ← future-display
//   5. neural-direct emission (BCI-channel) ← future-hardware

// ─────────────────────────────────────────────────────────────────────────
// § STAGE-0 BOOTSTRAP
// ─────────────────────────────────────────────────────────────────────────
//
// Until csslc compiles this module directly, the canonical implementation
// lives at `compiler-rs/crates/cssl-host-substrate-volumetric/`. Its public
// API mirrors this surface :
//
//   build_voxel_cloud(&[Crystal]) -> VoxelCloudHandle
//   build_voxel_cloud_with_observer(&[Crystal], &ObserverCoord) -> VoxelCloudHandle
//   pack_voxel_cloud(&VoxelCloudHandle) -> Vec<GpuVoxelPoint>
//   VolumetricVoxelCloud::dispatch(...) -> &TextureView   [feature = "runtime"]
//
// The shader is `shaders/volumetric_splat.wgsl` ; entry-point `splat_main` ;
// workgroup-size (64, 1, 1) ; one thread per voxel-point.

