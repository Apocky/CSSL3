#[test] fn t01_kind_as_str_stable ( ) {
  assert_eq!( kind_as_str(KIND_SCENE)    , "scene"    ) ;
  assert_eq!( kind_as_str(KIND_NPC_LINE) , "npc_line" ) ;
  assert_eq!( kind_as_str(KIND_RECIPE)   , "recipe"   ) ;
  assert_eq!( kind_as_str(KIND_LORE)     , "lore"     ) ;
  assert_eq!( kind_as_str(KIND_SYSTEM)   , "system"   ) ;
}

#[test] fn t02_system_requires_sovereign ( ) {
  assert!( kind_requires_sovereign(KIND_SYSTEM) ) ;
  assert!( ¬ kind_requires_sovereign(KIND_SCENE) ) ;
  assert!( ¬ kind_requires_sovereign(KIND_LORE) ) ;
}

#[test] fn t03_validate_empty_prompt_rejected ( ) {
  let req = SelfAuthorRequest { prompt: "" , kind: KIND_SCENE , examples: [] , constraints: constraints_default() , target_path: "" } ;
  assert_eq!( validate_request(req) , REQ_ERR_PROMPT_EMPTY ) ;
}

#[test] fn t04_validate_too_large_prompt_rejected ( ) {
  let huge = "x" 'p repeat (SA_MAX_PROMPT_BYTES + 1) ;
  let req = SelfAuthorRequest { prompt: huge , kind: KIND_SCENE , examples: [] , constraints: constraints_default() , target_path: "" } ;
  assert_eq!( validate_request(req) , REQ_ERR_PROMPT_TOO_LARGE ) ;
}

#[test] fn t05_validate_too_many_examples_rejected ( ) {
  let exes = [ "e" ] 'p repeat (SA_MAX_EXAMPLES + 1) ;
  let req = SelfAuthorRequest { prompt: "p" , kind: KIND_SCENE , examples: exes , constraints: constraints_default() , target_path: "" } ;
  assert_eq!( validate_request(req) , REQ_ERR_TOO_MANY_EXAMPLES ) ;
}

#[test] fn t06_validate_lore_only_violation ( ) {
  let cs = Constraints { max_lines: 200 , max_tokens: 4096 , forbid_effect_strings: [] , lore_only: true , score_threshold: 75 } ;
  let req = SelfAuthorRequest { prompt: "p" , kind: KIND_SCENE , examples: [] , constraints: cs , target_path: "" } ;
  assert_eq!( validate_request(req) , REQ_ERR_LORE_ONLY_VIOLATED ) ;
}

#[test] fn t07_validate_happy_path ( ) {
  let req = SelfAuthorRequest { prompt: "p" , kind: KIND_SCENE , examples: [] , constraints: constraints_default() , target_path: "" } ;
  assert_eq!( validate_request(req) , REQ_ERR_OK ) ;
}

#[test] fn t08_forbidden_target_compiler_rejected ( ) {
  assert!( is_forbidden_target("compiler-rs/crates/csslc/src/lib.rs") ) ;
  assert!( is_forbidden_target("compiler-rs/crates/cssl-rt/src/lib.rs") ) ;
}

#[test] fn t09_forbidden_target_substrate_glob_rejected ( ) {
  assert!( is_forbidden_target("compiler-rs/crates/cssl-substrate-sigma-runtime/src/lib.rs") ) ;
  assert!( is_forbidden_target("compiler-rs/crates/cssl-substrate-sigma-chain/src/entry.rs") ) ;
  assert!( is_forbidden_target("compiler-rs/crates/cssl-substrate-omega-field/src/cell.rs") ) ;
}

#[test] fn t10_forbidden_target_self_rejected ( ) {
  assert!( is_forbidden_target("compiler-rs/crates/cssl-host-self-author/src/orchestrator.rs") ) ;
}

#[test] fn t11_forbidden_target_prime_directive_rejected ( ) {
  assert!( is_forbidden_target("PRIME_DIRECTIVE.md") ) ;
}

#[test] fn t12_loa_scenes_allowed ( ) {
  assert!( ¬ is_forbidden_target("Labyrinth of Apocalypse/scenes/test_room.cssl") ) ;
  assert!( ¬ is_forbidden_target("Labyrinth of Apocalypse/systems/economy.csl") ) ;
