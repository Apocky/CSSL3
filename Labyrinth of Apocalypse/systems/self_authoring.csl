§§ THESIS
  ⊢ engine 'd self-author CSSL ⊑ {scenes · NPC-lines · recipes · lore · systems}
  ⊢ flow : prompt → llm-bridge → CSSL-string → csslc-compile → sandbox-execute
            → quality-score → IF score ≥ θ ∧ cap-grant → live-mutate
            ELSE record-only
  ⊢ all-outcomes → TrainingPairLog → Σ-Chain-anchor
  ⊢ feedback-loop : KAN-loop (W12-3) reads-training-pairs → bias-adjust

# ──────────────────────────────────────────────────────────────────────────
# § PUBLIC CONSTANTS — mirror cssl-host-self-author/src/lib.rs
# ──────────────────────────────────────────────────────────────────────────

const SA_DEFAULT_SCORE_THRESHOLD     : u8     = 75 ;
const SA_DEFAULT_TRAINING_RING_CAP   : u32    = 4096 ;
const SA_MAX_PROMPT_BYTES            : u32    = 16384 ;     // 16 KiB
const SA_MAX_EXAMPLES                : u32    = 8 ;
const SA_MAX_EXAMPLE_BYTES           : u32    = 4096 ;      // 4 KiB
const SA_MAX_SOURCE_BYTES            : u32    = 65536 ;     // 64 KiB

# § sandbox-config defaults (mirror SandboxConfig::default)
const SA_SANDBOX_COMPILE_ONLY        : bool   = true ;
const SA_SANDBOX_MAX_DIAGNOSTICS     : u32    = 64 ;
const SA_SANDBOX_DENY_EXTERNS        : bool   = true ;

# ──────────────────────────────────────────────────────────────────────────
# § SelfAuthorKind  ⊑ 5-variants  ←→ Rust enum SelfAuthorKind
# ──────────────────────────────────────────────────────────────────────────

const KIND_SCENE     : u8 = 0 ;  // .cssl scene-file (entities · triggers · lighting · camera)
const KIND_NPC_LINE  : u8 = 1 ;  // single dialogue-snippet (composes-into-scene)
const KIND_RECIPE    : u8 = 2 ;  // crafting recipe (in · out · station · time)
const KIND_LORE      : u8 = 3 ;  // prose-block (¬ executable · gated by Constraints.lore_only)
const KIND_SYSTEM    : u8 = 4 ;  // rules+invariants+effects (high-impact · sovereign-bit-required)
const KIND_COUNT     : u8 = 5 ;

# § kind-tag stable-string lookup (mirror SelfAuthorKind::as_str)
fn kind_as_str ( k : u8 ) -> Str
  | k == KIND_SCENE     -> "scene"
  | k == KIND_NPC_LINE  -> "npc_line"
  | k == KIND_RECIPE    -> "recipe"
  | k == KIND_LORE      -> "lore"
  | k == KIND_SYSTEM    -> "system"
  | _                   -> "unknown"

# § sovereign-bit requirement (mirror SelfAuthorKind::requires_sovereign)
fn kind_requires_sovereign ( k : u8 ) -> bool
  return k == KIND_SYSTEM

# ──────────────────────────────────────────────────────────────────────────
# § FORBIDDEN.TARGETS ‼ structural-rejection-pre-LLM (12 prefixes)
# ──────────────────────────────────────────────────────────────────────────
# §§ matched as path-prefix (case-sensitive · zero-allocation)
# §§ list mirrors compiler-rs/crates/cssl-host-self-author/src/forbidden.rs

const FORBIDDEN_TARGETS_COUNT : u8 = 12 ;

const FORBIDDEN_TARGET_0  : Str = "compiler-rs/crates/csslc/" ;
const FORBIDDEN_TARGET_1  : Str = "compiler-rs/crates/cssl-rt/" ;
const FORBIDDEN_TARGET_2  : Str = "compiler-rs/crates/cssl-substrate-" ;       // glob-prefix : ALL substrate-tier crates
const FORBIDDEN_TARGET_3  : Str = "compiler-rs/crates/cssl-host-coder-runtime/" ;
const FORBIDDEN_TARGET_4  : Str = "compiler-rs/crates/cssl-host-self-author/" ;  // bootstrap-loop guard
const FORBIDDEN_TARGET_5  : Str = "compiler-rs/crates/cssl-host-attestation/" ;
const FORBIDDEN_TARGET_6  : Str = "compiler-rs/crates/cssl-host-akashic-records/" ;
const FORBIDDEN_TARGET_7  : Str = "compiler-rs/crates/cssl-host-sigma-chain/" ;
const FORBIDDEN_TARGET_8  : Str = "compiler-rs/crates/cssl-effects/" ;
const FORBIDDEN_TARGET_9  : Str = "compiler-rs/crates/cssl-caps/" ;
const FORBIDDEN_TARGET_10 : Str = "PRIME_DIRECTIVE.md" ;
const FORBIDDEN_TARGET_11 : Str = "specs/grand-vision/" ;

fn is_forbidden_target ( path : Str ) -> bool
  | path 'p starts-with FORBIDDEN_TARGET_0   -> true
  | path 'p starts-with FORBIDDEN_TARGET_1   -> true
  | path 'p starts-with FORBIDDEN_TARGET_2   -> true
  | path 'p starts-with FORBIDDEN_TARGET_3   -> true
  | path 'p starts-with FORBIDDEN_TARGET_4   -> true
  | path 'p starts-with FORBIDDEN_TARGET_5   -> true
  | path 'p starts-with FORBIDDEN_TARGET_6   -> true
  | path 'p starts-with FORBIDDEN_TARGET_7   -> true
  | path 'p starts-with FORBIDDEN_TARGET_8   -> true
  | path 'p starts-with FORBIDDEN_TARGET_9   -> true
  | path 'p starts-with FORBIDDEN_TARGET_10  -> true
  | path 'p starts-with FORBIDDEN_TARGET_11  -> true
  | _                                        -> false

# ──────────────────────────────────────────────────────────────────────────
# § Constraints  ←→ Rust struct Constraints
# ──────────────────────────────────────────────────────────────────────────

struct Constraints
  max_lines              : u32                # default 200
  max_tokens             : u32                # default 4096
  forbid_effect_strings  : Vec<Str>          # substrings rejected in generated CSSL
  lore_only              : bool                # if true → kind W! Lore
  score_threshold        : u8                  # 0..100 · auto-mutate floor

fn constraints_default ( ) -> Constraints
  return Constraints {
    max_lines:             200 ,
    max_tokens:             4096 ,
    forbid_effect_strings: [ "Effect::NetworkEgress" , "Effect::FsWrite" , "Effect::Surveil" ] ,
    lore_only:             false ,
    score_threshold:       SA_DEFAULT_SCORE_THRESHOLD
  }

# ──────────────────────────────────────────────────────────────────────────
# § SelfAuthorRequest  ←→ Rust struct SelfAuthorRequest
# ──────────────────────────────────────────────────────────────────────────

struct SelfAuthorRequest
  prompt        : Str
  kind          : u8                          # KIND_*
  examples      : Vec<Str>                    # ≤ SA_MAX_EXAMPLES
  constraints   : Constraints
  target_path   : Str                          # may be empty (record-only)

# § validation-error codes (mirror RequestError)
const REQ_ERR_OK                            : i32 =  0 ;
const REQ_ERR_PROMPT_EMPTY                  : i32 = -1 ;
const REQ_ERR_PROMPT_TOO_LARGE              : i32 = -2 ;
const REQ_ERR_TOO_MANY_EXAMPLES             : i32 = -3 ;
const REQ_ERR_EXAMPLE_TOO_LARGE             : i32 = -4 ;
const REQ_ERR_LORE_ONLY_VIOLATED            : i32 = -5 ;
const REQ_ERR_FORBIDDEN_TARGET              : i32 = -6 ;

fn validate_request ( req : SelfAuthorRequest ) -> i32
  | req.prompt 'p is-empty                              -> REQ_ERR_PROMPT_EMPTY
  | req.prompt 'p len > SA_MAX_PROMPT_BYTES             -> REQ_ERR_PROMPT_TOO_LARGE
  | req.examples 'p len > SA_MAX_EXAMPLES               -> REQ_ERR_TOO_MANY_EXAMPLES
  | ∃ e ∈ req.examples ⊗ e 'p len > SA_MAX_EXAMPLE_BYTES -> REQ_ERR_EXAMPLE_TOO_LARGE
  | req.constraints.lore_only ∧ req.kind ≠ KIND_LORE    -> REQ_ERR_LORE_ONLY_VIOLATED
  | req.target_path 'p ¬ is-empty ∧ is_forbidden_target(req.target_path) -> REQ_ERR_FORBIDDEN_TARGET
  | _                                                   -> REQ_ERR_OK

# ──────────────────────────────────────────────────────────────────────────
# § SANDBOX.ISOLATION  ←→ Rust Sandbox / SandboxConfig / SandboxReport
# ──────────────────────────────────────────────────────────────────────────
# §§ sandbox holds-zero-handle · only output channel = SandboxReport (in-memory)
# §§ ¬ network-egress (no socket-handle structurally)
# §§ ¬ FS-write outside scratch (compile_only=true · no codegen / no link)
# §§ ¬ subprocess-exec (caller-supplied CompileFn · in-process-only)

struct SandboxConfig
  compile_only      : bool                    # default true
  max_source_bytes  : u32                     # default 64 KiB
  max_diagnostics   : u32                     # default 64
  deny_externs      : bool                    # default true

# § CompileOutcome — 3 variants
const COMPILE_PASS      : u8 = 0 ;   # payload : warnings : u32
const COMPILE_FAIL      : u8 = 1 ;   # payload : errors   : Vec<Str>
const COMPILE_REJECTED  : u8 = 2 ;   # payload : reason   : Str

struct InlineTestReport
  test_count                 : u32           # count of `#[test]` blocks
  assert_count               : u32           # count of assert! / assert_eq!
  forbidden_effect_matched   : bool           # any forbid-effect substring matched

struct SandboxReport
  compile_kind     : u8                      # COMPILE_*
  warnings         : u32                     # valid when COMPILE_PASS
  errors_first     : Str                     # first error-string when COMPILE_FAIL
  reject_reason    : Str                     # when COMPILE_REJECTED
  tests            : InlineTestReport
  source_blake3    : Bytes<32>               # canonical-id for Σ-Chain-anchor

# § quality-score formula (mirror SandboxReport::quality_score)
fn quality_score ( r : SandboxReport ) -> u8
  | r.compile_kind ≠ COMPILE_PASS            -> 0u8
  | r.tests.forbidden_effect_matched         -> 0u8
  | _ -> {
      let mut s : u32 = 40 ;                  # compile-pass = 40
      s += if r.warnings == 0 then 20 else 0 ;
      s += if r.tests.test_count > 0 then 20 else 0 ;
      s += if r.tests.assert_count > 0 then 20 else 0 ;
      ⟦ s 'p min 100 ⟧ as u8
    }

# § sandbox.run — pre-LLM gate + size-check + extern-deny + compile + heuristics
fn sandbox_run ( cfg : SandboxConfig , forbid : Vec<Str> , source : Str , compile_fn : fn(Str)→u8 ) -> SandboxReport
  let blake : Bytes<32> = blake3(source 'p bytes) ;
  | source 'p len > cfg.max_source_bytes -> SandboxReport {
      compile_kind: COMPILE_REJECTED ,
      warnings: 0 ,
      errors_first: "" ,
      reject_reason: "source-too-large" ,
      tests: InlineTestReport { test_count: 0 , assert_count: 0 , forbidden_effect_matched: false } ,
      source_blake3: blake
    }
  | cfg.deny_externs ∧ source 'p contains "extern \"C\"" -> SandboxReport {
      compile_kind: COMPILE_REJECTED ,
      warnings: 0 ,
      errors_first: "" ,
      reject_reason: "extern-C-block-rejected" ,
      tests: InlineTestReport { test_count: 0 , assert_count: 0 , forbidden_effect_matched: false } ,
      source_blake3: blake
    }
  | _ -> {
      let kind   = compile_fn(source) ;
      let tc     = source 'p count-substrings "#[test]" ;
      let ac     = source 'p count-substrings "assert!" + source 'p count-substrings "assert_eq!" ;
      let fem    = ∃ s ∈ forbid ⊗ source 'p contains s ;
      SandboxReport {
        compile_kind: kind ,
        warnings: 0 ,
        errors_first: "" ,
        reject_reason: "" ,
        tests: InlineTestReport { test_count: tc , assert_count: ac , forbidden_effect_matched: fem } ,
        source_blake3: blake
      }
    }

# ──────────────────────────────────────────────────────────────────────────
# § LIVE-MUTATE.GATE — Σ-cap REQUIRED  ←→ Rust LiveMutateGate / LiveMutateDecision
# ──────────────────────────────────────────────────────────────────────────

const DECISION_ALLOW                       : u8 = 0 ;
const DECISION_DENY_SCORE_BELOW_THRESHOLD  : u8 = 1 ;
const DECISION_DENY_SANDBOX_FAILED         : u8 = 2 ;
const DECISION_DENY_FORBIDDEN_TARGET       : u8 = 3 ;
const DECISION_DENY_CAP_INVALID            : u8 = 4 ;
const DECISION_DENY_CAP_REVOKED            : u8 = 5 ;
const DECISION_DENY_SOVEREIGN_BIT_MISSING  : u8 = 6 ;
const DECISION_NOT_ATTEMPTED               : u8 = 7 ;  # record-only path

fn decision_as_str ( d : u8 ) -> Str
  | d == DECISION_ALLOW                       -> "allow"
  | d == DECISION_DENY_SCORE_BELOW_THRESHOLD  -> "deny_score_below_threshold"
  | d == DECISION_DENY_SANDBOX_FAILED         -> "deny_sandbox_failed"
  | d == DECISION_DENY_FORBIDDEN_TARGET       -> "deny_forbidden_target"
  | d == DECISION_DENY_CAP_INVALID            -> "deny_cap_invalid"
  | d == DECISION_DENY_CAP_REVOKED            -> "deny_cap_revoked"
  | d == DECISION_DENY_SOVEREIGN_BIT_MISSING  -> "deny_sovereign_bit_missing"
  | d == DECISION_NOT_ATTEMPTED               -> "not_attempted"
  | _                                          -> "unknown"

struct MutateContext
  target_path           : Str
  score                 : u8
  threshold             : u8
  requires_sovereign    : bool
  sovereign_bit_held    : bool
  now_unix              : u64
  issuing_sovereign_pk  : Bytes<32>
  source_blake3         : Bytes<32>

# § the AND-narrow gate — order matters (cheap-first · cap-last)
fn decide_mutate ( ctx : MutateContext , cap : SovereignCap , revoked_set : Set<Bytes<32>> , compile_passed : bool ) -> u8
  | is_forbidden_target(ctx.target_path)           -> DECISION_DENY_FORBIDDEN_TARGET
  | cap.holder_pubkey ∈ revoked_set                -> DECISION_DENY_CAP_REVOKED
  | ¬ cap_preflight_ok(cap , ctx.issuing_sovereign_pk , ctx.now_unix) -> DECISION_DENY_CAP_INVALID
  | ¬ compile_passed                                -> DECISION_DENY_SANDBOX_FAILED
  | ctx.score < ctx.threshold                      -> DECISION_DENY_SCORE_BELOW_THRESHOLD
  | ctx.requires_sovereign ∧ ¬ ctx.sovereign_bit_held -> DECISION_DENY_SOVEREIGN_BIT_MISSING
  | _                                                -> DECISION_ALLOW

# ──────────────────────────────────────────────────────────────────────────
# § SIGMA-CHAIN.ANCHOR.SEQUENCE  (every-attempt anchored)
# ──────────────────────────────────────────────────────────────────────────

const ENTRY_KIND_CAP_GRANT          : u8 = 1 ;
const ENTRY_KIND_ATTESTATION_ANCHOR : u8 = 2 ;
const ENTRY_KIND_CAP_REVOKE         : u8 = 3 ;

struct AnchorPayload
  target_path        : Str
  score              : u8
  threshold          : u8
  decision           : Str
  source_blake3_hex  : Str

fn anchor_payload_from_decision ( d : u8 , ctx : MutateContext ) -> AnchorPayload
  return AnchorPayload {
    target_path:       ctx.target_path ,
    score:             ctx.score ,
    threshold:         ctx.threshold ,
    decision:          decision_as_str(d) ,
    source_blake3_hex: ctx.source_blake3 'p hex
  }

# ──────────────────────────────────────────────────────────────────────────
# § TRAINING-PAIR.LOG  ←→ Rust TrainingPairLog (VecDeque ring)
# ──────────────────────────────────────────────────────────────────────────

struct TrainingPairRecord
  ts_unix            : u64
  prompt             : Str
  kind               : u8                       # KIND_*
  generated_cssl     : Str
  source_blake3_hex  : Str                      # 64-char-hex
  score              : u8
  decision           : u8                       # DECISION_*
  target_path        : Str

struct TrainingPairLog
  capacity   : u32                              # default 4096
  records    : Ring<TrainingPairRecord>         # FIFO · oldest-evicted-on-overflow

fn training_pair_push ( log : TrainingPairLog , rec : TrainingPairRecord ) -> Maybe<TrainingPairRecord>
  | log.records 'p len == log.capacity -> {
      let evicted = log.records 'p pop-front ;
      log.records 'p push-back rec ;
      Some(evicted)
    }
  | _ -> {
      log.records 'p push-back rec ;
      None
    }

# ──────────────────────────────────────────────────────────────────────────
# § ORCHESTRATOR  ←→ Rust SelfAuthorOrchestrator
# ──────────────────────────────────────────────────────────────────────────

struct OrchestratorConfig
  llm_caps               : u32                  # cssl-host-llm-bridge CapBits
  sandbox_cfg            : SandboxConfig
  default_threshold      : u8
  training_log_capacity  : u32

struct AuthorOutcome
  generated_cssl         : Str
  sandbox_report         : SandboxReport
  score                  : u8
  mutate_decision        : u8                   # DECISION_*
  sigma_chain_seq        : Maybe<u64>
  training_record_index  : u32

# § canonical 8-step pipeline (record-only path)
fn orchestrator_author ( cfg : OrchestratorConfig , log : TrainingPairLog , req : SelfAuthorRequest , now : u64 , compile_fn : fn(Str)→u8 ) -> Result<AuthorOutcome , i32>
  let v = validate_request(req) ;
  | v ≠ REQ_ERR_OK -> Err(v)
  | _ -> {
      let cssl   = llm_bridge_chat(req.prompt , req.kind , req.examples , req.constraints) ;
      let report = sandbox_run(cfg.sandbox_cfg , req.constraints.forbid_effect_strings , cssl , compile_fn) ;
      let score  = quality_score(report) ;
      let rec    = TrainingPairRecord {
        ts_unix:           now ,
        prompt:            req.prompt ,
        kind:              req.kind ,
        generated_cssl:    cssl ,
        source_blake3_hex: report.source_blake3 'p hex ,
        score:             score ,
        decision:          DECISION_NOT_ATTEMPTED ,
        target_path:       req.target_path
      } ;
      let idx    = log.records 'p len ;
      training_pair_push(log , rec) ;
      Ok(AuthorOutcome {
        generated_cssl:         cssl ,
        sandbox_report:         report ,
        score:                  score ,
        mutate_decision:        DECISION_NOT_ATTEMPTED ,
        sigma_chain_seq:        None ,
        training_record_index:  idx
      })
    }

# §§ FAILURE-MODES (¬ silent · ∀ recorded)
#   compile-error      ⇒ training-pair{score=0 · decision=NotAttempted}
#   sandbox-test-fail  ⇒ training-pair{score=low · decision=DenySandboxFailed}
#   cap-deny           ⇒ training-pair{decision=DenyCap{Invalid|Revoked|SovereignBitMissing}}
#   score-below-θ      ⇒ training-pair{decision=DenyScoreBelowThreshold}
#   forbidden-target   ⇒ early-reject-pre-LLM · ¬ training-pair (request-validation-fail)
# §§ INTEGRATION.POINTS (sibling-W12-fanout)
#   W12-1 cocreative.proposal_submit ⇒ orchestrator::submit_proposal · author() · training-pair
#   W12-3 KAN-loop ⇒ reads training_log().iter() · gradient-descend on (prompt → CSSL → score)
#   W12-4 ContentPackage (.ccpkg) ⇒ MAY consume training_log Allow-records as content-bundle inputs

# ──────────────────────────────────────────────────────────────────────────
# § FFI BOUNDARY (Rust-mirror)
# ──────────────────────────────────────────────────────────────────────────

extern "C" fn cssl_self_author_orchestrator_new( cfg_handle : u32 ) -> usize ;
extern "C" fn cssl_self_author_orchestrator_drop( handle : usize ) -> i32 ;
extern "C" fn cssl_self_author_validate( prompt_ptr : *const u8 , prompt_len : usize , kind : u8 , target_ptr : *const u8 , target_len : usize ) -> i32 ;
extern "C" fn cssl_self_author_run( handle : usize , prompt_ptr : *const u8 , prompt_len : usize , kind : u8 , target_ptr : *const u8 , target_len : usize , now_unix : u64 , out_score : *mut u8 , out_decision : *mut u8 ) -> i32 ;
extern "C" fn cssl_self_author_training_log_len( handle : usize ) -> u32 ;
extern "C" fn cssl_self_author_training_log_drain( handle : usize , out_buf : *mut u8 , out_cap : usize ) -> i32 ;
extern "C" fn cssl_self_author_revoke_cap( handle : usize , holder_pk_ptr : *const u8 , now_unix : u64 ) -> i32 ;

# ──────────────────────────────────────────────────────────────────────────
# § INLINE TESTS (≥ 12)
