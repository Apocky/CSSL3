}

#[test] fn t13_quality_score_pass_no_tests_60 ( ) {
  let r = SandboxReport {
    compile_kind: COMPILE_PASS , warnings: 0 , errors_first: "" , reject_reason: "" ,
    tests: InlineTestReport { test_count: 0 , assert_count: 0 , forbidden_effect_matched: false } ,
    source_blake3: [0u8 ; 32]
  } ;
  assert_eq!( quality_score(r) , 60u8 ) ;
}

#[test] fn t14_quality_score_full_100 ( ) {
  let r = SandboxReport {
    compile_kind: COMPILE_PASS , warnings: 0 , errors_first: "" , reject_reason: "" ,
    tests: InlineTestReport { test_count: 1 , assert_count: 1 , forbidden_effect_matched: false } ,
    source_blake3: [0u8 ; 32]
  } ;
  assert_eq!( quality_score(r) , 100u8 ) ;
}

#[test] fn t15_quality_score_compile_fail_zero ( ) {
  let r = SandboxReport {
    compile_kind: COMPILE_FAIL , warnings: 0 , errors_first: "E001" , reject_reason: "" ,
    tests: InlineTestReport { test_count: 0 , assert_count: 0 , forbidden_effect_matched: false } ,
    source_blake3: [0u8 ; 32]
  } ;
  assert_eq!( quality_score(r) , 0u8 ) ;
}

#[test] fn t16_quality_score_warnings_drop_to_80 ( ) {
  let r = SandboxReport {
    compile_kind: COMPILE_PASS , warnings: 3 , errors_first: "" , reject_reason: "" ,
    tests: InlineTestReport { test_count: 1 , assert_count: 1 , forbidden_effect_matched: false } ,
    source_blake3: [0u8 ; 32]
  } ;
  assert_eq!( quality_score(r) , 80u8 ) ;
}

#[test] fn t17_quality_score_forbidden_effect_zeros ( ) {
  let r = SandboxReport {
    compile_kind: COMPILE_PASS , warnings: 0 , errors_first: "" , reject_reason: "" ,
    tests: InlineTestReport { test_count: 5 , assert_count: 5 , forbidden_effect_matched: true } ,
    source_blake3: [0u8 ; 32]
  } ;
  assert_eq!( quality_score(r) , 0u8 ) ;
}

#[test] fn t18_decision_strings_stable ( ) {
  assert_eq!( decision_as_str(DECISION_ALLOW) , "allow" ) ;
  assert_eq!( decision_as_str(DECISION_DENY_SCORE_BELOW_THRESHOLD) , "deny_score_below_threshold" ) ;
  assert_eq!( decision_as_str(DECISION_DENY_SANDBOX_FAILED) , "deny_sandbox_failed" ) ;
  assert_eq!( decision_as_str(DECISION_DENY_FORBIDDEN_TARGET) , "deny_forbidden_target" ) ;
  assert_eq!( decision_as_str(DECISION_DENY_CAP_REVOKED) , "deny_cap_revoked" ) ;
  assert_eq!( decision_as_str(DECISION_DENY_SOVEREIGN_BIT_MISSING) , "deny_sovereign_bit_missing" ) ;
  assert_eq!( decision_as_str(DECISION_NOT_ATTEMPTED) , "not_attempted" ) ;
}

