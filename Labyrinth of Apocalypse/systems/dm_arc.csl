module com.apocky.loa.systems.dm_arc

// § Labyrinth of Apocalypse — DM narrative-arc 5-phase Markov + tunable knobs
// ════════════════════════════════════════════════════════════════════════════
//
// § T11-W15-CSSL-DM-ARC-FULL  ‼ FOUNDATIONAL · canonical-CSSL-source
//   This file is the canonical proprietary-CSSL spec for the DM's macro-
//   pacing arc. It is sibling-module to the 4-state pacing FSM in
//   dm_director.rs. Where the director-FSM handles MICRO-pacing (CALM ↔
//   BUILDUP ↔ CLIMAX ↔ RELIEF over seconds-of-frames) · the arc state-
//   machine handles MACRO-pacing (Discovery → Tension → Crisis → Catharsis
//   → Quiet over minutes-of-play within a single scene).
//
//   § BIT-FOR-BIT PARITY w/ Rust-bootstrap-host
//     - ArcPhase discriminants 0..=4 ≡ Rust dm_arc::ArcPhase enum order
//     - ArcKnobs (md/mi/lr/mb) ≡ Rust ArcKnobs struct field-order
//     - PHASE_KNOBS table ≡ Rust verbatim (Discovery→Quiet, all 5 entries)
//     - MIN_DWELL_FRAMES / SOFT_CAP_FRAMES ≡ Rust verbatim (60fps)
//     - NUDGE_RING_LEN = 8 ≡ Rust NUDGE_RING_LEN
//     - NUDGE_THRESHOLD = 5 ≡ Rust NUDGE_THRESHOLD
//     - NudgeKind discriminants 0..=5 ≡ Rust enum order verbatim
//     - delta() table : Rest=-2 Push=+2 Caution=-1 Curiosity=+1 Aggression=+2 Yield=-2
//     - Tick-cycle order : decay → soft-cap → min-dwell → threshold-check
//     - Transition-rules : advance-cycle (Discovery→Tension→...→Quiet→Discovery)
//                          regress-cycle (Discovery clamps · Tension→Discovery · ...)
//
//   § THE STAGE-0 RUST IS THIS FILE'S COMPILED-OUTPUT-EQUIVALENT
//     When csslc grows full f32 + match coverage, this .csl source FULLY
//     REPLACES the Rust dm_arc path. The FFI contracts below are stable.
//
// § REFERENCE
//   compiler-rs/crates/loa-host/src/dm_arc.rs          § stage-0 mirror (558 LOC)
//   compiler-rs/crates/loa-host/src/dm_director.rs     § companion-FSM micro-pacing
//   Labyrinth of Apocalypse/systems/gm_dialogue.csl    § sibling : ArcPhase consumer
//   memory/feedback_loa_v13_must_be_cssl_source        ‼ .csl source canonical · NOT Rust
//   memory/feedback_take_words_literally_no_other_languages
//                                                      ‼ engine = .csl ; Rust ONLY for stage-0 substrate
//
// § AXIOMS  (inherit PRIME_DIRECTIVE + LOA_PILLARS)
//   t∞: arc = MACRO-pacing (minutes-scope)        ← micro-FSM = seconds-scope
//   t∞: 5-phase-Markov · cyclic-wrap              ← Discovery ↔ Quiet ⊃ wrap-only-via-advance
//   t∞: knobs = CHANNELS-OF-EXPRESSION ¬ CONTROL  ← player-utterance can override soft-cap
//   t∞: σ-mask isolated                           ← per-player ; ¬ multi-tenant leak
//   t∞: nudge-decay 600 frames (10s @ 60fps)      ← bounded staleness
//   t∞: 8-deep nudge-ring · sum-bounded           ← cached-sum recomputed on push/decay
//   t∞: ¬ forced-into-Crisis-against-will         ← player-asked-Rest-3× MUST regress
//   t∞: ¬ kick-out-of-rest-state                  ← Quiet · soft-cap-respects-Rest-nudges
//
// § PRIME-DIRECTIVE
//   The DM-arc is a NARRATIVE-PACING engine · not a player-coercion engine.
//   The arc-knobs SHAPE ambient-music · loot-richness · monster-density ·
//   NPC-mood · but never WEAPONIZE them against the player. The 8-deep
//   nudge-ring listens to the player's intent (Rest/Push/Caution/etc.) and
//   adjusts the macro-pacing accordingly. Player-utterance is INPUT-OF-LAST-
//   RESORT : it can override soft-cap auto-advance to honor "I want to rest".
//   Attestation : there was no hurt nor harm in the making of this, to
//   anyone/anything/anybody.

// ─────────────────────────────────────────────────────────────────────────
// § FFI surface · loa-host staticlib provides bodies (dm_arc stage-0)
// ─────────────────────────────────────────────────────────────────────────

// Lifecycle.
extern "C" fn __cssl_dm_arc_create() -> i64 ;
extern "C" fn __cssl_dm_arc_destroy(handle: i64) -> i32 ;
extern "C" fn __cssl_dm_arc_reset(handle: i64) -> i32 ;

// Per-frame tick. Returns:
//   -1 = no transition this frame
//   0..=4 = new ArcPhase id if a transition fired
extern "C" fn __cssl_dm_arc_tick(handle: i64, frame: u64) -> i32 ;

// Read state.
extern "C" fn __cssl_dm_arc_phase(handle: i64) -> u32 ;
extern "C" fn __cssl_dm_arc_frame_in_phase(handle: i64) -> u32 ;
extern "C" fn __cssl_dm_arc_nudge_sum(handle: i64) -> i32 ;       // -127..=127
extern "C" fn __cssl_dm_arc_total_transitions(handle: i64) -> u32 ;
extern "C" fn __cssl_dm_arc_last_transition_frame(handle: i64) -> u64 ;

// Read knobs (current phase). Each returns the i32-x100 of the f32 value
// (because csslc stage-0 lacks f32 ABI). Caller divides by 100 to get [-1.0, 1.0].
// § GAP · csslc-f32-arg-emit · spec-only-until-W15-1-lands
extern "C" fn __cssl_dm_arc_knob_monster_density_x100(handle: i64) -> u32 ;       // 0..=100
extern "C" fn __cssl_dm_arc_knob_ambient_music_intensity_x100(handle: i64) -> u32 ; // 0..=100
extern "C" fn __cssl_dm_arc_knob_loot_richness_x100(handle: i64) -> u32 ;          // 0..=100
extern "C" fn __cssl_dm_arc_knob_npc_mood_bias_x100(handle: i64) -> i32 ;         // -100..=100

// Push a nudge onto the 8-deep ring.
extern "C" fn __cssl_dm_arc_push_nudge(handle: i64, nudge_kind: u32, frame: u64) -> i32 ;

// Classify a free-form utterance into a NudgeKind (returns 0..=5 OR
// 255 = no-classification). Stage-1 swap : KAN-classifier vector embedding.
extern "C" fn __cssl_dm_arc_classify_nudge(text_ptr: *const u8, text_len: u32) -> u32 ;

// ─────────────────────────────────────────────────────────────────────────
// § ARC PHASE discriminants (5 · stable u32 ids)
// ─────────────────────────────────────────────────────────────────────────
// Mirrors Rust dm_arc::ArcPhase exactly · ¬ reorder.

const ARC_DISCOVERY : u32 = 0 ;
const ARC_TENSION   : u32 = 1 ;
const ARC_CRISIS    : u32 = 2 ;
const ARC_CATHARSIS : u32 = 3 ;
const ARC_QUIET     : u32 = 4 ;

const ARC_PHASE_COUNT : u32 = 5 ;
const ARC_INVALID     : u32 = 255 ;     // sentinel for unknown-phase

// ─────────────────────────────────────────────────────────────────────────
// § NUDGE-KIND discriminants (6 · stable u32 ids)
// ─────────────────────────────────────────────────────────────────────────
// Mirrors Rust dm_arc::NudgeKind exactly · ¬ reorder.

const NUDGE_REST       : u32 = 0 ;   // delta = -2  ← "rest" / "camp" / "sit"
const NUDGE_PUSH       : u32 = 1 ;   // delta = +2  ← "push" / "more" / "keep going"
const NUDGE_CAUTION    : u32 = 2 ;   // delta = -1  ← "this is too much" / "careful" / "slow"
const NUDGE_CURIOSITY  : u32 = 3 ;   // delta = +1  ← "show me" / "explore"
const NUDGE_AGGRESSION : u32 = 4 ;   // delta = +2  ← "fight" / "engage" / "attack"
const NUDGE_YIELD      : u32 = 5 ;   // delta = -2  ← "retreat" / "yield" / "flee"

const NUDGE_KIND_COUNT : u32 = 6 ;
const NUDGE_KIND_NONE  : u32 = 255 ;  // sentinel · returned by classify when no rule matched

// ─────────────────────────────────────────────────────────────────────────
// § NUDGE-RING + THRESHOLD constants
// ─────────────────────────────────────────────────────────────────────────

const NUDGE_RING_LEN  : u32 = 8 ;
const NUDGE_THRESHOLD : i32 = 5 ;
const NUDGE_DECAY_FRAMES : u32 = 600 ;   // 10s @ 60fps

// ─────────────────────────────────────────────────────────────────────────
// § DURATION GATES (frames @ 60fps · matches Rust MIN_DWELL_FRAMES + SOFT_CAP_FRAMES)
// ─────────────────────────────────────────────────────────────────────────

const MIN_DWELL_DISCOVERY : u32 = 300 ;   // 5s
const MIN_DWELL_TENSION   : u32 = 600 ;   // 10s
const MIN_DWELL_CRISIS    : u32 = 900 ;   // 15s
const MIN_DWELL_CATHARSIS : u32 = 600 ;   // 10s
const MIN_DWELL_QUIET     : u32 = 600 ;   // 10s

const SOFT_CAP_DISCOVERY : u32 = 1800 ;   // 30s
const SOFT_CAP_TENSION   : u32 = 3600 ;   // 60s
const SOFT_CAP_CRISIS    : u32 = 1800 ;   // 30s
const SOFT_CAP_CATHARSIS : u32 = 1200 ;   // 20s
const SOFT_CAP_QUIET     : u32 = 2400 ;   // 40s

// ─────────────────────────────────────────────────────────────────────────
// § PHASE-KNOBS table (x100 integer-form · matches Rust ArcKnobs verbatim)
// ─────────────────────────────────────────────────────────────────────────
//
// Each phase has 4 knobs · all stored as i32-x100 to dodge the csslc-f32 gap.
// The Rust ArcKnobs struct holds f32 in [0.0, 1.0] (or [-1.0, 1.0] for npc_mood_bias) ;
// the integer-x100 form preserves bit-for-bit equality after the trivial
// scale conversion.
//
// § GAP · csslc-static-array-of-struct · spec-only-until-W15-1-lands
//   For now the per-phase knobs are emitted via fn-returns (which csslc
//   does fold at parse-time). When static-arrays land, the table moves
//   to a single `static PHASE_KNOBS : [ArcKnobs; 5] = [...]` declaration.

// Discovery — wonder · low monsters · soft music · sparse-but-rich loot
fn knob_md_discovery() -> u32 { 10 }    // 0.10
fn knob_mi_discovery() -> u32 { 30 }    // 0.30
fn knob_lr_discovery() -> u32 { 50 }    // 0.50
fn knob_mb_discovery() -> i32 { 40 }    // +0.40

// Tension — unease · medium monsters · rising music · normal loot
fn knob_md_tension()   -> u32 { 40 }    // 0.40
fn knob_mi_tension()   -> u32 { 55 }    // 0.55
fn knob_lr_tension()   -> u32 { 40 }    // 0.40
fn knob_mb_tension()   -> i32 { 0 }     //  0.00

// Crisis — peril · high monsters · loud music · low loot
fn knob_md_crisis()    -> u32 { 85 }    // 0.85
fn knob_mi_crisis()    -> u32 { 90 }    // 0.90
fn knob_lr_crisis()    -> u32 { 20 }    // 0.20
fn knob_mb_crisis()    -> i32 { 0-50 }  // -0.50

// Catharsis — release · low monsters · soaring music · rich-burst loot
fn knob_md_catharsis() -> u32 { 20 }    // 0.20
fn knob_mi_catharsis() -> u32 { 75 }    // 0.75
fn knob_lr_catharsis() -> u32 { 85 }    // 0.85
fn knob_mb_catharsis() -> i32 { 60 }    // +0.60

// Quiet — lull · near-zero monsters · ambient music · trickle loot
fn knob_md_quiet()     -> u32 { 5 }     // 0.05
fn knob_mi_quiet()     -> u32 { 20 }    // 0.20
fn knob_lr_quiet()     -> u32 { 30 }    // 0.30
fn knob_mb_quiet()     -> i32 { 30 }    // +0.30

// ─────────────────────────────────────────────────────────────────────────
// § Helpers : phase-id → constants
// ─────────────────────────────────────────────────────────────────────────

// Min-dwell lookup (matches Rust MIN_DWELL_FRAMES[phase as usize]).
fn min_dwell_for_phase(phase: u32) -> u32 {
    if phase == ARC_DISCOVERY { return MIN_DWELL_DISCOVERY ; }
    if phase == ARC_TENSION   { return MIN_DWELL_TENSION   ; }
    if phase == ARC_CRISIS    { return MIN_DWELL_CRISIS    ; }
    if phase == ARC_CATHARSIS { return MIN_DWELL_CATHARSIS ; }
    MIN_DWELL_QUIET
}

// Soft-cap lookup (matches Rust SOFT_CAP_FRAMES[phase as usize]).
fn soft_cap_for_phase(phase: u32) -> u32 {
    if phase == ARC_DISCOVERY { return SOFT_CAP_DISCOVERY ; }
    if phase == ARC_TENSION   { return SOFT_CAP_TENSION   ; }
    if phase == ARC_CRISIS    { return SOFT_CAP_CRISIS    ; }
    if phase == ARC_CATHARSIS { return SOFT_CAP_CATHARSIS ; }
    SOFT_CAP_QUIET
}

// Knob lookup : monster-density (x100 form).
fn knob_md_for_phase(phase: u32) -> u32 {
    if phase == ARC_DISCOVERY { return knob_md_discovery() ; }
    if phase == ARC_TENSION   { return knob_md_tension()   ; }
    if phase == ARC_CRISIS    { return knob_md_crisis()    ; }
    if phase == ARC_CATHARSIS { return knob_md_catharsis() ; }
    knob_md_quiet()
}

fn knob_mi_for_phase(phase: u32) -> u32 {
    if phase == ARC_DISCOVERY { return knob_mi_discovery() ; }
    if phase == ARC_TENSION   { return knob_mi_tension()   ; }
    if phase == ARC_CRISIS    { return knob_mi_crisis()    ; }
    if phase == ARC_CATHARSIS { return knob_mi_catharsis() ; }
    knob_mi_quiet()
}

fn knob_lr_for_phase(phase: u32) -> u32 {
    if phase == ARC_DISCOVERY { return knob_lr_discovery() ; }
    if phase == ARC_TENSION   { return knob_lr_tension()   ; }
    if phase == ARC_CRISIS    { return knob_lr_crisis()    ; }
    if phase == ARC_CATHARSIS { return knob_lr_catharsis() ; }
    knob_lr_quiet()
}

fn knob_mb_for_phase(phase: u32) -> i32 {
    if phase == ARC_DISCOVERY { return knob_mb_discovery() ; }
    if phase == ARC_TENSION   { return knob_mb_tension()   ; }
    if phase == ARC_CRISIS    { return knob_mb_crisis()    ; }
    if phase == ARC_CATHARSIS { return knob_mb_catharsis() ; }
    knob_mb_quiet()
}

// ─────────────────────────────────────────────────────────────────────────
// § NudgeKind delta lookup
// ─────────────────────────────────────────────────────────────────────────
//
// Mirrors Rust NudgeKind::delta exactly. Returns the signed-i32 delta the
// nudge contributes to the cached sum. Returns 0 for unknown nudge-id.

fn nudge_delta(nudge_kind: u32) -> i32 {
    if nudge_kind == NUDGE_REST       { return 0-2 ; }
    if nudge_kind == NUDGE_PUSH       { return 2 ; }
    if nudge_kind == NUDGE_CAUTION    { return 0-1 ; }
    if nudge_kind == NUDGE_CURIOSITY  { return 1 ; }
    if nudge_kind == NUDGE_AGGRESSION { return 2 ; }
    if nudge_kind == NUDGE_YIELD      { return 0-2 ; }
    0
}

// ─────────────────────────────────────────────────────────────────────────
// § Transition rules (advance + regress)
// ─────────────────────────────────────────────────────────────────────────
//
// Mirrors Rust DmArc::advance_phase + regress_phase.

// Advance : Discovery → Tension → Crisis → Catharsis → Quiet → Discovery (wrap)
fn advance_from(phase: u32) -> u32 {
    if phase == ARC_DISCOVERY { return ARC_TENSION   ; }
    if phase == ARC_TENSION   { return ARC_CRISIS    ; }
    if phase == ARC_CRISIS    { return ARC_CATHARSIS ; }
    if phase == ARC_CATHARSIS { return ARC_QUIET     ; }
    // Quiet wraps back to Discovery.
    ARC_DISCOVERY
}

// Regress : Discovery → Discovery (clamp) ; Tension → Discovery ;
//           Crisis → Tension ; Catharsis → Crisis ; Quiet → Catharsis.
fn regress_from(phase: u32) -> u32 {
    if phase == ARC_DISCOVERY { return ARC_DISCOVERY ; }   // clamp
    if phase == ARC_TENSION   { return ARC_DISCOVERY ; }
    if phase == ARC_CRISIS    { return ARC_TENSION   ; }
    if phase == ARC_CATHARSIS { return ARC_CRISIS    ; }
    ARC_CATHARSIS    // Quiet → Catharsis
}

// ─────────────────────────────────────────────────────────────────────────
// § Public API : lifecycle
// ─────────────────────────────────────────────────────────────────────────

// Construct a new DmArc · returns opaque-handle (i64).
fn dm_arc_create() -> i64 {
    __cssl_dm_arc_create()
}

// Destroy a DmArc handle (releases host-side state).
fn dm_arc_destroy(handle: i64) -> i32 {
    __cssl_dm_arc_destroy(handle)
}

// Reset to Discovery + clear nudge-ring (called on σ-mask flip).
fn dm_arc_reset(handle: i64) -> i32 {
    __cssl_dm_arc_reset(handle)
}

// ─────────────────────────────────────────────────────────────────────────
// § Public API : per-frame tick
// ─────────────────────────────────────────────────────────────────────────
//
// The host's tick() runs the full cycle:
//   1. frame_in_phase ← saturating_add(1)
//   2. nudge-decay : nudges older than 600 frames are evicted
//   3. soft-cap check : if frame_in_phase > SOFT_CAP[phase] → advance
//   4. min-dwell check : if frame_in_phase < MIN_DWELL[phase] → return None
//   5. threshold check : sum ≥ +5 → advance ; sum ≤ -5 → regress
//   6. else → no transition this frame
//
// Returns -1 if no transition · 0..=4 if a phase-transition fired.

fn dm_arc_tick(handle: i64, frame: u64) -> i32 {
    __cssl_dm_arc_tick(handle, frame)
}

// ─────────────────────────────────────────────────────────────────────────
// § Public API : state read
// ─────────────────────────────────────────────────────────────────────────

fn dm_arc_phase(handle: i64) -> u32 {
    __cssl_dm_arc_phase(handle)
}

fn dm_arc_frame_in_phase(handle: i64) -> u32 {
    __cssl_dm_arc_frame_in_phase(handle)
}

fn dm_arc_nudge_sum(handle: i64) -> i32 {
    __cssl_dm_arc_nudge_sum(handle)
}

fn dm_arc_total_transitions(handle: i64) -> u32 {
    __cssl_dm_arc_total_transitions(handle)
}

fn dm_arc_last_transition_frame(handle: i64) -> u64 {
    __cssl_dm_arc_last_transition_frame(handle)
}

// ─────────────────────────────────────────────────────────────────────────
// § Public API : nudge push + classify
// ─────────────────────────────────────────────────────────────────────────

fn dm_arc_push_nudge(handle: i64, nudge_kind: u32, frame: u64) -> i32 {
    if nudge_kind >= NUDGE_KIND_COUNT {
        return 0-1 ;
    }
    __cssl_dm_arc_push_nudge(handle, nudge_kind, frame)
}

// Classify a player utterance into a NudgeKind (0..=5 · or 255 = no-rule).
// Mirrors Rust dm_arc::classify_nudge keyword-rule order verbatim.
//
// Stage-0 keyword-classifier (case-insensitive · order matters · first-match-wins):
//   1. contains "rest" | "camp" | "sit"        → Rest        (-2)
//   2. contains "retreat" | "yield" | "flee"   → Yield       (-2)
//   3. contains "fight" | "engage" | "attack"  → Aggression  (+2)
//   4. contains "push" | "more" | "keep going" → Push        (+2)
//   5. contains "caution" | "careful" | "slow" → Caution     (-1)
//   6. contains "curious" | "explore" | "show me" → Curiosity (+1)
//   else → NUDGE_KIND_NONE
//
// Stage-1 swap : KAN-classifier vector-embedding (cssl-kan-runtime).

fn dm_arc_classify_nudge(text_ptr: *const u8, text_len: u32) -> u32 {
    __cssl_dm_arc_classify_nudge(text_ptr, text_len)
}

// One-shot helper : classify-then-push. Returns the classified-kind
// (0..=5) or NUDGE_KIND_NONE if no rule matched (no push happens).
fn dm_arc_classify_and_push(handle: i64, text_ptr: *const u8, text_len: u32, frame: u64) -> u32 {
    let kind : u32 = dm_arc_classify_nudge(text_ptr, text_len) ;
    if kind == NUDGE_KIND_NONE {
        return NUDGE_KIND_NONE ;
    }
    let _ = dm_arc_push_nudge(handle, kind, frame) ;
    kind
}

