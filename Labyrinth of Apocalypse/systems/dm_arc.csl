// Test : phase-knobs (loot-richness) match Rust verbatim.
fn test_phase_knobs_lr_match_rust() -> i32 {
    if knob_lr_for_phase(ARC_DISCOVERY) != 50 { return 1 ; }
    if knob_lr_for_phase(ARC_TENSION)   != 40 { return 2 ; }
    if knob_lr_for_phase(ARC_CRISIS)    != 20 { return 3 ; }
    if knob_lr_for_phase(ARC_CATHARSIS) != 85 { return 4 ; }
    if knob_lr_for_phase(ARC_QUIET)     != 30 { return 5 ; }
