// Test : phase-knobs (npc-mood-bias) match Rust verbatim · signed.
fn test_phase_knobs_mb_match_rust() -> i32 {
    if knob_mb_for_phase(ARC_DISCOVERY) != 40    { return 1 ; }
    if knob_mb_for_phase(ARC_TENSION)   != 0     { return 2 ; }
    if knob_mb_for_phase(ARC_CRISIS)    != (0-50) { return 3 ; }
    if knob_mb_for_phase(ARC_CATHARSIS) != 60    { return 4 ; }
    if knob_mb_for_phase(ARC_QUIET)     != 30    { return 5 ; }
    0
}

// Test : per-phase knob-table is non-overlapping (each phase has distinct
// 4-tuple) — sanity-check matches Rust arc_knobs_per_phase_distinct.
fn test_phase_knobs_distinct_pairwise() -> i32 {
    // Discovery vs Tension
    if knob_md_for_phase(ARC_DISCOVERY) == knob_md_for_phase(ARC_TENSION) {
        if knob_mi_for_phase(ARC_DISCOVERY) == knob_mi_for_phase(ARC_TENSION) {
            return 1 ;
        }
    }
    // Crisis vs Catharsis
    if knob_md_for_phase(ARC_CRISIS) == knob_md_for_phase(ARC_CATHARSIS) {
        if knob_mb_for_phase(ARC_CRISIS) == knob_mb_for_phase(ARC_CATHARSIS) {
            return 2 ;
        }
    }
    // Quiet vs Tension
    if knob_md_for_phase(ARC_QUIET) == knob_md_for_phase(ARC_TENSION) {
        return 3 ;
    }
    0
}

// Test : phase-knob ranges match Rust arc_knobs_in_canonical_ranges.
fn test_phase_knobs_in_canonical_ranges() -> i32 {
    let mut p : u32 = 0 ;
    while p < ARC_PHASE_COUNT {
        let md : u32 = knob_md_for_phase(p) ;
        let mi : u32 = knob_mi_for_phase(p) ;
        let lr : u32 = knob_lr_for_phase(p) ;
        let mb : i32 = knob_mb_for_phase(p) ;
        // 0..=100 for all unsigned knobs
        if md > 100 { return 1 ; }
        if mi > 100 { return 2 ; }
        if lr > 100 { return 3 ; }
        // -100..=100 for signed npc_mood_bias
        if mb < (0-100) { return 4 ; }
        if mb > 100     { return 5 ; }
        p = p + 1 ;
    }
    0
}

// Test : the 5 min-dwell + 5 soft-cap values are pairwise <= each other
// (soft-cap >= min-dwell for every phase · matches Rust invariant).
fn test_soft_cap_geq_min_dwell() -> i32 {
    let mut p : u32 = 0 ;
    while p < ARC_PHASE_COUNT {
        if soft_cap_for_phase(p) < min_dwell_for_phase(p) {
            return 1 ;
        }
        p = p + 1 ;
    }
    0
}

// Test : nudge_kind_none sentinel != any real nudge-kind discriminant.
fn test_nudge_none_sentinel_distinct() -> i32 {
    if NUDGE_KIND_NONE == NUDGE_REST       { return 1 ; }
    if NUDGE_KIND_NONE == NUDGE_PUSH       { return 2 ; }
    if NUDGE_KIND_NONE == NUDGE_CAUTION    { return 3 ; }
    if NUDGE_KIND_NONE == NUDGE_CURIOSITY  { return 4 ; }
    if NUDGE_KIND_NONE == NUDGE_AGGRESSION { return 5 ; }
    if NUDGE_KIND_NONE == NUDGE_YIELD      { return 6 ; }
    if NUDGE_KIND_NONE != 255              { return 7 ; }
    0
}

// ─────────────────────────────────────────────────────────────────────────
// § Sovereignty-attestation gate
// ─────────────────────────────────────────────────────────────────────────
//
// Rule : if the player has pushed Rest 3+ times within the decay-window,
// the arc MUST regress (or stay-Quiet) regardless of soft-cap. The host's
// __cssl_dm_arc_tick honors this · the predicate below is the in-CSSL
// auditable form for any external sovereignty-checker.
//
// "Stay-rest dominance" predicate · matches "¬ kick-out-of-rest-state" axiom.

extern "C" fn __cssl_dm_arc_count_recent_rests(handle: i64) -> u32 ;

fn must_honor_rest(handle: i64) -> u32 {
    let count : u32 = __cssl_dm_arc_count_recent_rests(handle) ;
    if count >= 3 { 1 } else { 0 }
}

// ─────────────────────────────────────────────────────────────────────────
// § GAP · csslc-feature-coverage roadmap
// ─────────────────────────────────────────────────────────────────────────
//
// The function bodies above declare the canonical surface but csslc
// stage-0 cannot yet emit:
//
//   * f32 ABI · the ArcKnobs table is currently exposed as i32-x100 · this
//     is bit-equivalent (caller divides by 100.0 for [0.0, 1.0] / [-1.0, 1.0])
//     but the natural Rust f32-form awaits W15-1.
//   * struct-types with mixed-typed fields (ArcKnobs has 4 f32) — currently
//     decomposed into 4 fn-returns. When csslc lands struct-emit + f32, the
//     ArcKnobs struct can be exposed as a single value-object.
//   * static [T; N] arrays · we use match-shaped fn-returns as substitute.
//   * #[test] attribute for the harness.
//   * match statement for the nudge-classifier (we use if-chains instead).
//   * for i in 0..n range-loop (we use while + manual increment).
//
// § REMEDIATION ROADMAP (W15-1 · csslc-advance · ~600 LOC)
//   1. csslc · f32 ABI emit + arithmetic
//   2. csslc · struct-types with f32 fields (ArcKnobs becomes native)
//   3. csslc · static [T; N] table-emission
//   4. csslc · #[test] attr → t11_w11_parser_advancements style harness
//   5. csslc · match statement lowering
//   6. csslc · for-i-in-range range-syntax
//   7. loa-host · delete dm_arc.rs once dm_arc.csl is live
//
// Until the roadmap lands, this file serves as :
