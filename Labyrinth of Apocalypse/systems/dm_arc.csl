    __cssl_dm_arc_knob_npc_mood_bias_x100(handle)
}

// ─────────────────────────────────────────────────────────────────────────
// § INLINE TESTS (bit-for-bit-Rust-parity gates)
// ─────────────────────────────────────────────────────────────────────────
//
// § GAP · csslc-#[test]-attr · spec-only-until-W15-1-lands
//   Until the test attribute is wired, the `test_*` fns below are plain-fn
//   bodies that return 0=PASS · non-zero=FAIL.

// Test : phase discriminants are stable + match Rust enum order.
fn test_phase_discriminants_match_rust() -> i32 {
    if ARC_DISCOVERY != 0 { return 1 ; }
    if ARC_TENSION   != 1 { return 2 ; }
    if ARC_CRISIS    != 2 { return 3 ; }
    if ARC_CATHARSIS != 3 { return 4 ; }
    if ARC_QUIET     != 4 { return 5 ; }
    if ARC_PHASE_COUNT != 5 { return 6 ; }
    0
}

// Test : nudge-kind discriminants are stable + match Rust enum order.
fn test_nudge_kind_discriminants_match_rust() -> i32 {
    if NUDGE_REST       != 0 { return 1 ; }
    if NUDGE_PUSH       != 1 { return 2 ; }
    if NUDGE_CAUTION    != 2 { return 3 ; }
    if NUDGE_CURIOSITY  != 3 { return 4 ; }
    if NUDGE_AGGRESSION != 4 { return 5 ; }
    if NUDGE_YIELD      != 5 { return 6 ; }
    if NUDGE_KIND_COUNT != 6 { return 7 ; }
    0
}

// Test : nudge-delta values match Rust NudgeKind::delta.
fn test_nudge_delta_values() -> i32 {
    if nudge_delta(NUDGE_REST)       != (0-2) { return 1 ; }
    if nudge_delta(NUDGE_PUSH)       != 2     { return 2 ; }
    if nudge_delta(NUDGE_CAUTION)    != (0-1) { return 3 ; }
    if nudge_delta(NUDGE_CURIOSITY)  != 1     { return 4 ; }
    if nudge_delta(NUDGE_AGGRESSION) != 2     { return 5 ; }
    if nudge_delta(NUDGE_YIELD)      != (0-2) { return 6 ; }
    if nudge_delta(99)               != 0     { return 7 ; }   // unknown → 0
    0
}

// Test : advance-cycle matches Rust verbatim.
fn test_advance_cycle() -> i32 {
    if advance_from(ARC_DISCOVERY) != ARC_TENSION   { return 1 ; }
    if advance_from(ARC_TENSION)   != ARC_CRISIS    { return 2 ; }
    if advance_from(ARC_CRISIS)    != ARC_CATHARSIS { return 3 ; }
    if advance_from(ARC_CATHARSIS) != ARC_QUIET     { return 4 ; }
    if advance_from(ARC_QUIET)     != ARC_DISCOVERY { return 5 ; }   // wrap
    0
}

// Test : regress-cycle matches Rust verbatim · Discovery clamps.
fn test_regress_cycle() -> i32 {
    if regress_from(ARC_DISCOVERY) != ARC_DISCOVERY { return 1 ; }   // clamp
    if regress_from(ARC_TENSION)   != ARC_DISCOVERY { return 2 ; }
    if regress_from(ARC_CRISIS)    != ARC_TENSION   { return 3 ; }
    if regress_from(ARC_CATHARSIS) != ARC_CRISIS    { return 4 ; }
    if regress_from(ARC_QUIET)     != ARC_CATHARSIS { return 5 ; }
    0
}

// Test : MIN_DWELL_FRAMES per-phase match Rust verbatim.
fn test_min_dwell_per_phase() -> i32 {
    if min_dwell_for_phase(ARC_DISCOVERY) != 300 { return 1 ; }
    if min_dwell_for_phase(ARC_TENSION)   != 600 { return 2 ; }
    if min_dwell_for_phase(ARC_CRISIS)    != 900 { return 3 ; }
    if min_dwell_for_phase(ARC_CATHARSIS) != 600 { return 4 ; }
    if min_dwell_for_phase(ARC_QUIET)     != 600 { return 5 ; }
    0
}

// Test : SOFT_CAP_FRAMES per-phase match Rust verbatim.
fn test_soft_cap_per_phase() -> i32 {
    if soft_cap_for_phase(ARC_DISCOVERY) != 1800 { return 1 ; }
    if soft_cap_for_phase(ARC_TENSION)   != 3600 { return 2 ; }
    if soft_cap_for_phase(ARC_CRISIS)    != 1800 { return 3 ; }
    if soft_cap_for_phase(ARC_CATHARSIS) != 1200 { return 4 ; }
    if soft_cap_for_phase(ARC_QUIET)     != 2400 { return 5 ; }
    0
}

// Test : NUDGE_THRESHOLD = 5 (matches Rust).
fn test_nudge_threshold_is_5() -> i32 {
    if NUDGE_THRESHOLD != 5 { return 1 ; }
    0
}

// Test : NUDGE_RING_LEN = 8 (matches Rust).
fn test_nudge_ring_len_is_8() -> i32 {
    if NUDGE_RING_LEN != 8 { return 1 ; }
    0
}

// Test : nudge-decay window = 600 frames (10s @ 60fps).
fn test_nudge_decay_window() -> i32 {
    if NUDGE_DECAY_FRAMES != 600 { return 1 ; }
    0
}

// Test : phase-knobs (monster-density) match Rust PHASE_KNOBS table verbatim.
fn test_phase_knobs_md_match_rust() -> i32 {
    if knob_md_for_phase(ARC_DISCOVERY) != 10 { return 1 ; }
    if knob_md_for_phase(ARC_TENSION)   != 40 { return 2 ; }
    if knob_md_for_phase(ARC_CRISIS)    != 85 { return 3 ; }
    if knob_md_for_phase(ARC_CATHARSIS) != 20 { return 4 ; }
    if knob_md_for_phase(ARC_QUIET)     != 5  { return 5 ; }
    0
}

// Test : phase-knobs (ambient-music) match Rust verbatim.
fn test_phase_knobs_mi_match_rust() -> i32 {
