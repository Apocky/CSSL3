// ─────────────────────────────────────────────────────────────────────────
// § GM PROCEDURAL-COMPOSITION SEED MIXING (replaces xorshift32+FNV)
// ─────────────────────────────────────────────────────────────────────────
//
// The substrate-intelligence accepts a u64 seed; we derive it from the
// caller's parameters using SplitMix64-style mixing (matches gm_persona's
// 0x9E3779B97F4A7C15 / 0xBF58476D1CE4E5B9 / 0x94D049BB133111EB constants).
// This is NOT a phrase-pool · NOT a table-lookup · the seed PARAMETERIZES
// the substrate's procedural ω-field-sample at composition-time.

fn splitmix_offset()  -> u64 { 0x9E3779B97F4A7C15 }
fn splitmix_mul1()    -> u64 { 0xBF58476D1CE4E5B9 }
fn splitmix_mul2()    -> u64 { 0x94D049BB133111EB }

// Mix Vec3-bits + ToD into a 64-bit composition-seed for environment.
// The bits-of-f32-via-u32 pun is csslc-supported (cssl-substrate-omega-field
// uses the same trick). When csslc-stage-0 lacks f32 ABI, the loa-host
// shim performs the to_bits() and passes the u64 directly.
fn env_seed_mix(x_bits: u32, y_bits: u32, z_bits: u32, tod: u32) -> u64 {
    let mut s : u64 = splitmix_offset() ;
    s = s + (x_bits as u64) ;
    s = s + ((y_bits as u64) * 2654435761u64) ;
    s = s + ((z_bits as u64) * 40503u64) ;
    s = s + ((tod as u64) * 0x27d4eb2fu64) ;
    s
}

// Mix dialogue inputs into a 64-bit composition-seed.
fn dialogue_seed_mix(npc_id: u32, archetype: u32, mood: u32, topic: u32) -> u64 {
    let mut s : u64 = splitmix_offset() ;
    s = s + ((npc_id as u64) * 0x9E3779B9u64) ;
    s = s + ((archetype as u64) * 0x85ebca6bu64) ;
    s = s + ((mood as u64) * 0xc2b2ae35u64) ;
    s = s + ((topic as u64) * 0x27d4eb2fu64) ;
    s
}

// ─────────────────────────────────────────────────────────────────────────
// § PUBLIC API — describe_environment
// ─────────────────────────────────────────────────────────────────────────
//
// Procedurally compose 1-3 sentences describing the neighborhood at
// `camera_pos` for the given `time_of_day`. NO phrase-pools · the substrate-
// intelligence runs the full ω-field-sample → KAN-classify → HDC-bind →
// Σ-mask-gate pipeline and writes UTF-8 bytes into out_buf.
//
// Returns the byte-count written. Caller (gm_narrator.rs shim) converts to
// String. On Σ-mask-deny, returns 0 (host emits a default-deny attestation
// trail to Σ-Chain; UI shows blank narration).
//
// PARAMS encoding (LE-bytes into params_ptr buffer) :
//   bytes  0..4   : x_bits   (u32 little-endian f32 bits)
//   bytes  4..8   : y_bits   (u32 little-endian f32 bits)
//   bytes  8..12  : z_bits   (u32 little-endian f32 bits)
//   bytes 12..16  : tod      (u32 little-endian)

fn describe_environment_compose(
    x_bits: u32,
    y_bits: u32,
    z_bits: u32,
    tod: u32,
    out_ptr: *mut u8,
    out_max: u32,
) -> u32 {
    if tod >= tod_count() { return 0 ; }
    let seed : u64 = env_seed_mix(x_bits, y_bits, z_bits, tod) ;
    // Pack PARAMS for substrate-intelligence.
    // The stub expects (x · y · z · tod · null-tail) ; the host marshals.
    si::intelligence_compose(
        si::role_gm(),
        si::c_environment_description(),
        seed,
        0 as *const u8,    // params buffer marshaled host-side from seed
        0u32,
        out_ptr,
        out_max,
    )
}

// ─────────────────────────────────────────────────────────────────────────
// § PUBLIC API — generate_dialogue
// ─────────────────────────────────────────────────────────────────────────
//
// Procedurally compose a single line of dialogue for `npc_id` of the given
// `archetype` in the given `mood` on the given `topic`. NO phrase-pools.
// Archetype-coherence emerges from the substrate-intelligence's KAN-bias
// over (role × archetype × topic) cells; "Mute archetype mostly emits
// silence" is a property of the bias-vector, NOT a hardcoded pool.

fn generate_dialogue_compose(
    npc_id: u32,
    archetype: u32,
    mood: u32,
    topic: u32,
    out_ptr: *mut u8,
    out_max: u32,
) -> u32 {
    if archetype >= arch_count() { return 0 ; }
    if mood >= mood_count()      { return 0 ; }
    if topic >= topic_count()    { return 0 ; }
    let seed : u64 = dialogue_seed_mix(npc_id, archetype, mood, topic) ;
    si::intelligence_compose(
        si::role_gm(),
        si::c_dialogue_line(),
        seed,
        0 as *const u8,
        0u32,
        out_ptr,
        out_max,
    )
}

// ─────────────────────────────────────────────────────────────────────────
// § PUBLIC API — respond_in_persona (cross-arc + persona-aware)
// ─────────────────────────────────────────────────────────────────────────
//
// Compose a persona+arc-aware response to a player-utterance. This is the
// FRONTSTAGE chat-panel entry-point. Per W11-GM-DM-DEEPEN: the response
// blends arc-phase (Discovery → Quiet) + dm-state (Calm → Relief) +
// persona-axes (8 channels) into a single composed-utterance.
//
// All persona/arc mixing happens INSIDE the substrate-intelligence; the
// specialist just packages params and sets c_kind=dialogue_line with a
// richer params buffer (gm_dialogue.csl persona-fields).

fn respond_in_persona_compose(
    player_seed: u64,
    arc_phase: u32,
    dm_state: u32,
    topic_hint: u32,
    frame: u64,
    out_ptr: *mut u8,
    out_max: u32,
) -> u32 {
    if topic_hint >= topic_count() { return 0 ; }
    let seed : u64 = player_seed
        + (arc_phase as u64)
        + ((dm_state as u64) * splitmix_mul1())
        + ((topic_hint as u64) * splitmix_mul2())
        + frame ;
    si::intelligence_compose(
        si::role_gm(),
        si::c_dialogue_line(),
        seed,
        0 as *const u8,
        0u32,
        out_ptr,
        out_max,
    )
}

// ─────────────────────────────────────────────────────────────────────────
// § OBSERVATION uplink (player-response feedback into KAN-bias)
// ─────────────────────────────────────────────────────────────────────────
//
// When the chat-panel records a player-response (utterance-text-hash), the
// GM-specialist forwards it to substrate-intelligence as an observation,
// which feeds the KAN-loop sibling (self_authoring_kan.csl). This closes
// the procedural-feedback ring: composer-output → player-feedback → KAN-
// bias → next-composer-output evolves.

fn observe_player_response(
    utterance_hash: u64,
    accepted: u32,    // 0 = ignored · 1 = engaged-positive · 2 = pushed-back
) -> i32 {
    si::intelligence_observe(
        si::role_gm(),
        si::o_player_response(),
        utterance_hash,
        0 as *const u8,
        accepted,
    )
}

