#[test]
fn t01_archetype_discriminants_match_rust_verbatim() -> i32 {
    if arch_sage()        !=  0 { return 1 ; }
    if arch_trickster()   !=  1 { return 2 ; }
    if arch_warrior()     !=  2 { return 3 ; }
    if arch_healer()      !=  3 { return 4 ; }
    if arch_merchant()    !=  4 { return 5 ; }
    if arch_hermit()      !=  5 { return 6 ; }
    if arch_apprentice()  !=  6 { return 7 ; }
    if arch_elder()       !=  7 { return 8 ; }
    if arch_scout()       !=  8 { return 9 ; }
    if arch_bard()        !=  9 { return 10 ; }
    if arch_smith()       != 10 { return 11 ; }
    if arch_witness()     != 11 { return 12 ; }
    if arch_wanderer()    != 12 { return 13 ; }
    if arch_apocalyptic() != 13 { return 14 ; }
    if arch_liminal()     != 14 { return 15 ; }
    if arch_mute()        != 15 { return 16 ; }
    if arch_count()       != 16 { return 17 ; }
    0
}

#[test]
fn t02_phrase_topic_discriminants_match_rust_verbatim() -> i32 {
    if topic_lore_history() !=  0 { return 1 ; }
    if topic_environment()  !=  1 { return 2 ; }
    if topic_weather()      !=  2 { return 3 ; }
    if topic_creature()     !=  3 { return 4 ; }
    if topic_architecture() !=  4 { return 5 ; }
    if topic_memory()       !=  5 { return 6 ; }
    if topic_prophecy()     !=  6 { return 7 ; }
    if topic_warning()      !=  7 { return 8 ; }
    if topic_greeting()     !=  8 { return 9 ; }
    if topic_farewell()     !=  9 { return 10 ; }
    if topic_silence()      != 31 { return 11 ; }
    if topic_count()        != 32 { return 12 ; }
    0
}

#[test]
fn t03_seed_mixing_is_deterministic() -> i32 {
    let s1 : u64 = env_seed_mix(0, 0, 0, 0) ;
    let s2 : u64 = env_seed_mix(0, 0, 0, 0) ;
    if s1 != s2 { return 1 ; }
    let s3 : u64 = env_seed_mix(1, 0, 0, 0) ;
    if s1 == s3 { return 2 ; }
    let d1 : u64 = dialogue_seed_mix(0, 0, 0, 0) ;
    let d2 : u64 = dialogue_seed_mix(0, 0, 0, 0) ;
    if d1 != d2 { return 3 ; }
    let d3 : u64 = dialogue_seed_mix(0, 1, 0, 0) ;
    if d1 == d3 { return 4 ; }
    0
}

#[test]
fn t04_tod_and_mood_discriminants_distinct() -> i32 {
    if tod_dawn()  != 0 { return 1 ; }
    if tod_day()   != 1 { return 2 ; }
    if tod_dusk()  != 2 { return 3 ; }
    if tod_night() != 3 { return 4 ; }
    if tod_count() != 4 { return 5 ; }
    if mood_calm()      != 0 { return 6 ; }
    if mood_defiant()   != 7 { return 7 ; }
    if mood_count()     != 8 { return 8 ; }
    0
}

#[test]
fn t05_splitmix_constants_match_gm_persona_verbatim() -> i32 {
    if splitmix_offset() != 0x9E3779B97F4A7C15 { return 1 ; }
    if splitmix_mul1()   != 0xBF58476D1CE4E5B9 { return 2 ; }
    if splitmix_mul2()   != 0x94D049BB133111EB { return 3 ; }
    0
}

