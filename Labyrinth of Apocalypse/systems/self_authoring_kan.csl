# § FFI BOUNDARY (declarations · CONSUMED by host-side cssl-self-authoring-kan)
# ──────────────────────────────────────────────────────────────────────────

extern "C" fn sak_loop_new( created_at_frame : u32 , created_at_seconds : u64 , k_anon_floor : u32 ) -> usize ;
extern "C" fn sak_loop_drop( handle : usize ) -> i32 ;
extern "C" fn sak_loop_ingest_signal( handle : usize , template_id : u32 , archetype_id : u8 , signal_tag : u8 , signal_payload : u16 , player_handle : u32 , frame_offset : u16 ) -> i32 ;
extern "C" fn sak_loop_tick( handle : usize , dt_seconds : f64 , now_seconds : u64 ) -> u32 ;
extern "C" fn sak_loop_sovereign_revoke( handle : usize , player_handle : u32 , now_seconds : u64 ) -> u32 ;
extern "C" fn sak_loop_rollback_to_anchor( handle : usize , anchor_seq : u64 , now_seconds : u64 ) -> i32 ;
extern "C" fn sak_inspector_read_cell( handle : usize , sigma_mask_ptr : *const u8 , sigma_cap_ptr : *const u8 , sigma_cap_len : u32 , template_id : u32 , archetype_id : u8 , now_seconds : u64 , issuing_pk_ptr : *const u8 , out_status : *mut i32 , out_q14_bias : *mut i16 ) -> i32 ;
extern "C" fn sak_loop_drain_stats( handle : usize , out_tick_count : *mut u64 , out_updates : *mut u64 , out_skipped : *mut u64 , out_rejected : *mut u64 , out_anchors : *mut u64 ) -> i32 ;

# §§ Integration-points · sibling-W12 agents
#  W12-2  training-pair-log   : SANDBOX_PASS / SANDBOX_FAIL on compile-events
#  W12-7  rating-pipeline     : RATING_5_STAR · RATING_1_STAR · PLAYER_{LIKE,DISLIKE}(weight_q14)
#  W12-10 playtest-scorer     : GM_ACCEPT(score_q14) · GM_REJECT(reason_code) · PLAYTEST_PASS(score_q14)
#  procgen-template-selector  : sak_inspector_read_cell → Q14 bias adjusts selection-RNG-priority

# ──────────────────────────────────────────────────────────────────────────
# § Anti-poisoning attestation
# ──────────────────────────────────────────────────────────────────────────
#   1. Reservoir-sampling : uniform-random FIFO-eviction · ¬ bursty-domination
#   2. K-anon-floor       : ≥ 10 distinct fingerprints required-per-cell
#   3. Per-cell-rate-limit: ≤ 64 contributions per (player · template · archetype)
#   4. Sovereign-revoke   : cascading recompute-from-remaining
#   5. Σ-mask inspector   : default-deny per-row · admin-cap-required
#   6. Σ-Chain-anchor     : every 1024 updates · BLAKE3-128 hash · rollback-safe
#   7. Q14 saturating-clamp : ¬ runaway-amplification

# ──────────────────────────────────────────────────────────────────────────
# § INLINE TESTS (≥ 12)
# ──────────────────────────────────────────────────────────────────────────

#[test] fn t01_signal_tag_distinct_for_each_variant ( ) {
  let all = [
    SAK_SIG_SANDBOX_PASS , SAK_SIG_SANDBOX_FAIL , SAK_SIG_GM_ACCEPT , SAK_SIG_GM_REJECT ,
    SAK_SIG_PLAYER_LIKE  , SAK_SIG_PLAYER_DISLIKE , SAK_SIG_REMIX_FORKED ,
    SAK_SIG_RATING_5_STAR , SAK_SIG_RATING_1_STAR , SAK_SIG_PLAYTEST_PASS
  ] ;
  let mut tags = all ;
  tags 'p sort-unstable ;
  let prev_len = tags 'p len ;
  tags 'p dedup ;
  assert_eq!( tags 'p len , prev_len ) ;
  assert_eq!( tags 'p len , SAK_SIG_COUNT as u32 ) ;
}

#[test] fn t02_q14_delta_sign_matches_polarity ( ) {
  assert!( signal_to_q14_delta(SAK_SIG_SANDBOX_PASS , 0) > 0 ) ;
  assert!( signal_to_q14_delta(SAK_SIG_SANDBOX_FAIL , 0) < 0 ) ;
  assert!( signal_to_q14_delta(SAK_SIG_GM_ACCEPT , 8192) > 0 ) ;
  assert!( signal_to_q14_delta(SAK_SIG_GM_REJECT , 7) < 0 ) ;
  assert!( signal_to_q14_delta(SAK_SIG_REMIX_FORKED , 0) > 0 ) ;
  assert!( signal_to_q14_delta(SAK_SIG_RATING_5_STAR , 0) > 0 ) ;
  assert!( signal_to_q14_delta(SAK_SIG_RATING_1_STAR , 0) < 0 ) ;
}

#[test] fn t03_q14_delta_clamped_within_range ( ) {
  for tag in [ SAK_SIG_SANDBOX_PASS , SAK_SIG_SANDBOX_FAIL , SAK_SIG_GM_ACCEPT , SAK_SIG_PLAYER_DISLIKE , SAK_SIG_PLAYTEST_PASS ] {
    let d = signal_to_q14_delta(tag , 0xFFFF) ;
    assert!( d ≥ SAK_BIAS_Q14_MIN ∧ d ≤ SAK_BIAS_Q14_MAX ) ;
  }
}

#[test] fn t04_signal_names_unique_well_formed ( ) {
  let all = [ SAK_SIG_SANDBOX_PASS , SAK_SIG_SANDBOX_FAIL , SAK_SIG_GM_ACCEPT , SAK_SIG_GM_REJECT ,
              SAK_SIG_PLAYER_LIKE , SAK_SIG_PLAYER_DISLIKE , SAK_SIG_REMIX_FORKED ,
              SAK_SIG_RATING_5_STAR , SAK_SIG_RATING_1_STAR , SAK_SIG_PLAYTEST_PASS ] ;
  let mut names = all 'p map (fn(t) -> Str { signal_name(t) }) ;
  names 'p sort-unstable ;
  let prev = names 'p len ;
  names 'p dedup ;
  assert_eq!( names 'p len , prev ) ;
  for n in names { assert!( n 'p contains "." ) }
}

#[test] fn t05_archetype_canonical_eight ( ) {
  for a in 0u8..SAK_ARCH_COUNT { assert!( archetype_is_canonical(a) ) }
  assert!( ¬ archetype_is_canonical(8u8) ) ;
  assert_eq!( archetype_name(SAK_ARCH_WARRIOR) , "warrior" ) ;
  assert_eq!( archetype_name(SAK_ARCH_ENGINEER) , "engineer" ) ;
  assert_eq!( archetype_name(255u8) , "unknown" ) ;
}

#[test] fn t06_reservoir_default_capacity_and_kanon ( ) {
  let r = reservoir_new(0u32 , 0u32) ;                        # 0 → use default
  assert_eq!( r.k_anon_floor , SAK_K_ANON_FLOOR_DEFAULT ) ;
  assert_eq!( r.count , 0u32 ) ;
  let r2 = reservoir_new(0u32 , 1u32) ;                       # below MIN → MIN
  assert_eq!( r2.k_anon_floor , SAK_K_ANON_FLOOR_MIN ) ;
}

#[test] fn t07_reservoir_ingest_bad_archetype_rejected ( ) {
  let r = reservoir_new(0u32 , 0u32) ;
  let rec = QualitySignalRecord {
    template_id: 1u32 , archetype_id: 99u8 , signal_tag: SAK_SIG_SANDBOX_PASS ,
    signal_payload: 0u16 , player_handle: 1u32 , frame_offset: 0u16
  } ;
  assert_eq!( reservoir_ingest(r , rec) , SAK_OUT_INGEST_BAD_ARCHETYPE ) ;
}

#[test] fn t08_reservoir_ingest_revoked_player_rejected ( ) {
  let r = reservoir_new(0u32 , 0u32) ;
  let _ = reservoir_sovereign_revoke(r , 42u32) ;
  let rec = QualitySignalRecord {
    template_id: 1u32 , archetype_id: 0u8 , signal_tag: SAK_SIG_SANDBOX_PASS ,
    signal_payload: 0u16 , player_handle: 42u32 , frame_offset: 0u16
  } ;
  assert_eq!( reservoir_ingest(r , rec) , SAK_OUT_INGEST_REVOKED ) ;
}

#[test] fn t09_reservoir_per_cell_rate_limit ( ) {
  let r = reservoir_new(0u32 , 0u32) ;
  for i in 0u32..SAK_PER_CELL_RATE_LIMIT {
    let rec = QualitySignalRecord {
      template_id: 1u32 , archetype_id: 0u8 , signal_tag: SAK_SIG_SANDBOX_PASS ,
      signal_payload: 0u16 , player_handle: 7u32 , frame_offset: ⟦i as u16⟧
    } ;
    assert_eq!( reservoir_ingest(r , rec) , SAK_OUT_OK ) ;
  }
  # Next ingest from same (player · cell) → rate-limit
  let extra = QualitySignalRecord {
    template_id: 1u32 , archetype_id: 0u8 , signal_tag: SAK_SIG_SANDBOX_PASS ,
    signal_payload: 0u16 , player_handle: 7u32 , frame_offset: 999u16
  } ;
  assert_eq!( reservoir_ingest(r , extra) , SAK_OUT_INGEST_RATE_LIMIT ) ;
}

#[test] fn t10_kanon_floor_blocks_underpopulated_cells ( ) {
  let r = reservoir_new(0u32 , 0u32) ;                        # k_anon = 10
  # 9 distinct players → insufficient
  for p in 1u32..10u32 {
    let rec = QualitySignalRecord {
      template_id: 1u32 , archetype_id: 0u8 , signal_tag: SAK_SIG_SANDBOX_PASS ,
      signal_payload: 0u16 , player_handle: p , frame_offset: 0u16
    } ;
    let _ = reservoir_ingest(r , rec) ;
  }
  assert!( ¬ reservoir_cell_meets_kanon(r , 1u32 , 0u8) ) ;
  # 10th distinct → meets floor
  let rec10 = QualitySignalRecord {
    template_id: 1u32 , archetype_id: 0u8 , signal_tag: SAK_SIG_SANDBOX_PASS ,
    signal_payload: 0u16 , player_handle: 10u32 , frame_offset: 0u16
  } ;
  let _ = reservoir_ingest(r , rec10) ;
  assert!( reservoir_cell_meets_kanon(r , 1u32 , 0u8) ) ;
}

#[test] fn t11_template_bias_map_saturating_clamp ( ) {
  let m = template_bias_map_new() ;
  let big = KanBiasUpdate { template_id: 1u32 , archetype_id: 0u8 , delta_q14: SAK_BIAS_Q14_MAX } ;
  assert_eq!( template_bias_map_apply_update(m , big) , SAK_OUT_OK ) ;
  let again = KanBiasUpdate { template_id: 1u32 , archetype_id: 0u8 , delta_q14: 1000i16 } ;
  let _ = template_bias_map_apply_update(m , again) ;
  let p = priority_shift(m , 1u32 , 0u8) ;
  assert!( p ≤ SAK_BIAS_Q14_MAX ) ;       # saturating-clamp · ¬ overflow
}

#[test] fn t12_template_bias_map_default_zero ( ) {
  let m = template_bias_map_new() ;
  assert_eq!( priority_shift(m , 999u32 , 7u8) , 0i16 ) ;     # unset → 0
}

#[test] fn t13_anchor_ring_push_and_find ( ) {
  let ring = anchor_ring_new(1000u64) ;
  let h : Bytes<16> = [0xABu8 ; 16] ;
  let rec = anchor_ring_push(ring , 1024u64 , h , 1100u64) ;
  assert_eq!( rec.seq , 0u64 ) ;
  assert_eq!( rec.update_count_at_anchor , 1024u64 ) ;
  assert_eq!( rec.timestamp_offset_seconds , 100u32 ) ;
  let found = anchor_ring_find(ring , 0u64) ;
  assert!( found 'p is-some ) ;
  let missing = anchor_ring_find(ring , 999u64) ;
  assert!( missing 'p is-none ) ;
}

#[test] fn t14_sovereign_revoke_scrubs_reservoir ( ) {
  let r = reservoir_new(0u32 , 0u32) ;
  for p in 1u32..6u32 {
    let rec = QualitySignalRecord {
      template_id: 1u32 , archetype_id: 0u8 , signal_tag: SAK_SIG_SANDBOX_PASS ,
      signal_payload: 0u16 , player_handle: 5u32 , frame_offset: ⟦p as u16⟧
    } ;
    let _ = reservoir_ingest(r , rec) ;
  }
  let scrubbed = reservoir_sovereign_revoke(r , 5u32) ;
  assert!( scrubbed ≥ 5u32 ) ;
}

#[test] fn t15_loop_ingest_increments_rejected_on_bad_signal ( ) {
  let loop = self_authoring_kan_loop_new(0u32 , 0u64 , 0u32) ;
  let outcome = loop_ingest_signal(loop , 1u32 , 99u8 , SAK_SIG_SANDBOX_PASS , 0u16 , 1u32 , 0u16) ;
  assert_eq!( outcome , SAK_OUT_INGEST_BAD_ARCHETYPE ) ;
  assert_eq!( loop.stats.signals_rejected , 1u64 ) ;
}

#[test] fn t16_inspector_denied_when_kanon_fail ( ) {
  let loop = self_authoring_kan_loop_new(0u32 , 0u64 , 0u32) ;
  # No signals → cell does not meet k-anon
  let mask = SigmaMask::admin_read() ;
  let result = inspector_read_cell(loop.bias_map , loop.reservoir , mask , None , 1u32 , 0u8 , 0u64 , None) ;
  assert!( result 'p is-err ) ;
  assert_eq!( result 'p unwrap-err , INSPECTOR_K_ANON_FAIL ) ;
}

#[test] fn t17_signal_polarity_classification ( ) {
  assert!( signal_is_positive(SAK_SIG_SANDBOX_PASS) ) ;
  assert!( ¬ signal_is_positive(SAK_SIG_SANDBOX_FAIL) ) ;
  assert!( signal_is_positive(SAK_SIG_GM_ACCEPT) ) ;
  assert!( ¬ signal_is_positive(SAK_SIG_GM_REJECT) ) ;
  assert!( signal_is_positive(SAK_SIG_REMIX_FORKED) ) ;
  assert!( signal_is_positive(SAK_SIG_RATING_5_STAR) ) ;
  assert!( ¬ signal_is_positive(SAK_SIG_RATING_1_STAR) ) ;
  assert!( signal_is_positive(SAK_SIG_PLAYTEST_PASS) ) ;
}

#[test] fn t18_constants_match_rust_mirror ( ) {
  assert_eq!( SAK_BIAS_Q14_MAX  , 16383i16 ) ;
  assert_eq!( SAK_BIAS_Q14_MIN  , -16383i16 ) ;
  assert_eq!( SAK_BIAS_Q14_ONE  , 16384i32 ) ;
  assert_eq!( SAK_RESERVOIR_CAPACITY    , 4096u32 ) ;
  assert_eq!( SAK_K_ANON_FLOOR_DEFAULT  , 10u32 ) ;
  assert_eq!( SAK_PER_CELL_RATE_LIMIT   , 64u32 ) ;
  assert_eq!( SAK_ANCHOR_EVERY_N_UPDATES , 1024u64 ) ;
  assert_eq!( SAK_ANCHOR_RING_CAPACITY   , 64u32 ) ;
  assert_eq!( SAK_ARCH_COUNT             , 8u8 ) ;
  assert_eq!( SAK_SIG_COUNT              , 10u8 ) ;
}

