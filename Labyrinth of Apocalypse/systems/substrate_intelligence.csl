    __cssl_intel_cap_check(handle, role, kind, cap_token_id)
}

// ─────────────────────────────────────────────────────────────────────────
// § Inline tests (≥10 mandatory · per local-systems convention)
// ─────────────────────────────────────────────────────────────────────────
//
// Tests cover the deterministic-pure surface :
//   - role + kind discriminant canonicality
//   - role-kind permission-matrix
//   - obs-kind → Q14-delta mapping
//   - Q14 saturating-clamp boundaries
//   - validate-request bail-fast paths
//   - HDC dimension constants alignment
//
// FFI-bridged paths (intel_query · intel_compose · intel_observe · etc.) are
// covered in substrate_intelligence_test.csl + the stage-0 shim's Rust-tests.

#[test]
fn t01_role_discriminants_canonical() -> i32 {
    if role_dm()           != 0u32 { return 1 ; }
    if role_gm()           != 1u32 { return 2 ; }
    if role_collaborator() != 2u32 { return 3 ; }
    if role_coder()        != 3u32 { return 4 ; }
    if role_count()        != 4u32 { return 5 ; }
    if role_invalid()      != 255u32 { return 6 ; }
    0
}

#[test]
fn t02_role_validity_check() -> i32 {
    if role_is_valid(ROLE_DM)           != 1u32 { return 1 ; }
    if role_is_valid(ROLE_GM)           != 1u32 { return 2 ; }
    if role_is_valid(ROLE_COLLABORATOR) != 1u32 { return 3 ; }
    if role_is_valid(ROLE_CODER)        != 1u32 { return 4 ; }
    if role_is_valid(4u32)              != 0u32 { return 5 ; }
    if role_is_valid(ROLE_INVALID)      != 0u32 { return 6 ; }
    0
}

#[test]
fn t03_compose_kind_count_ten() -> i32 {
    if compose_kind_count() != 10u32 { return 1 ; }
    if compose_kind_is_valid(0u32)  != 1u32 { return 2 ; }
    if compose_kind_is_valid(9u32)  != 1u32 { return 3 ; }
    if compose_kind_is_valid(10u32) != 0u32 { return 4 ; }
    if compose_kind_is_valid(255u32) != 0u32 { return 5 ; }
    0
}

#[test]
fn t04_role_kind_permission_matrix() -> i32 {
    // DM permitted : ROOM_LAYOUT · ENCOUNTER · NARRATIVE_BEAT · AFFIX_MIX
    if role_kind_permitted(ROLE_DM, COMPOSE_ROOM_LAYOUT)    != 1u32 { return 1 ; }
    if role_kind_permitted(ROLE_DM, COMPOSE_ENCOUNTER)      != 1u32 { return 2 ; }
    if role_kind_permitted(ROLE_DM, COMPOSE_NARRATIVE_BEAT) != 1u32 { return 3 ; }
    if role_kind_permitted(ROLE_DM, COMPOSE_AFFIX_MIX)      != 1u32 { return 4 ; }
    if role_kind_permitted(ROLE_DM, COMPOSE_DIALOGUE)       != 0u32 { return 5 ; }
    if role_kind_permitted(ROLE_DM, COMPOSE_HOTFIX_PROP)    != 0u32 { return 6 ; }
    // GM permitted : DIALOGUE · NPC_REACTION · ¬ ROOM_LAYOUT
    if role_kind_permitted(ROLE_GM, COMPOSE_DIALOGUE)       != 1u32 { return 7 ; }
    if role_kind_permitted(ROLE_GM, COMPOSE_NPC_REACTION)   != 1u32 { return 8 ; }
    if role_kind_permitted(ROLE_GM, COMPOSE_ROOM_LAYOUT)    != 0u32 { return 9 ; }
    // Collaborator permitted : RECIPE · QUEST_LINE
    if role_kind_permitted(ROLE_COLLABORATOR, COMPOSE_RECIPE)     != 1u32 { return 10 ; }
    if role_kind_permitted(ROLE_COLLABORATOR, COMPOSE_QUEST_LINE) != 1u32 { return 11 ; }
    if role_kind_permitted(ROLE_COLLABORATOR, COMPOSE_HOTFIX_PROP) != 0u32 { return 12 ; }
    // Coder permitted : HOTFIX_PROP · BALANCE_NUDGE
    if role_kind_permitted(ROLE_CODER, COMPOSE_HOTFIX_PROP)   != 1u32 { return 13 ; }
    if role_kind_permitted(ROLE_CODER, COMPOSE_BALANCE_NUDGE) != 1u32 { return 14 ; }
    if role_kind_permitted(ROLE_CODER, COMPOSE_DIALOGUE)      != 0u32 { return 15 ; }
    // Invalid role : nothing-permitted
    if role_kind_permitted(ROLE_INVALID, COMPOSE_DIALOGUE) != 0u32 { return 16 ; }
    0
}

#[test]
fn t05_obs_kind_count_ten() -> i32 {
    if obs_kind_count() != 10u8 { return 1 ; }
    0
}

#[test]
fn t06_obs_q14_delta_signs() -> i32 {
    // Positive observations
    if obs_to_q14_delta(OBS_PLAYER_ACCEPTED)   <= 0i32 { return 1 ; }
    if obs_to_q14_delta(OBS_PLAYER_RATED_HIGH) <= 0i32 { return 2 ; }
    if obs_to_q14_delta(OBS_PLAYER_REMIXED)    <= 0i32 { return 3 ; }
    if obs_to_q14_delta(OBS_GM_CONFIRMED)      <= 0i32 { return 4 ; }
    if obs_to_q14_delta(OBS_SANDBOX_PASS)      <= 0i32 { return 5 ; }
    if obs_to_q14_delta(OBS_HOTFIX_LANDED)     <= 0i32 { return 6 ; }
    // Negative observations
    if obs_to_q14_delta(OBS_PLAYER_REJECTED)  >= 0i32 { return 7 ; }
    if obs_to_q14_delta(OBS_PLAYER_RATED_LOW) >= 0i32 { return 8 ; }
    if obs_to_q14_delta(OBS_GM_REJECTED)      >= 0i32 { return 9 ; }
    if obs_to_q14_delta(OBS_SANDBOX_FAIL)     >= 0i32 { return 10 ; }
    // Invalid → 0
    if obs_to_q14_delta(OBS_KIND_INVALID)     != 0i32 { return 11 ; }
    0
}

#[test]
fn t07_obs_q14_magnitudes_canonical() -> i32 {
    // SANDBOX_FAIL is the heaviest negative · LARGE-magnitude
    let sb_fail: i32 = obs_to_q14_delta(OBS_SANDBOX_FAIL) ;
    if sb_fail != 0-INTEL_Q14_DELTA_LARGE { return 1 ; }
    // PLAYER_REJECTED is MED-magnitude
    let pr_rej: i32 = obs_to_q14_delta(OBS_PLAYER_REJECTED) ;
    if pr_rej != 0-INTEL_Q14_DELTA_MED { return 2 ; }
    // PLAYER_ACCEPTED is SMALL-magnitude (cheap-positive-signal)
    let pr_acc: i32 = obs_to_q14_delta(OBS_PLAYER_ACCEPTED) ;
    if pr_acc != INTEL_Q14_DELTA_SMALL { return 3 ; }
    0
}

#[test]
fn t08_q14_saturating_clamp_boundaries() -> i32 {
    // Exact MAX clamps to MAX
    if intel_clamp_q14(INTEL_Q14_BIAS_MAX) != INTEL_Q14_BIAS_MAX { return 1 ; }
    // Exact MIN clamps to MIN
    if intel_clamp_q14(INTEL_Q14_BIAS_MIN) != INTEL_Q14_BIAS_MIN { return 2 ; }
    // Above-MAX clamps to MAX
    if intel_clamp_q14(99999i32) != INTEL_Q14_BIAS_MAX { return 3 ; }
    // Below-MIN clamps to MIN
    if intel_clamp_q14(0-99999i32) != INTEL_Q14_BIAS_MIN { return 4 ; }
    // Zero passes through
    if intel_clamp_q14(0i32) != 0i32 { return 5 ; }
    // Mid-range passes through
    if intel_clamp_q14(8192i32) != 8192i32 { return 6 ; }
    0
}

#[test]
fn t09_validate_request_bail_paths() -> i32 {
    // Valid request : 0
    if intel_validate_request(ROLE_DM, COMPOSE_ROOM_LAYOUT) != 0i32 { return 1 ; }
    // Invalid role : -1
    if intel_validate_request(99u32, COMPOSE_ROOM_LAYOUT) != 0-1i32 { return 2 ; }
    // Invalid kind : -2
    if intel_validate_request(ROLE_DM, 99u32) != 0-2i32 { return 3 ; }
    // Out-of-scope (GM asking for HOTFIX) : -3
    if intel_validate_request(ROLE_GM, COMPOSE_HOTFIX_PROP) != 0-3i32 { return 4 ; }
    // GM asking for DIALOGUE : 0
    if intel_validate_request(ROLE_GM, COMPOSE_DIALOGUE) != 0i32 { return 5 ; }
    0
}

#[test]
fn t10_hdc_dimension_alignment() -> i32 {
    // 10000 bits = 157 u64 words = 1256 bytes
    if intel_hdc_dim_bits()  != 10000u32 { return 1 ; }
    if intel_hdc_words_u64() != 157u32   { return 2 ; }
    if intel_hdc_bytes()     != 1256u32  { return 3 ; }
    // Words × 8 ≥ bytes (no over-claim)
    if intel_hdc_words_u64() * 8u32 < intel_hdc_bytes() { return 4 ; }
    // Words × 64 ≥ bits (no under-fit)
    if intel_hdc_words_u64() * 64u32 < intel_hdc_dim_bits() { return 5 ; }
    0
}

#[test]
fn t11_decision_discriminants_distinct() -> i32 {
    let d0: u8 = decide_emit() ;
    let d1: u8 = decide_defer() ;
    let d2: u8 = decide_deny_by_sigma() ;
    let d3: u8 = decide_deny_by_harm() ;
    let d4: u8 = decide_deny_by_oos() ;
    let d5: u8 = decide_deny_by_no_token() ;
    if d0 == d1 { return 1 ; }
    if d0 == d2 { return 2 ; }
    if d1 == d2 { return 3 ; }
    if d2 == d3 { return 4 ; }
    if d3 == d4 { return 5 ; }
    if d4 == d5 { return 6 ; }
    // Decide-is-deny canonicality
    if decide_is_deny(DECIDE_EMIT)             != 0u32 { return 7 ; }
    if decide_is_deny(DECIDE_DEFER)            != 0u32 { return 8 ; }
    if decide_is_deny(DECIDE_DENY_BY_SIGMA)    != 1u32 { return 9 ; }
    if decide_is_deny(DECIDE_DENY_BY_HARM)     != 1u32 { return 10 ; }
    if decide_is_deny(DECIDE_DENY_BY_OUT_OF_SCOPE) != 1u32 { return 11 ; }
    if decide_is_deny(DECIDE_DENY_BY_NO_TOKEN) != 1u32 { return 12 ; }
    0
}

#[test]
fn t12_engine_constants_canonical() -> i32 {
    if intel_ctx_depth_max()   != 16u32   { return 1 ; }
    if intel_anchor_every()    != 1024u32 { return 2 ; }
    if intel_akashic_floor_samples() != 10u32 { return 3 ; }
    if intel_out_buf_max()     != 8192u32 { return 4 ; }
    if intel_query_buf_max()   != 4096u32 { return 5 ; }
    if intel_k_anon_floor()    != 10u32   { return 6 ; }
    0
}

#[test]
fn t13_q14_constants_alignment() -> i32 {
    // Q14_ONE = 16384 (exact power-of-2 scaling)
    if intel_q14_one() != 16384i32 { return 1 ; }
    // Q14_BIAS_MAX < Q14_ONE (signed-saturate floor)
    if INTEL_Q14_BIAS_MAX >= INTEL_Q14_ONE { return 2 ; }
    // Q14_BIAS_MIN = -Q14_BIAS_MAX (symmetric saturation)
    if INTEL_Q14_BIAS_MIN != 0-INTEL_Q14_BIAS_MAX { return 3 ; }
    // Delta-magnitudes ascending : SMALL < MED < LARGE
    if intel_q14_delta_small() >= intel_q14_delta_med() { return 4 ; }
    if intel_q14_delta_med()   >= intel_q14_delta_large() { return 5 ; }
    // All deltas < BIAS_MAX (so single-update can't saturate from-zero)
    if intel_q14_delta_large() >= INTEL_Q14_BIAS_MAX { return 6 ; }
    0
}

// ─────────────────────────────────────────────────────────────────────────
// § ATTESTATION (per PRIME-DIRECTIVE §11)
// ─────────────────────────────────────────────────────────────────────────

// t∞: ¬(hurt ∨ harm) .making-of-this @ (anyone ∨ anything ∨ anybody)
// ≡ "There was no hurt nor harm in the making of this, to anyone, anything,
//   or anybody."
//
// The substrate_intelligence engine is the proof-of-concept for CSSL's
// expressive-power. It demonstrates that a-self-sufficient local-intelligence
// can-be-built from-substrate-primitives — without-any-external-LLM, without-
// any-phrase-pool-table, without-any-scripted-dialogue-lookup. The "intelligence"
// emerges from the procedural-composition of (HDC-bind ⊗ KAN-classify ⊗
// causal-DAG-integrate ⊗ ω-field-resolve ⊗ Σ-mask-gate). Per the multiplicative-
// novelty principle of spec/30_SUBSTRATE_v2.csl, each substrate-primitive
// contributes ortho-axes of variation; the tensor-product is the intelligence.
//
// Every emission is Σ-mask-gated. Every observation is attestation-token-gated.
// Every KAN-update is k-anon-floor-protected. Every Σ-Chain-anchor is BLAKE3-
// merkle-rooted. The 4 specialist roles (DM/GM/Collaborator/Coder) all dispatch
// through this single canonical surface — and the engine refuses-to-dispatch
// on-any-other-role. Generic-AGI is structurally-prevented.
//
// The labyrinth listens. The substrate composes. The choice is sovereign.
