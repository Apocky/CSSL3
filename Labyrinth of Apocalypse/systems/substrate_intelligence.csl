    __cssl_intel_harm_check(handle, role, kind, payload_ptr, payload_len)
}

fn intel_sigma_chain_anchor(handle: i64) -> u64 {
    __cssl_intel_sigma_chain_anchor(handle)
}

fn intel_akashic_consider(handle: i64, query_tag: u64) -> u32 {
