#[test]
fn test_pattern_size_is_thirty_two() {
    assert_eq(FED_PATTERN_SIZE, 32usize) ;
}

#[test]
fn test_kind_count_canonical() {
    assert_eq(FED_KIND_UNKNOWN,           0u8) ;
    assert_eq(FED_KIND_CELL_STATE,        1u8) ;
    assert_eq(FED_KIND_KAN_BIAS,          2u8) ;
    assert_eq(FED_KIND_CONTENT_DISCOVERY, 3u8) ;
    assert_eq(FED_KIND_CHAT_SHAPE,        4u8) ;
    assert_eq(FED_KIND_HOTFIX_WITNESS,    5u8) ;
    assert_eq(FED_KIND_RECIPE_OUTCOME,    6u8) ;
    assert_eq(FED_KIND_ENCOUNTER_STAT,    7u8) ;
    assert_eq(FED_KIND_NEMESIS_EVENT,     8u8) ;
    assert_eq(FED_KIND_MAX,               8u8) ;
}

#[test]
fn test_caps_all_is_low_nibble() {
    assert_eq(FED_CAPS_ALL,          0x0Fu8) ;
    assert_eq(FED_CAPS_RESERVED_MASK, 0xF0u8) ;
}

#[test]
fn test_caps_disjoint_bits() {
    assert_ne(FED_CAP_EMIT_ALLOWED,         FED_CAP_INGEST) ;
    assert_ne(FED_CAP_INGEST,               FED_CAP_PURGE_ON_REVOKE) ;
    assert_ne(FED_CAP_PURGE_ON_REVOKE,      FED_CAP_REPLAY_DETERMINISTIC) ;
    assert_eq(FED_CAP_EMIT_ALLOWED & FED_CAP_INGEST, 0u8) ;
}

#[test]
fn test_caps_all_is_or_of_four_bits() {
    let composed: u8 = FED_CAP_EMIT_ALLOWED | FED_CAP_INGEST | FED_CAP_PURGE_ON_REVOKE | FED_CAP_REPLAY_DETERMINISTIC ;
    assert_eq(composed, FED_CAPS_ALL) ;
}

#[test]
fn test_k_anon_floor_is_ten() {
    assert_eq(FED_K_ANONYMITY_FLOOR, 10u32) ;
}

#[test]
fn test_k_anon_floor_predicate_at_floor() {
    assert_eq(k_anon_floor_met(10u32), true) ;
    assert_eq(k_anon_floor_met(9u32),  false) ;
    assert_eq(k_anon_floor_met(0u32),  false) ;
}

#[test]
fn test_k_anon_floor_predicate_above() {
    assert_eq(k_anon_floor_met(100u32),    true) ;
    assert_eq(k_anon_floor_met(1_000u32),  true) ;
}

#[test]
fn test_k_anon_floor_tighter_than_chat_sync() {
    // chat-sync uses k=5 ; heartbeat uses k=10.
    let chat_k: u32 = 5u32 ;
    let heart_k: u32 = FED_K_ANONYMITY_FLOOR ;
    assert_eq(heart_k > chat_k, true) ;
}

#[test]
fn test_heartbeat_period_is_sixty_seconds() {
    assert_eq(FED_HEARTBEAT_PERIOD_SECS, 60u64) ;
}

#[test]
fn test_bandwidth_target_is_one_kb_per_minute() {
    assert_eq(FED_BANDWIDTH_TARGET_BPM, 1024u32) ;
}

#[test]
fn test_ts_bucket_truncates_to_minutes() {
    // 100min + 37s drops the 37s.
    let ts: u64 = (60u64 * 100u64) + 37u64 ;
    assert_eq(ts_bucket_60s(ts), 100u32) ;
}

#[test]
fn test_ts_bucket_zero_at_origin() {
    assert_eq(ts_bucket_60s(0u64),  0u32) ;
    assert_eq(ts_bucket_60s(59u64), 0u32) ;
    assert_eq(ts_bucket_60s(60u64), 1u32) ;
}

#[test]
fn test_saturate_cohort_clamps_to_255() {
    assert_eq(saturate_cohort_u8(0u32),       0u8) ;
    assert_eq(saturate_cohort_u8(10u32),     10u8) ;
    assert_eq(saturate_cohort_u8(255u32),   255u8) ;
    assert_eq(saturate_cohort_u8(1_000u32), 255u8) ;
    assert_eq(saturate_cohort_u8(99_999u32), 255u8) ;
}

#[test]
fn test_kind_validity_range() {
    assert_eq(kind_is_valid(0u8),   true) ;   // Unknown sentinel
    assert_eq(kind_is_valid(8u8),   true) ;   // NemesisEvent (max)
    assert_eq(kind_is_valid(9u8),  false) ;
    assert_eq(kind_is_valid(255u8), false) ;
}

#[test]
fn test_cap_flags_well_formed_rejects_reserved() {
    assert_eq(cap_flags_well_formed(0x00u8), true) ;
    assert_eq(cap_flags_well_formed(0x0Fu8), true) ;
    assert_eq(cap_flags_well_formed(0x10u8), false) ;
    assert_eq(cap_flags_well_formed(0xFFu8), false) ;
}

#[test]
fn test_pattern_cap_check_default_deny_with_zero_caps() {
    let mut raw : [u8; 32] = [0u8; 32] ;
    raw[FED_OFF_KIND] = FED_KIND_CELL_STATE ;
    raw[FED_OFF_CAP_FLAGS] = 0u8 ;
    assert_eq(pattern_cap_check(&raw, FED_CAP_EMIT_ALLOWED), false) ;
    assert_eq(pattern_cap_check(&raw, FED_CAP_INGEST),       false) ;
}

#[test]
fn test_pattern_cap_check_passes_with_full_caps() {
    let mut raw : [u8; 32] = [0u8; 32] ;
    raw[FED_OFF_KIND] = FED_KIND_KAN_BIAS ;
    raw[FED_OFF_CAP_FLAGS] = FED_CAPS_ALL ;
    assert_eq(pattern_cap_check(&raw, FED_CAP_EMIT_ALLOWED), true) ;
    assert_eq(pattern_cap_check(&raw, FED_CAP_INGEST),       true) ;
    assert_eq(pattern_cap_check(&raw, FED_CAPS_ALL),         true) ;
}

#[test]
fn test_pattern_cap_check_rejects_reserved_bit() {
    let mut raw : [u8; 32] = [0u8; 32] ;
    raw[FED_OFF_KIND] = FED_KIND_CELL_STATE ;
    raw[FED_OFF_CAP_FLAGS] = 0x10u8 ;  // bit-4 reserved
    assert_eq(pattern_cap_check(&raw, FED_CAP_EMIT_ALLOWED), false) ;
}

#[test]
fn test_pattern_cloud_eligible_requires_emit_and_ingest() {
    let mut raw : [u8; 32] = [0u8; 32] ;
    raw[FED_OFF_KIND] = FED_KIND_CELL_STATE ;

    // Only EMIT_ALLOWED · should reject (missing INGEST).
    raw[FED_OFF_CAP_FLAGS] = FED_CAP_EMIT_ALLOWED ;
    assert_eq(pattern_cloud_eligible(&raw), false) ;

    // Only INGEST · should reject (missing EMIT_ALLOWED).
    raw[FED_OFF_CAP_FLAGS] = FED_CAP_INGEST ;
    assert_eq(pattern_cloud_eligible(&raw), false) ;

    // Both bits · should accept.
    raw[FED_OFF_CAP_FLAGS] = FED_CAP_EMIT_ALLOWED | FED_CAP_INGEST ;
    assert_eq(pattern_cloud_eligible(&raw), true) ;
}

#[test]
fn test_pattern_cloud_eligible_rejects_unknown_kind() {
    let mut raw : [u8; 32] = [0u8; 32] ;
    raw[FED_OFF_KIND] = 99u8 ;  // out-of-range
    raw[FED_OFF_CAP_FLAGS] = FED_CAPS_ALL ;
    assert_eq(pattern_cloud_eligible(&raw), false) ;
}

#[test]
fn test_pattern_field_offsets_are_canonical() {
    assert_eq(FED_OFF_KIND,         0usize) ;
    assert_eq(FED_OFF_CAP_FLAGS,    1usize) ;
    assert_eq(FED_OFF_COHORT,       2usize) ;
    assert_eq(FED_OFF_CONFIDENCE_Q8, 3usize) ;
    assert_eq(FED_OFF_TS,           4usize) ;
    assert_eq(FED_OFF_PAYLOAD_HASH, 8usize) ;
    assert_eq(FED_OFF_EMITTER,      16usize) ;
    assert_eq(FED_OFF_SIG,          24usize) ;
}

#[test]
fn test_pattern_field_layout_does_not_overlap() {
    // Sum of field-sizes equals pattern-size.
    let size_kind:        usize = 1usize ;
    let size_cap_flags:   usize = 1usize ;
    let size_cohort:      usize = 1usize ;
    let size_confidence:  usize = 1usize ;
    let size_ts:          usize = 4usize ;
    let size_payload_hash: usize = 8usize ;
    let size_emitter:     usize = 8usize ;
    let size_sig:         usize = 8usize ;
    let total: usize = size_kind + size_cap_flags + size_cohort + size_confidence
                     + size_ts + size_payload_hash + size_emitter + size_sig ;
    assert_eq(total, FED_PATTERN_SIZE) ;
}

#[test]
fn test_quantize_confidence_clamps_to_range() {
    assert_eq(quantize_confidence(0.0f32),    0u8) ;
    assert_eq(quantize_confidence(1.0f32),    255u8) ;
    assert_eq(quantize_confidence(-1.0f32),   0u8) ;     // clamp-low
    assert_eq(quantize_confidence(2.0f32),    255u8) ;   // clamp-high
}

#[test]
fn test_cloud_state_constants_distinct() {
    assert_ne(FED_CLOUD_UP,   FED_CLOUD_DOWN) ;
    assert_ne(FED_CLOUD_DOWN, FED_CLOUD_UNKNOWN) ;
    assert_eq(FED_CLOUD_UP,      0u8) ;
    assert_eq(FED_CLOUD_DOWN,    1u8) ;
    assert_eq(FED_CLOUD_UNKNOWN, 2u8) ;
}

#[test]
fn test_ffi_error_codes_distinct() {
    assert_eq(FED_FFI_OK,                 0i32) ;
    assert_eq(FED_FFI_ERR_INVALID_ARG,    -1i32) ;
    assert_eq(FED_FFI_ERR_CAP_DENIED,     -2i32) ;
    assert_eq(FED_FFI_ERR_K_ANON_NOT_MET, -4i32) ;
    assert_eq(FED_FFI_ERR_QUEUE_FULL,     -6i32) ;
    assert_ne(FED_FFI_ERR_INVALID_ARG, FED_FFI_ERR_CAP_DENIED) ;
    assert_ne(FED_FFI_ERR_K_ANON_NOT_MET, FED_FFI_ERR_QUEUE_FULL) ;
}

#[test]
fn test_default_queue_capacity_one_hour_at_60s() {
    // 60 bundles × 60s/bundle = 3600s = 1 hour.
    assert_eq(FED_DEFAULT_QUEUE_CAPACITY, 60u32) ;
    let buffer_secs: u64 = (FED_DEFAULT_QUEUE_CAPACITY as u64) * FED_HEARTBEAT_PERIOD_SECS ;
    assert_eq(buffer_secs, 3_600u64) ;
}

#[test]
fn test_protocol_version_is_one() {
    assert_eq(FED_BUNDLE_PROTOCOL_VERSION, 1u32) ;
}

#[test]
fn test_max_patterns_per_bundle_is_256() {
    assert_eq(FED_BUNDLE_MAX_PATTERNS, 256usize) ;
}

// ─────────────────────────────────────────────────────────────────────────
// § Flow + Compliance attestation  (PRIME_DIRECTIVE.md § 11)
// ─────────────────────────────────────────────────────────────────────────
//
// SOVEREIGN-REVOKE (break-glass · idempotent) cascades :
//   1. zero cap-policy   (outgoing-zero next-tick)
//   2. purge local ring  (defense-in-depth)
//   3. drain entire queue (anchor-bound bundles cannot be edited)
//   4. emit PurgeRequest (caller HTTP-POSTs to /api/mycelium/heartbeat)
//   5. cloud cascades : drop emitter from staged-cohorts · tombstone-row
//
// BACKPRESSURE (cloud-down tolerance) :
//   mark_cloud_down → tick queues bundles (drop-oldest @ 60-bundle cap) ;
//   cron probes /health · on 200 → mark_cloud_up + drain-until-empty.
//
// Σ-MASK GATES @ THREE points :
//   emit-ring-side · emit-bundle-side · cloud-ingest-side.
//
// k-anonymity floor enforced @ SQL CHECK(cohort_size >= 10) on
// mycelium_federation_public ; structural-enforcement means even a bug in
// the promotion trigger cannot leak below-floor rows.
//
// Σ-Chain-anchor : every emitted bundle carries a 32-byte BLAKE3 anchor.
// Tamper-evident + replay-stable + immutable-attribution-survives-revoke.
//
// ¬ raw-payload egress · ¬ surveillance · ¬ IP-logging beyond-session ·
// ¬ behavioral-fingerprinting.
//
// Attestation : there was no hurt nor harm in the making of this, to anyone,
// anything, or anybody.
