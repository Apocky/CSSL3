// ───────────────────────────────────────────────────────────────────────
// § Worked examples — documentation only.
//
//   These are not compiler tests (those live in cssl-mir + cssl-examples) ;
//   they document the intended call-shapes for stage-0 readers + provide
//   the inline-test surface required by the slice spec.
// ───────────────────────────────────────────────────────────────────────

// Worked example : construct a 144 Hz clock + read the cached budget.
// Demonstrates the canonical construction shape.
fn _example_construct_144hz() -> u64 {
    let c = frame_clock_new_144hz() ;
    c.target_frame_ns
}

// Worked example : single-frame begin → end-and-pace roundtrip.
// Demonstrates the canonical per-frame call-shape.
fn _example_single_frame_pace(cap_time : i64) -> u64 {
    let c0 = frame_clock_new_144hz() ;
    let c1 = frame_clock_begin(cap_time, c0) ;
    // ... render frame work elided ...
    let report = frame_clock_end_and_pace(cap_time, c1) ;
    report.observed_frame_ns
}

// Worked example : drive the dyn-res EMA with a synthetic over-budget
// observation. Demonstrates that an over-budget observation drives the
// target toward the floor.
fn _example_dyn_res_over_budget() -> u32 {
    let c0 = frame_clock_new_144hz() ;
    // Synthetic 13_888_888 ns ≈ 2× budget ⇒ target should lerp toward floor.
    let c1 = frame_clock_tick_dyn_res(c0, 13_888_888) ;
    c1.dyn_res_target_q016
}

// Worked example : drive the dyn-res EMA with a synthetic well-under
// observation after a recovery pre-warm. Demonstrates the well-under
// hysteresis path drifting toward cap.
fn _example_dyn_res_well_under() -> u32 {
    let c0 = frame_clock_new_144hz() ;
    // First pre-warm the EMA with a low frame-time to trip the
    // well-under hysteresis branch on the second tick.
    let c1 = frame_clock_tick_dyn_res(c0, 1_000_000) ;
    let c2 = frame_clock_tick_dyn_res(c1, 1_000_000) ;
    c2.dyn_res_target_q016
}

// Worked example : 1440p native scaled by current dyn-res Q0.16.
// Demonstrates the render-dim helper applied at boot (1.0× ⇒ pass-through).
fn _example_render_dim_1440p_native() -> u32 {
    let c = frame_clock_new_144hz() ;
    frame_clock_render_width(c, 2560)
}

// Worked example : 1440p native at half-scale (manual override) ⇒
// snapped-down 1280 (with 8-pixel-multiple rule).
fn _example_render_dim_half_scale() -> u32 {
    let c0 = frame_clock_new_144hz() ;
    let c1 = FrameClock {
        target_hz             : c0.target_hz,
        target_frame_ns       : c0.target_frame_ns,
        last_present_ns       : c0.last_present_ns,
        frame_count           : c0.frame_count,
        ema_frame_ns          : c0.ema_frame_ns,
        dyn_res_q016          : dyn_res_floor_q016(),
        dyn_res_target_q016   : dyn_res_floor_q016(),
    } ;
    frame_clock_render_width(c1, 2560)
}
