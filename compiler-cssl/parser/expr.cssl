fn has_trait_named(m : &Module, name : &str) -> bool {
    let n = vec_len::<Item>(m.items) ;
    let mut i : u32 = 0'u32 ;
    let mut found = false ;
    while i < n && !found {
        match vec_get_unchecked::<Item>(m.items, i) {
            Item::Trait(_) => { found = true ; }
            _              => {}
        }
        i = i + 1'u32 ;
    }
    found
}

fn is_binary(e : &Expr) -> bool {
    match e.kind {
        ExprKind::Binary(_, _, _) => true,
        _                          => false,
    }
}

fn is_unary(e : &Expr) -> bool {
    match e.kind {
        ExprKind::Unary(_, _) => true,
        _                      => false,
    }
}

fn is_call(e : &Expr) -> bool {
    match e.kind {
        ExprKind::Call(_, _) => true,
        _                     => false,
    }
}

fn is_path(e : &Expr) -> bool {
    match e.kind {
        ExprKind::Path(_)  => true,
        ExprKind::Field(_, _) => true,    // tail might be field after path-cont
        _                  => false,
    }
}

fn is_if(e : &Expr) -> bool {
    match e.kind {
        ExprKind::If(_, _, _) => true,
        _                      => false,
    }
}

fn is_match(e : &Expr) -> bool {
    match e.kind {
        ExprKind::Match(_, _) => true,
        _                      => false,
    }
}

fn is_lambda(e : &Expr) -> bool {
    match e.kind {
        ExprKind::Lambda(_, _, _) => true,
        _                          => false,
    }
}

// `_run_all_tests()` — convenience harness : returns count of passing tests.
fn _run_all_tests() -> u32 {
    let mut n : u32 = 0'u32 ;
    if _test_let_typed()             { n = n + 1'u32 ; }
    if _test_let_mut_untyped()       { n = n + 1'u32 ; }
    if _test_const_decl()            { n = n + 1'u32 ; }
    if _test_fn_with_generics()      { n = n + 1'u32 ; }
    if _test_struct_named()          { n = n + 1'u32 ; }
    if _test_struct_tuple()          { n = n + 1'u32 ; }
    if _test_enum_variants()         { n = n + 1'u32 ; }
    if _test_impl_inherent()         { n = n + 1'u32 ; }
    if _test_impl_trait()            { n = n + 1'u32 ; }
    if _test_trait_decl()            { n = n + 1'u32 ; }
    if _test_binary_precedence()     { n = n + 1'u32 ; }
    if _test_unary_op()              { n = n + 1'u32 ; }
    if _test_call_args()             { n = n + 1'u32 ; }
    if _test_path_with_generics()    { n = n + 1'u32 ; }
    if _test_if_expr()               { n = n + 1'u32 ; }
    if _test_match_expr()            { n = n + 1'u32 ; }
    if _test_lambda()                { n = n + 1'u32 ; }
    n
}
