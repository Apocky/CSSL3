§ STABLE-API CONTRACTS  ‼ downstream content-authoring depends on these
  W! Q-* content-slices CONSUME these surfaces ; their shape is FIXED
     post-v1.1. Breaking changes require a full DECISIONS-entry +
     downstream-Q-* re-validation.

  cssl-substrate-omega-field
    type FieldCell : repr(C) 72-byte 7-facet
      facet[0] potential   : f32
      facet[1] flux        : Vec3<f32>
      facet[2] entropy     : f32
      facet[3] amplitude   : Vec2<f32>  // psi-field
      facet[4] coherence   : f32
      facet[5] tension     : f32
      facet[6] consent     : SigmaMask  // 16B std430 packed-bitmap
    fn evolve(field : &mut OmegaField, dt : f32) {Travel + Crystallize}
    fn read_facet(field : &OmegaField, cell : CellId, facet : FacetIdx) -> f32

  cssl-substrate-kan
    type KanRuntime : Φ-pattern-pool + KAN-evaluator
    fn evaluate(rt : &KanRuntime, sample : KanSample) -> f32
    fn bake_lut(rt : &KanRuntime, range : SampleRange) -> KanLut

  cssl-render-v2::pipeline
    enum StageRole : Embodiment | GazeCollapse | OmegaFieldUpdate |
                     WaveSolver | SdfRaymarch | KanBrdf |
                     FractalAmplifier | CompanionSemantic | MiseEnAbyme |
                     ToneMap | AppSpaceWarp | XrCompose
    enum TwelveStagePipelineSlot : Slot1Embodiment ... Slot12XrCompose
    impl TwelveStagePipelineSlot {
      fn allowed_role(self) -> StageRole
    }
    impl StageRole {
      fn slot_index(self) -> u8  // 1-based
    }
    trait StageNode {
      fn role(&self) -> StageRole;
      fn slot(&self) -> TwelveStagePipelineSlot;
      fn run(&mut self, ctx : &mut RenderCtx);
    }

  cssl-host-openxr
    type OpenXrSession : opaque-handle
    fn claim_session_with_consent(prompt : ConsentPrompt) -> Result<OpenXrSession, PD0001>
    fn destroy_session(s : OpenXrSession)
    impl Drop for OpenXrSession  // automatic cleanup

  cssl-substrate-prime-directive
    enum Prohibition : 21 variants  (PD0000 + PD0001..PD0017 + PD0018..PD0020)
    type CapToken : non-Copy + non-Clone proof-of-grant
    fn substrate_halt(reason : HaltReason) -> Result<(), HaltError>
                                              // 1ms latency budget
    const ATTESTATION : &'static str
                          // = "There was no hurt nor harm in the making
                          //    of this, to anyone, anything, or anybody."

  loa-game (Phase-I scaffold ; Q-* surface)
    Stub variants per § scaffold-mapping above ; Q-* slices replace
    Stub with Apocky-direction variants.
    13 OmegaSystem impls (one per omega_step phase) — STABLE
    one_omega_step_runs_all_thirteen_phases test — STABLE
    save_then_load_round_trips_bit_equal test — STABLE
    consent-architecture surface — STABLE

